    <!-- YouTube mark (Play triangle in rounded rect) -->
    <StreamGeometry x:Key="IconYouTubeGeometry">M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.546 12 3.546 12 3.546s-7.505 0-9.377.504A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.504 9.376.504 9.376.504s7.505 0 9.377-.504a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z</StreamGeometry>
    <!-- Globe/Web icon -->
    <StreamGeometry x:Key="IconWebGeometry">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z</StreamGeometry>

    <!-- Legacy text fallbacks keep backward compatibility -->
    <x:String x:Key="IconDiscord">D</x:String>
    <x:String x:Key="IconYouTube">Y</x:String>
    <x:String x:Key="IconFacebook">f</x:String>
    <x:String x:Key="IconInstagram">I</x:String>
    <x:String x:Key="IconGitHub">G</x:String>

    <!-- ═══════════════ SOCIAL BRAND COLORS ═══════════════ -->
    <Color x:Key="DiscordBrand">#5865F2</Color>
    <Color x:Key="GitHubBrand">#f0f0f0</Color>
    <Color x:Key="YouTubeBrand">#FF0000</Color>
    <Color x:Key="WebBrand">#00d4aa</Color>
    <SolidColorBrush x:Key="DiscordBrandBrush" Color="{StaticResource DiscordBrand}"/>
    <SolidColorBrush x:Key="GitHubBrandBrush" Color="{StaticResource GitHubBrand}"/>
    <SolidColorBrush x:Key="YouTubeBrandBrush" Color="{StaticResource YouTubeBrand}"/>
    <SolidColorBrush x:Key="WebBrandBrush" Color="{StaticResource WebBrand}"/>

    <!-- ═══════════════ INSTANCE / GAME ═══════════════ -->
    <x:String x:Key="IconFolder">□</x:String>
    <x:String x:Key="IconMods">⊞</x:String>
    <x:String x:Key="IconConfig">⌘</x:String>
    <x:String x:Key="IconCrash">✕</x:String>
    <x:String x:Key="IconBackup">▣</x:String>
    <x:String x:Key="IconGallery">▥</x:String>
    <x:String x:Key="IconPerformance">▤</x:String>

    <!-- ═══════════════ ICON SIZES ═══════════════ -->
    <x:Double x:Key="IconSizeSmall">14</x:Double>
    <x:Double x:Key="IconSizeMedium">18</x:Double>
    <x:Double x:Key="IconSizeLarge">22</x:Double>
    <x:Double x:Key="IconSizeNav">20</x:Double>
    <x:Double x:Key="IconSizeHero">28</x:Double>

</ResourceDictionary>