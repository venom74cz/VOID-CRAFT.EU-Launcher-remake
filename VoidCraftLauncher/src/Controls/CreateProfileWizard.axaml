<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             x:Class="VoidCraftLauncher.Controls.CreateProfileWizard"
             x:DataType="vm:MainViewModel"
             x:Name="WizardRoot">

    <Grid IsVisible="{Binding IsCreateProfileModalVisible}">
        <Border Background="{DynamicResource BgCanvasBrush}" Opacity="0.82"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <Border Classes="overlay-panel"
                Background="{DynamicResource BgShellBrush}"
                CornerRadius="{DynamicResource RadiusCard}"
                BorderBrush="{DynamicResource StrokeSoftBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="620"
                MaxHeight="760"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.85"/>
            </Border.Effect>

            <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0"
                        Background="{DynamicResource BgElevatedBrush}"
                        CornerRadius="16,16,0,0"
                        Padding="28,22"
                        BorderBrush="{DynamicResource StrokeSoftBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Spacing="18">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Nová instance" FontSize="24" FontWeight="ExtraBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CreateProfileStepTitle}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBBrush}"/>
                                <TextBlock Text="{Binding CreateProfileStepSubtitle}" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding CloseCreateProfileModalCommand}"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Padding="8"
                                    Cursor="Hand"
                                    CornerRadius="{DynamicResource RadiusSmall}"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{StaticResource IconClose}" FontSize="15"/>
                            </Button>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="14" Padding="14,12"
                                    BorderBrush="{DynamicResource PrimaryBBrush}" BorderThickness="1"
                                    IsVisible="{Binding IsCreateProfileIdentityStep}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="01" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                    <TextBlock Text="Název a umístění" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="14" Padding="14,12"
                                    BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                                    IsVisible="{Binding !IsCreateProfileIdentityStep}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="01" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="Název a umístění" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="14" Padding="14,12"
                                    BorderBrush="{DynamicResource PrimaryBBrush}" BorderThickness="1"
                                    IsVisible="{Binding IsCreateProfileRuntimeStep}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="02" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                    <TextBlock Text="Runtime" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="14" Padding="14,12"
                                    BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                                    IsVisible="{Binding !IsCreateProfileRuntimeStep}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="02" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="Runtime" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{DynamicResource BgPanelBrush}" CornerRadius="14" Padding="14,12"
                                    BorderBrush="{DynamicResource PrimaryBBrush}" BorderThickness="1"
                                    IsVisible="{Binding IsCreateProfileReviewStep}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="03" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                    <TextBlock Text="Kontrola" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource BgPanelBrush}" CornerRadius="14" Padding="14,12"
                                    BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                                    IsVisible="{Binding !IsCreateProfileReviewStep}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="03" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="Kontrola" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="20" Margin="28,24">
                        <StackPanel Spacing="6" IsVisible="{Binding IsCreateProfileIdentityStep}">
                            <TextBlock Text="Jak se má instance jmenovat" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding NewProfileName}" Watermark="Např. My Epic Survival"/>

                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="14" Padding="16"
                                    BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Výsledné umístění" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding CreateProfilePathPreview}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                    <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="10" Padding="12,10">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <TextBlock Text="{StaticResource IconLibrary}" FontSize="18" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="Technický název složky" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding CreateProfileDirectoryName}" FontSize="13" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="16" IsVisible="{Binding IsCreateProfileRuntimeStep}">
                            <Grid ColumnDefinitions="*,12,*">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Minecraft verze" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <ComboBox SelectedItem="{Binding NewProfileMcVersion}"
                                              ItemsSource="{Binding AvailableMcVersions}"
                                              PlaceholderText="1.21.1"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="Mod loader" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <ComboBox SelectedItem="{Binding NewProfileModLoader}" HorizontalAlignment="Stretch">
                                        <x:String>fabric</x:String>
                                        <x:String>forge</x:String>
                                        <x:String>neoforge</x:String>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Verze loaderu" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <ComboBox SelectedItem="{Binding NewProfileModLoaderVersion}"
                                          ItemsSource="{Binding AvailableModLoaderVersions}"
                                          PlaceholderText="Vyber kompatibilní build"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="14" Padding="16"
                                    BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Border Width="36" Height="36" CornerRadius="18"
                                            Background="{DynamicResource BgInteractiveBrush}">
                                        <TextBlock Text="{StaticResource IconConfig}" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Stav runtime výběru" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CreateProfileRuntimeStatus}" FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="16" IsVisible="{Binding IsCreateProfileReviewStep}">
                            <Border Classes="card">
                                <StackPanel Spacing="16">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="Finální konfigurace" FontSize="16" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Instance se po vytvoření otevře v detail view a připraví se pro správu modů."
                                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{DynamicResource SuccessBrush}" CornerRadius="999"
                                                Padding="10,5" VerticalAlignment="Top">
                                            <TextBlock Text="Ready" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BgCanvasBrush}"/>
                                        </Border>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="14">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Instance" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding CreateProfileDirectoryName}" FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="14">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Runtime" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding CreateProfileRuntimeSummary}" FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="12" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Cílová cesta" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                            <TextBlock Text="{Binding CreateProfilePathPreview}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource BgElevatedBrush}"
                        CornerRadius="0,0,16,16"
                        Padding="28,18"
                        BorderBrush="{DynamicResource StrokeSoftBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding CreateProfileWizardHint}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
                            <Button Content="Zrušit" Command="{Binding CloseCreateProfileModalCommand}"
                                    Classes="ghost" FontSize="13" Padding="16,10"/>
                            <Button Grid.Column="1" Content="Zpět" Command="{Binding PreviousCreateProfileStepCommand}"
                                    Classes="secondary" FontSize="13" Padding="16,10"
                                    IsVisible="{Binding CanGoBackCreateProfileStep}"/>
                            <TextBlock Grid.Column="3" Text="Krok 1/3" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                                       IsVisible="{Binding IsCreateProfileIdentityStep}"/>
                            <TextBlock Grid.Column="3" Text="Krok 2/3" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                                       IsVisible="{Binding IsCreateProfileRuntimeStep}"/>
                            <TextBlock Grid.Column="3" Text="Krok 3/3" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                                       IsVisible="{Binding IsCreateProfileReviewStep}"/>

                            <Button Grid.Column="4" Content="Pokračovat" Command="{Binding NextCreateProfileStepCommand}"
                                    Classes="primary" FontSize="14" Padding="24,10"
                                    IsVisible="{Binding !IsCreateProfileReviewStep}"
                                    IsEnabled="{Binding CanAdvanceCreateProfileStep}"/>
                            <Button Grid.Column="4" Content="Vytvořit instanci" Command="{Binding CreateCustomProfileCommand}"
                                    Classes="primary" FontSize="14" Padding="24,10"
                                    IsVisible="{Binding IsCreateProfileReviewStep}"
                                    IsEnabled="{Binding CanCreateCustomProfile}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>