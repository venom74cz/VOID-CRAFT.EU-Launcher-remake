<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             x:Class="VoidCraftLauncher.Controls.UpdatePromptSheet"
             x:DataType="vm:MainViewModel">

    <Grid IsVisible="{Binding IsUpdatePromptVisible}">
        <Border Background="{DynamicResource BgCanvasBrush}" Opacity="0.82"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <Border Background="{DynamicResource BgShellBrush}" CornerRadius="{DynamicResource RadiusCard}"
                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="600" Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.85"/>
            </Border.Effect>

            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <Border Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                        CornerRadius="16,16,0,0" Padding="28,20"
                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="{DynamicResource AccentTealBrush}" Opacity="0.15">
                            <TextBlock Text="🔄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Nová aktualizace k dispozici" FontSize="20" FontWeight="ExtraBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}">
                                <Run Text="{Binding UpdatePromptModpackName}"/>
                                <Run Text=" → "/>
                                <Run Text="{Binding UpdatePromptTargetVersionName}"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Command="{Binding SkipUpdatePromptCommand}"
                                Background="Transparent" Foreground="{DynamicResource TextMutedBrush}"
                                FontSize="16" Padding="6" Cursor="Hand"
                                CornerRadius="{DynamicResource RadiusSmall}" VerticalAlignment="Top">
                            <TextBlock Text="✕"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Body (Changelog) -->
                <Border Grid.Row="1" Padding="28,20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="CO JE NOVÉHO?" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{DynamicResource RadiusSmall}"
                                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                                MaxHeight="220">
                            <ScrollViewer Margin="0" Padding="14">
                                <TextBlock Text="{Binding UpdatePromptChangelog}"
                                           TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <Border Grid.Row="2" Background="{DynamicResource BgElevatedBrush}"
                        CornerRadius="0,0,16,16" Padding="28,16"
                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                        <Button Content="Ne, pokračovat bez updatu" Command="{Binding SkipUpdatePromptCommand}"
                                Classes="ghost" FontSize="13" Padding="16,10" Grid.Column="0"/>
                        
                        <Button Content="Zálohovat a aktualizovat" Command="{Binding ConfirmUpdatePromptWithBackupCommand}"
                                Classes="secondary" FontSize="13" Padding="16,10" Grid.Column="2"/>
                                
                        <Button Content="Aktualizovat a HRÁT" Command="{Binding ConfirmUpdatePromptCommand}"
                                Classes="primary" FontSize="13" Padding="20,10" Grid.Column="3"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
