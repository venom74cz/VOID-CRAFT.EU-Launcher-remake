<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             xmlns:models="using:VoidCraftLauncher.Models"
             xmlns:controls="using:VoidCraftLauncher.Controls"
             xmlns:converters="using:VoidCraftLauncher.Converters"
             xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="VoidCraftLauncher.Controls.InstanceWorkspaceView"
             x:DataType="vm:MainViewModel"
             x:Name="WorkspaceRoot">

    <UserControl.Resources>
        <converters:RamValueConverter x:Key="RamValueConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Instance Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BgShellBrush}"
                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Back nav -->
                <Grid Margin="24,14,24,0" ColumnDefinitions="Auto,*">
                    <Button Command="{Binding GoToHomeCommand}" Classes="ghost" Padding="6,4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="←" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="→" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Knihovna" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="›" FontSize="14" Foreground="{DynamicResource StrokeSoftBrush}" Margin="6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentWorkspaceDisplayName}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Instance Info Row -->
                <Grid Margin="24,14,24,14" ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                    <!-- Logo -->
                    <Border Width="56" Height="56" CornerRadius="{DynamicResource RadiusControl}" ClipToBounds="True"
                            Background="{DynamicResource BgInteractiveBrush}">
                        <asyncImage:AdvancedImage Source="{Binding CurrentModpack.LogoUrl}" Stretch="UniformToFill"/>
                    </Border>

                    <!-- Name & info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="2">
                        <TextBlock Text="{Binding CurrentWorkspaceDisplayName}" FontSize="20" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{StaticResource IconPlay}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentModpack.VersionTransitionText}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <WrapPanel Orientation="Horizontal" IsVisible="{Binding HasCurrentWorkspaceCreatorMetadata}">
                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="999" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding CurrentWorkspaceMetadataSummary}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="999" Padding="10,4" Margin="0,0,8,0" IsVisible="{Binding HasCurrentWorkspacePrimaryServer}">
                                <TextBlock Text="{Binding CurrentWorkspacePrimaryServerLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="999" Padding="10,4">
                                <TextBlock Text="{Binding CurrentWorkspaceRecommendedRamLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Play Button -->
                    <Button Grid.Column="2" Command="{Binding SelectAndPlayCommand}" CommandParameter="{Binding CurrentModpack}"
                            IsEnabled="{Binding !IsLaunching}"
                            Background="{DynamicResource PrimaryBBrush}" Foreground="{DynamicResource BgCanvasBrush}"
                            CornerRadius="20" Padding="24,10" Cursor="Hand" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="▶" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Hrát" FontWeight="ExtraBold" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- Settings Gear -->
                    <Button Grid.Column="3" Command="{Binding SelectAndConfigureCommand}" CommandParameter="{Binding CurrentModpack}"
                            Background="{DynamicResource BgInteractiveBrush}" CornerRadius="20" Padding="10" Cursor="Hand" Margin="0,0,4,0"
                            ToolTip.Tip="Nastavení instance">
                        <TextBlock Text="{StaticResource IconSettings}" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>

                    <!-- Three dots menu -->
                    <Button Grid.Column="4" Background="{DynamicResource BgInteractiveBrush}" CornerRadius="20" Padding="10" Cursor="Hand">
                        <TextBlock Text="⋮" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Bold"/>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Otevřít složku" Command="{Binding OpenModpackFolderCommand}"/>
                                <MenuItem Header="Přeinstalovat" Command="{Binding ReinstallModpackContextCommand}" CommandParameter="{Binding CurrentModpack}"/>
                                <Separator/>
                                <MenuItem Header="Smazat" Command="{Binding DeleteModpackContextCommand}" CommandParameter="{Binding CurrentModpack}"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <Border Margin="24,0,24,16" Height="164" CornerRadius="18" ClipToBounds="True" IsVisible="{Binding HasCurrentWorkspaceHeroPreview}">
                    <Grid>
                        <asyncImage:AdvancedImage Source="{Binding CurrentWorkspaceHeroPreview}" Stretch="UniformToFill"/>
                        <Border Background="#A5121624"/>
                        <Grid Margin="22,18,22,18" RowDefinitions="*,Auto">
                            <StackPanel Spacing="10" VerticalAlignment="Top">
                                <TextBlock Text="{Binding CurrentWorkspaceDisplayName}" FontSize="24" FontWeight="ExtraBold" Foreground="White" TextWrapping="Wrap" MaxWidth="520"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                <Border Background="#2A141C2C" CornerRadius="999" Padding="10,4">
                                    <TextBlock Text="{Binding CurrentWorkspaceMetadataSummary}" FontSize="10" Foreground="White"/>
                                </Border>
                                <Border Background="#2A141C2C" CornerRadius="999" Padding="10,4" IsVisible="{Binding HasCurrentWorkspacePrimaryServer}">
                                    <TextBlock Text="{Binding CurrentWorkspacePrimaryServerLabel}" FontSize="10" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Instance Tabs -->
        <TabControl Grid.Row="1" Margin="24,4,24,0">

            <!-- TAB: Přehled (Overview) -->
            <TabItem Header="Přehled">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="0,16,0,60">
                        <StackPanel Spacing="16" MaxWidth="900">
                            <Border Classes="card">
                                <Grid ColumnDefinitions="*,260" ColumnSpacing="20">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Krátký popis" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                            <TextBlock Text="{Binding CurrentWorkspaceDescription}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" LineHeight="20"
                                                       IsVisible="{Binding HasCurrentWorkspaceDescription}"/>
                                            <StackPanel IsVisible="{Binding !HasCurrentWorkspaceDescription}">
                                                <TextBlock Text="Popis není k dispozici." Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" FontSize="13"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource StrokeSoftBrush}" Margin="0,2"/>

                                        <StackPanel Spacing="10" IsVisible="{Binding HasCurrentWorkspaceFullDescription}">
                                            <TextBlock Text="Podrobnosti" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15"/>
                                            <TextBlock Text="{Binding CurrentWorkspaceDescriptionIntro}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" LineHeight="22"
                                                       IsVisible="{Binding HasCurrentWorkspaceDescriptionIntro}"/>

                                            <ItemsControl ItemsSource="{Binding CurrentWorkspaceDescriptionSections}" IsVisible="{Binding HasCurrentWorkspaceDescriptionSections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:InstanceOverviewDescriptionSection">
                                                        <Border Background="{DynamicResource BgElevatedBrush}"
                                                                BorderBrush="{DynamicResource StrokeSoftBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="16"
                                                                Padding="14">
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Body}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap" LineHeight="20"
                                                                           IsVisible="{Binding HasBody}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="{Binding CurrentWorkspaceFullDescription}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" LineHeight="22"
                                                       IsVisible="{Binding HasPlainCurrentWorkspaceFullDescription}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="{DynamicResource BgElevatedBrush}"
                                            BorderBrush="{DynamicResource StrokeSoftBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="16">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="Info pro hráče" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15"/>

                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                                <TextBlock Text="Pack" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CurrentWorkspaceDisplayName}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="1" Text="Autoři" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentWorkspaceAuthorLabel}" Foreground="{DynamicResource PrimaryBBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="2" Text="Minecraft" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentWorkspaceMinecraftVersion}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="3" Text="Loader" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentWorkspaceLoaderLabel}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="4" Text="Channel" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentWorkspaceReleaseChannelLabel}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="999" Padding="10,5" IsVisible="{Binding HasCurrentWorkspacePrimaryServer}">
                                                    <TextBlock Text="{Binding CurrentWorkspacePrimaryServerLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"/>
                                                </Border>
                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="999" Padding="10,5" IsVisible="{Binding HasCurrentWorkspaceRecommendedRam}">
                                                    <TextBlock Text="{Binding CurrentWorkspaceRecommendedRamLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"/>
                                                </Border>
                                            </StackPanel>

                                            <Button Command="{Binding OpenUrlCommand}" CommandParameter="{Binding CurrentModpack.WebLink}"
                                                    IsVisible="{Binding HasCurrentWorkspaceWebLink}"
                                                    Classes="secondary" FontSize="12" Padding="12,8" HorizontalAlignment="Stretch">
                                                <TextBlock Text="Navštívit web ↗"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: Obsah (Content / Mods) -->
            <TabItem Header="Obsah">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="0,16,0,60">
                        <StackPanel Spacing="14">
                            <!-- Search & Actions Bar -->
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}"
                                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Text="{StaticResource IconSearch}" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                                        <TextBox Grid.Column="1" Text="{Binding InstalledModsSearchQuery}" Watermark="Filtrovat nainstalované mody..."
                                                 BorderThickness="0" Background="Transparent" FontSize="12" Padding="4,8"/>
                                    </Grid>
                                </Border>
                                <Button Grid.Column="1" Content="+ Přidat obsah" Command="{Binding SearchModsForProfileCommand}"
                                        IsVisible="{Binding CurrentModpack.IsCustomProfile}"
                                        Classes="primary" FontSize="12" Padding="14,8"/>
                                <Button Grid.Column="2"
                                        Background="{DynamicResource BgInteractiveBrush}" Foreground="{DynamicResource TextSecondaryBrush}"
                                        CornerRadius="{DynamicResource RadiusSmall}" Padding="12,8" FontSize="12" Cursor="Hand"
                                        Command="{Binding RefreshInstalledModsCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{StaticResource IconRefresh}"/>
                                        <TextBlock Text="Obnovit"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Mod list header -->
                            <Grid ColumnDefinitions="36,*,Auto" Margin="0,4,0,0" ColumnSpacing="10">
                                <Border Width="32" Height="1" Background="Transparent"/>
                                <TextBlock Grid.Column="1" Text="Nainstalované mody" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Akce" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource StrokeSoftBrush}"/>

                            <controls:EmptyState IsVisible="{Binding !HasFilteredInstalledMods}"
                                                 Icon="{StaticResource IconSearch}"
                                                 Title="{Binding InstalledModsEmptyTitle}"
                                                 Subtitle="{Binding InstalledModsEmptySubtitle}"/>

                            <!-- Installed Mods List -->
                            <ItemsControl ItemsSource="{Binding FilteredInstalledMods}" IsVisible="{Binding HasFilteredInstalledMods}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Border Background="{DynamicResource BgShellBrush}" CornerRadius="{DynamicResource RadiusSmall}"
                                                Padding="10,8" Margin="0,0,0,4"
                                                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                                                </Style>
                                            </Border.Styles>
                                            <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="10">
                                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="{DynamicResource RadiusSmall}" ClipToBounds="True"
                                                        Background="{DynamicResource BgInteractiveBrush}" VerticalAlignment="Center">
                                                    <asyncImage:AdvancedImage Source="{Binding IconUrl}" Width="32" Height="32" Stretch="UniformToFill"
                                                                            IsVisible="{Binding IconUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                                                        <TextBlock Text="{Binding Source}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" MaxLines="2"
                                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                    <TextBlock Text="{Binding Author, StringFormat='Autor: {0}'}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}"
                                                               IsVisible="{Binding Author, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                    <TextBlock Text="{Binding InstalledFileName}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <Button Command="{Binding DataContext.RemoveModFromProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            IsVisible="{Binding DataContext.CurrentModpack.IsCustomProfile, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Background="Transparent" Foreground="{DynamicResource DangerBrush}" Padding="6" CornerRadius="6" Cursor="Hand"
                                                            ToolTip.Tip="Odebrat">
                                                        <TextBlock Text="{StaticResource IconTrash}" FontSize="13"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Search & Add Mods (Custom Profile) -->
                            <Border Classes="card" IsVisible="{Binding CurrentModpack.IsCustomProfile}" Margin="0,8,0,0">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Přidat mody" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15"/>
                                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="MC {0} | {1}">
                                                    <Binding Path="CurrentModpack.CustomMcVersion"/>
                                                    <Binding Path="CurrentModpack.CustomModLoader"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBox Text="{Binding ProfileModSearchQuery}" Watermark="Hledat mod..." FontSize="12">
                                            <TextBox.KeyBindings>
                                                <KeyBinding Gesture="Enter" Command="{Binding SearchModsForProfileCommand}"/>
                                            </TextBox.KeyBindings>
                                        </TextBox>
                                        <Button Grid.Column="1" Content="Vyhledat" Command="{Binding SearchModsForProfileCommand}"
                                                Classes="accent" FontSize="12" Padding="16,10"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding ProfileModSearchResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:CompileBindings="False">
                                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}"
                                                        Padding="10" Margin="0,0,0,6"
                                                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                    <Grid ColumnDefinitions="42,*,Auto" ColumnSpacing="12">
                                                        <Border Width="38" Height="38" CornerRadius="{DynamicResource RadiusSmall}" ClipToBounds="True"
                                                                Background="{DynamicResource BgInteractiveBrush}" VerticalAlignment="Center">
                                                            <asyncImage:AdvancedImage Source="{Binding IconUrl}" Width="38" Height="38" Stretch="UniformToFill"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding Source}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding DownloadCount, StringFormat='↓ {0}'}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="2" Content="+ Přidat"
                                                                Command="{Binding DataContext.AddModToProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Classes="primary" FontSize="11" Padding="12,6" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: Nastavení Instance -->
            <TabItem Header="Nastavení">
                <Grid RowDefinitions="*,Auto">
                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled">
                        <Border Padding="0,16,0,60">
                            <StackPanel Spacing="16" MaxWidth="900">
                                <!-- Enable Override -->
                                <Border Classes="card">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Specifické nastavení" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15"/>
                                            <TextBlock Text="Ignorovat globální nastavení pro tento modpack" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch IsChecked="{Binding CurrentModpackConfig.IsEnabled}" Grid.Column="1" OnContent="" OffContent=""/>
                                    </Grid>
                                </Border>

                                <Grid ColumnDefinitions="*,16,*" IsVisible="{Binding CurrentModpackConfig.IsEnabled}">
                                    <!-- RAM -->
                                    <Border Grid.Column="0" Classes="card">
                                        <StackPanel Spacing="18">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="RAM" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <Border Grid.Column="1" Background="{DynamicResource BgInteractiveBrush}" CornerRadius="6" Padding="8,4">
                                                    <TextBlock Text="{Binding CurrentModpackConfig.RamSliderValue, Converter={StaticResource RamValueConverter}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBBrush}" FontSize="13"/>
                                                </Border>
                                            </Grid>
                                            <Slider Minimum="0" Maximum="{Binding SystemRamMb}" Value="{Binding CurrentModpackConfig.RamSliderValue}" TickFrequency="512" IsSnapToTickEnabled="True"/>
                                            <TextBlock Text="0 = Globální limit" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Potato Mode + Flags -->
                                    <StackPanel Grid.Column="2" Spacing="16">
                                        <Border Classes="card" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{StaticResource IconWarning}" FontSize="14" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Bramborový režim" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" FontSize="14" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding CurrentModpackConfig.PotatoModeEnabled}" OnContent="" OffContent=""/>
                                                </Grid>
                                                <TextBlock Text="Vypne náročné mody pro slabší PC." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                <Button Content="Spravovat mody" Command="{Binding OpenPotatoConfigCommand}"
                                                        Classes="secondary" FontSize="11" Padding="12,6"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Classes="card">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="Optimalizace" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding CurrentModpackConfig.OptimizationFlagsHelper}" OnContent="" OffContent=""/>
                                                </Grid>
                                                <StackPanel IsVisible="{Binding CurrentModpackConfig.OptimizationFlagsHelper}" Spacing="6">
                                                    <TextBlock Text="GC typ" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <ComboBox ItemsSource="{Binding GcTypes}" SelectedItem="{Binding CurrentModpackConfig.OverrideGcType}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Options Presets -->
                                <Border Classes="card">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Options Presets" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15"/>
                                            <TextBlock Text="Přenášejte klávesové zkratky a nastavení mezi modpacky" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBox Text="{Binding NewOptionsPresetName}" Watermark="Název presetu" FontSize="12"/>
                                            <Button Grid.Column="1" Content="Uložit" Command="{Binding SaveOptionsPresetCommand}"
                                                    Classes="secondary" FontSize="12" Padding="14,8"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <ComboBox ItemsSource="{Binding OptionsPresetNames}" SelectedItem="{Binding SelectedOptionsPresetName}"
                                                      PlaceholderText="Vyber preset..." HorizontalAlignment="Stretch"/>
                                            <Button Grid.Column="1" Content="Načíst" Command="{Binding LoadOptionsPresetToCurrentModpackCommand}"
                                                    Classes="accent" FontSize="12" Padding="14,8"/>
                                            <Button Grid.Column="2" Content="Smazat" Command="{Binding DeleteOptionsPresetCommand}"
                                                    Classes="danger" FontSize="12" Padding="14,8"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- Bottom Bar -->
                    <Border Grid.Row="1" Background="{DynamicResource BgShellBrush}" Padding="24,14"
                            BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Command="{Binding SaveModpackSettingsCommand}"
                                    Classes="primary" FontSize="13" Padding="24,10">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{StaticResource IconSave}"/>
                                    <TextBlock Text="Uložit"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteModpackCommand}"
                                    IsVisible="{Binding CurrentModpack.IsDeletable}"
                                    Classes="danger" FontSize="13" Padding="18,10">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{StaticResource IconTrash}"/>
                                    <TextBlock Text="Odstranit"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB: Galerie -->
            <TabItem Header="Galerie">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="0,16,0,60">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Screenshoty" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                            <TextBlock Text="Žádné screenshoty zatím nebyly nalezeny." Foreground="{DynamicResource TextMutedBrush}" FontSize="12" IsVisible="{Binding !HasCurrentModpackScreenshots}"/>

                            <ItemsControl ItemsSource="{Binding CurrentModpackScreenshots}" IsVisible="{Binding HasCurrentModpackScreenshots}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Button Width="220" Height="124" Margin="0,0,10,10" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                Command="{Binding DataContext.OpenScreenshotCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding .}">
                                            <Border CornerRadius="{DynamicResource RadiusSmall}" ClipToBounds="True"
                                                    BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                <asyncImage:AdvancedImage Source="{Binding .}" Stretch="UniformToFill"/>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: Performance (NEW) -->
            <TabItem Header="Výkon">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="0,16,0,60">
                        <StackPanel Spacing="16" MaxWidth="900">
                            <!-- RAM Usage -->
                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Paměť" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Přidělená RAM" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="Hodnota se přebírá z nastavení instance nebo globálního nastavení." FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{DynamicResource BgInteractiveBrush}" CornerRadius="6" Padding="12,6">
                                            <TextBlock Text="{Binding Config.MaxRamMb, Converter={StaticResource RamValueConverter}}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBBrush}" FontSize="14"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- JVM Info -->
                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Java Runtime" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                    <TextBlock Text="Launcher automaticky spravuje Java instalaci pro každý modpack." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    <Border Height="1" Background="{DynamicResource StrokeSoftBrush}"/>
                                    <TextBlock Text="Pokročilé JVM flagy a GC nastavení naleznete v záložce Nastavení." FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Historie pádů" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                            <TextBlock Text="Launcher si ukládá poslední pády této instance včetně exit code, délky běhu a výpisu logu." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Obnovit" Command="{Binding RefreshCrashHistoryCommand}" Classes="secondary" FontSize="12" Padding="12,8"/>
                                    </Grid>

                                    <controls:EmptyState IsVisible="{Binding !HasCurrentModpackCrashHistory}"
                                                         Icon="{StaticResource IconCrash}"
                                                         Title="{Binding CurrentModpackCrashHistoryEmptyTitle}"
                                                         Subtitle="{Binding CurrentModpackCrashHistoryEmptySubtitle}"/>

                                    <ItemsControl ItemsSource="{Binding CurrentModpackCrashHistory}" IsVisible="{Binding HasCurrentModpackCrashHistory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:CrashHistoryEntry">
                                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="16"
                                                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <StackPanel Spacing="6">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding Summary}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" MaxWidth="520"/>
                                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="999" Padding="8,3">
                                                                    <TextBlock Text="{Binding ExitCodeLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding OccurredAtLabel, StringFormat='{}Zaznamenáno {0}'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="{Binding RuntimeLabel, StringFormat='{}Běh hry: {0}'}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <Border Background="{DynamicResource BgShellBrush}" CornerRadius="12" Padding="10" IsVisible="{Binding HasLogTail}">
                                                                <TextBlock Text="{Binding LogTail}" FontSize="10" LineHeight="16" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas,monospace" TextWrapping="Wrap" MaxLines="6"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                            <Button Classes="secondary" FontSize="11" Padding="12,6"
                                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).OpenCrashHistoryArtifactCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    IsVisible="{Binding HasOpenableArtifact}">
                                                                <TextBlock Text="Otevřít log"/>
                                                            </Button>
                                                            <Button Classes="ghost" FontSize="11" Padding="12,6"
                                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CopyCrashHistoryLogCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    IsVisible="{Binding HasLogTail}">
                                                                <TextBlock Text="Kopírovat výpis"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: Saves & Backups (NEW) -->
            <TabItem Header="Zálohy">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="0,16,0,60">
                        <StackPanel Spacing="16" MaxWidth="900">
                            <!-- Saves -->
                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Uložené světy" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                            <TextBlock Text="Přímý přístup ke světům této instance a možnost vytvořit ruční zálohu pro každý svět." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding OpenSavesFolderCommand}"
                                                Classes="secondary" FontSize="12" Padding="14,8">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{StaticResource IconFolder}"/>
                                                <TextBlock Text="Otevřít saves"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <controls:EmptyState IsVisible="{Binding !HasCurrentModpackSaveWorlds}"
                                                         Icon="{StaticResource IconFolder}"
                                                         Title="Zatím žádné světy"
                                                         Subtitle="Jakmile v instanci vznikne první svět, objeví se tady."/>

                                    <ItemsControl ItemsSource="{Binding CurrentModpackSaveWorlds}" IsVisible="{Binding HasCurrentModpackSaveWorlds}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:InstanceSaveWorldEntry">
                                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusControl}"
                                                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                                                    <StackPanel Spacing="12">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                <TextBlock Text="{Binding LastModifiedAt, StringFormat='{}Naposledy změněno {0:dd.MM.yyyy HH:mm}'}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                <TextBlock Text="{Binding BackupStatusLabel}" FontSize="11" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="{DynamicResource RadiusPill}" Padding="10,4" HorizontalAlignment="Right">
                                                                    <TextBlock Text="{Binding FileCount, StringFormat='{}{0} souborů'}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                </Border>
                                                                <Button Classes="secondary" FontSize="11" Padding="12,6"
                                                                        Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).BackupSaveWorldCommand}"
                                                                        CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                                        <TextBlock Text="{StaticResource IconBackup}"/>
                                                                        <TextBlock Text="Zálohovat svět"/>
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button Classes="ghost" FontSize="11" Padding="12,6"
                                                                        Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).OpenSaveWorldFolderCommand}"
                                                                        CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                                        <TextBlock Text="{StaticResource IconFolder}"/>
                                                                        <TextBlock Text="Otevřít svět"/>
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button Classes="ghost" FontSize="11" Padding="12,6"
                                                                        Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).OpenSaveWorldBackupFolderCommand}"
                                                                        CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                                        <TextBlock Text="{StaticResource IconFolder}"/>
                                                                        <TextBlock Text="Otevřít backupy"/>
                                                                    </StackPanel>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Border Height="1" Background="{DynamicResource StrokeSoftBrush}" IsVisible="{Binding HasBackups}"/>

                                                        <StackPanel Spacing="8" IsVisible="{Binding HasBackups}">
                                                            <TextBlock Text="Zálohy tohoto světa" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <ItemsControl ItemsSource="{Binding Backups}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="models:InstanceWorldBackupSnapshot">
                                                                        <Border Background="{DynamicResource BgShellBrush}" CornerRadius="14"
                                                                                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,6">
                                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                                                <StackPanel Spacing="3">
                                                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}Vytvořeno {0:dd.MM.yyyy HH:mm}'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                                    <TextBlock Text="{Binding FileCount, StringFormat='{}{0} souborů'}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                                </StackPanel>
                                                                                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                                                    <Button Classes="secondary" FontSize="11" Padding="12,6"
                                                                                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).RestoreWorldBackupSnapshotCommand}"
                                                                                            CommandParameter="{Binding}">
                                                                                        <TextBlock Text="Obnovit svět"/>
                                                                                    </Button>
                                                                                    <Button Classes="ghost" FontSize="11" Padding="12,6"
                                                                                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).OpenWorldBackupSnapshotCommand}"
                                                                                            CommandParameter="{Binding}">
                                                                                        <TextBlock Text="Otevřít zálohu"/>
                                                                                    </Button>
                                                                                    <Button Classes="danger" FontSize="11" Padding="12,6"
                                                                                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).DeleteWorldBackupSnapshotCommand}"
                                                                                            CommandParameter="{Binding}">
                                                                                        <TextBlock Text="Smazat zálohu"/>
                                                                                    </Button>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Zálohy instance" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                            <TextBlock Text="Rychlé zálohy configů, shaderů, nastavení a dalších dat této instance." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="↻ Obnovit" Command="{Binding RefreshInstanceWorkspaceDataCommand}"
                                                Classes="secondary" FontSize="12" Padding="12,8"/>
                                        <Button Grid.Column="2" Command="{Binding CreateInstanceBackupCommand}"
                                                Classes="accent" FontSize="12" Padding="14,8">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{StaticResource IconBackup}"/>
                                                <TextBlock Text="Vytvořit zálohu"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <controls:EmptyState IsVisible="{Binding !HasCurrentModpackBackups}"
                                                         Icon="{StaticResource IconBackup}"
                                                         Title="Zatím žádné zálohy"
                                                         Subtitle="Po vytvoření první zálohy se tu zobrazí přehled."/>

                                    <ItemsControl ItemsSource="{Binding CurrentModpackBackupSnapshots}" IsVisible="{Binding HasCurrentModpackBackups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:InstanceBackupSnapshot">
                                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusControl}"
                                                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                            <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="{DynamicResource RadiusPill}" Padding="10,4">
                                                                <TextBlock Text="{Binding FileCount, StringFormat='{}{0} souborů'}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            </Border>
                                                                <Button Content="Otevřít zálohu ↗" Classes="secondary" FontSize="11" Padding="12,6"
                                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).OpenBackupSnapshotCommand}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Export / Import" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                        <TextBlock Text="Export vytvoří .voidpack archiv. Import načte archiv zpět jako lokální instanci." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                        <Button Command="{Binding ExportInstanceCommand}" Classes="secondary" FontSize="12" Padding="14,8">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{StaticResource IconExport}"/>
                                                <TextBlock Text="Exportovat instanci"/>
                                            </StackPanel>
                                        </Button>
                                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ExportProgress}" Height="10"
                                                     IsVisible="{Binding IsExporting}" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <TextBox Text="{Binding ImportArchivePath}" Watermark="Cesta k .voidpack archivu"/>
                                        <Button Grid.Column="1" Content="Vybrat" Command="{Binding BrowseImportArchiveCommand}" Classes="secondary" FontSize="12" Padding="12,8"/>
                                        <Button Grid.Column="2" Content="Vyčistit" Command="{Binding ClearImportArchiveCommand}" Classes="ghost" FontSize="12" Padding="12,8" IsVisible="{Binding HasImportArchivePath}"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                        <Button Command="{Binding ImportInstanceCommand}" CommandParameter="{Binding ImportArchivePath}"
                                                Classes="accent" FontSize="12" Padding="14,8" IsEnabled="{Binding HasImportArchivePath}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{StaticResource IconImport}"/>
                                                <TextBlock Text="Importovat archiv"/>
                                            </StackPanel>
                                        </Button>
                                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ImportProgress}" Height="10"
                                                     IsVisible="{Binding IsImporting}" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: Advanced (NEW) -->
            <TabItem Header="Pokročilé">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="0,16,0,60">
                        <StackPanel Spacing="16" MaxWidth="900">
                            <!-- Instance Info -->
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Informace o instanci" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0">
                                        <TextBlock Text="Název:" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,12,6"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentWorkspaceDisplayName}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Row="1" Text="Verze:" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,12,6"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentModpack.VersionTransitionText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Row="2" Text="Autor:" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentWorkspaceAuthorLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Servery navázané na modpack" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16"/>
                                            <TextBlock Text="Spusť správnou instanci a připoj se na vybraný server jedním kliknutím." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Servery" Command="{Binding GoToServerHubCommand}" Classes="secondary" FontSize="12" Padding="12,8"/>
                                    </Grid>

                                    <controls:EmptyState IsVisible="{Binding !HasCurrentModpackLinkedServers}"
                                                         Icon="{StaticResource IconServerHub}"
                                                         Title="K tomuto modpacku zatím není navázaný server"
                                                         Subtitle="V přehledu serverů můžeš přidat vlastní server nebo upravit existující vazby, aby rychlé připojení spouštělo správnou instanci."/>

                                    <ItemsControl ItemsSource="{Binding CurrentModpackLinkedServers}" IsVisible="{Binding HasCurrentModpackLinkedServers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:ServerInfo">
                                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusControl}"
                                                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <StackPanel Spacing="4">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="{DynamicResource RadiusPill}" Padding="8,3">
                                                                    <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Address}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas,monospace"/>
                                                            <TextBlock Text="{Binding LinkedModpackName, StringFormat='{}Navázáno na: {0}'}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                            <Button Content="▶ Připojit" Classes="primary" FontSize="11" Padding="12,6"
                                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).QuickConnectCommand}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Button Classes="secondary" FontSize="11" Padding="12,6"
                                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CopyServerIpCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <TextBlock Text="{StaticResource IconCopy}"/>
                                                                    <TextBlock Text="Kopírovat IP"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Danger Zone -->
                            <Border Classes="card" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Nebezpečná zóna" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" FontSize="16"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Command="{Binding ReinstallModpackContextCommand}" CommandParameter="{Binding CurrentModpack}"
                                                Classes="secondary" FontSize="12" Padding="14,8">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{StaticResource IconRefresh}"/>
                                                <TextBlock Text="Přeinstalovat"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding DeleteModpackContextCommand}" CommandParameter="{Binding CurrentModpack}"
                                                IsVisible="{Binding CurrentModpack.IsDeletable}"
                                                Classes="danger" FontSize="12" Padding="14,8">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{StaticResource IconTrash}"/>
                                                <TextBlock Text="Smazat instanci"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
