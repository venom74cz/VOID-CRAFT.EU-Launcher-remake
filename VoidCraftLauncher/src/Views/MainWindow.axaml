<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VoidCraftLauncher.ViewModels"
        xmlns:converters="using:VoidCraftLauncher.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="VoidCraftLauncher.Views.MainWindow"
        Icon="avares://VoidCraftLauncher/src/Assets/icon.png"
        x:DataType="vm:MainViewModel"
        x:Name="RootWindow"
        Title="VOID-CRAFT Launcher"
        Width="1350" Height="850"
        MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#111218"
        TransparencyLevelHint="None">

    <Window.Resources>
        <converters:ObjectEqualityConverter x:Key="ObjectEqualityConverter"/>
        <converters:ObjectInequalityConverter x:Key="ObjectInequalityConverter"/>
        <converters:RamValueConverter x:Key="RamValueConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="240,*">

        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║                   SIDEBAR                        ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <Border Grid.Column="0" Background="#1A1B26" BorderBrush="#24273A" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- ══ LOGO ══ -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="20,22,20,16" VerticalAlignment="Center">
                        <Image Source="avares://VoidCraftLauncher/src/Assets/icon.png" Width="32" Height="32" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center" Spacing="0">
                            <TextBlock Text="VOID-CRAFT" FontSize="15" FontWeight="ExtraBold" Foreground="#E2E8F0" LetterSpacing="0.5"/>
                            <TextBlock Text="LAUNCHER" FontSize="9" FontWeight="Bold" Foreground="#1BD96A" LetterSpacing="3" Margin="1,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── User Profile Card ── -->
                    <Border Background="#1E2030" CornerRadius="10" Padding="12" Margin="12,0,12,0" BorderBrush="#24273A" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Width="36" Height="36" CornerRadius="18" ClipToBounds="True" Background="#24273A">
                                    <asyncImage:AdvancedImage Width="36" Height="36" CornerRadius="18"
                                        Source="{Binding PlayerSkinUrl, FallbackValue='https://crafatar.com/avatars/MHF_Steve?size=36&amp;overlay'}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding UserSession.Username, FallbackValue='Guest'}" FontWeight="Bold" FontSize="13" Foreground="#E2E8F0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Accounts.Count, StringFormat='{}{0} účtů'}" FontSize="10" Foreground="#5B6078" IsVisible="{Binding IsLoggedIn}"/>
                                    <TextBlock Text="Nepřihlášen" FontSize="10" Foreground="#ED4245" IsVisible="{Binding !IsLoggedIn}"/>
                                </StackPanel>
                                <Button Grid.Column="2" Command="{Binding ToggleAccountPickerCommand}"
                                        Background="Transparent" Padding="6" VerticalAlignment="Center" Cursor="Hand" CornerRadius="4">
                                    <TextBlock Text="▼" FontSize="9" Foreground="#5B6078"/>
                                </Button>
                            </Grid>

                            <!-- Account Picker Dropdown -->
                            <StackPanel IsVisible="{Binding IsAccountPickerOpen}" Spacing="4">
                                <Border Height="1" Background="#24273A" Margin="0,2,0,4"/>
                                <ItemsControl ItemsSource="{Binding Accounts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:CompileBindings="False">
                                            <Border Background="#24273A" CornerRadius="6" Padding="8,6" Margin="0,1"
                                                    Cursor="Hand">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="#E2E8F0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <Button Grid.Column="1" Content="✓"
                                                            Command="{Binding DataContext.SwitchAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" Foreground="#1BD96A" FontSize="11" Padding="6,2" CornerRadius="4" Cursor="Hand"/>
                                                    <Button Grid.Column="2" Content="✕"
                                                            Command="{Binding DataContext.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" Foreground="#ED4245" FontSize="11" Padding="4,2" CornerRadius="4" Cursor="Hand"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Command="{Binding OpenLoginModalCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Background="#24273A" Foreground="#8892B0" FontSize="11" Padding="8,6" CornerRadius="6" Cursor="Hand">
                                    <TextBlock Text="+ Přidat účet"/>
                                </Button>
                            </StackPanel>

                            <!-- Quick Login/Logout (when picker closed) -->
                            <StackPanel IsVisible="{Binding !IsAccountPickerOpen}">
                                <Button Content="PŘIHLÁSIT SE" Command="{Binding OpenLoginModalCommand}" IsVisible="{Binding !IsLoggedIn}"
                                        Classes="primary" FontSize="11" Padding="0,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Content="Odhlásit" Command="{Binding LogoutCommand}" IsVisible="{Binding IsLoggedIn}"
                                        Classes="ghost" FontSize="11" Padding="0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Foreground="#ED4245"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ══ NAVIGATION ══ -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="2" Margin="12,12,12,0">
                        <TextBlock Text="NAVIGACE" FontSize="10" FontWeight="Bold" Foreground="#5B6078" Margin="14,4,0,8" LetterSpacing="1.5"/>

                        <Button Command="{Binding GoToHomeCommand}" Classes="nav"
                                Classes.active="{Binding IsLibraryView}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="📚" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Knihovna" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding GoToBrowserCommand}" Classes="nav"
                                Classes.active="{Binding IsDiscoverView}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Procházet" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding GoToSettingsCommand}" Classes="nav"
                                Classes.active="{Binding IsSettingsView}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Nastavení" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="#24273A" Margin="0,14"/>

                        <TextBlock Text="KOMUNITA" FontSize="10" FontWeight="Bold" Foreground="#5B6078" Margin="14,0,0,8" LetterSpacing="1.5"/>

                        <Button Content="🌐  Void-Craft Web" Command="{Binding OpenUrlCommand}" CommandParameter="https://void-craft.eu/"
                                Classes="nav" FontSize="12"/>
                        <Button Content="💬  Discord" Command="{Binding OpenUrlCommand}" CommandParameter="https://discord.com/invite/8rjhkck9w4"
                                Classes="nav" FontSize="12"/>
                        <Button Content="🎬  YouTube" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.youtube.com/@void-craft-eu"
                                Classes="nav" FontSize="12"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- ══ SERVER STATUS + FOOTER ══ -->
                <StackPanel Grid.Row="2" Spacing="10" Margin="12,12">
                    <!-- Server Status -->
                    <Border Background="#1E2030" CornerRadius="10" Padding="14" BorderBrush="#24273A" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Panel VerticalAlignment="Center">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#1BD96A" IsVisible="{Binding IsServerOnline}">
                                            <Border.Effect><DropShadowEffect BlurRadius="6" Color="#1BD96A" Opacity="0.6"/></Border.Effect>
                                        </Border>
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#ED4245" IsVisible="{Binding !IsServerOnline}"/>
                                    </Panel>
                                    <TextBlock Text="VOID-CRAFT.EU" FontWeight="Bold" Foreground="#1BD96A" FontSize="11" IsVisible="{Binding IsServerOnline}" VerticalAlignment="Center"/>
                                    <TextBlock Text="OFFLINE" FontWeight="Bold" Foreground="#ED4245" FontSize="11" IsVisible="{Binding !IsServerOnline}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="2" Command="{Binding CopyIpCommand}" Background="Transparent" Foreground="#5B6078" FontSize="10" Padding="4,2" CornerRadius="4" Cursor="Hand" ToolTip.Tip="Zkopírovat IP">
                                    <TextBlock Text="📋" FontSize="11"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding ServerMotd}" Foreground="#8892B0" FontSize="11" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <ProgressBar Value="{Binding ServerPlayerCount}" Maximum="{Binding ServerMaxPlayers}" Height="4" CornerRadius="2"/>
                                <TextBlock Grid.Column="1" Foreground="#5B6078" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}/{1}">
                                            <Binding Path="ServerPlayerCount"/>
                                            <Binding Path="ServerMaxPlayers"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Version / Footer -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{Binding AppVersion}" Foreground="#5B6078" FontSize="10"/>
                            <TextBlock Text="VOIDIVIDE" Foreground="#363A4F" FontSize="9" LetterSpacing="1"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CheckForUpdatesCommand}"
                                Background="#1E2030" CornerRadius="6" Padding="6" Cursor="Hand" ToolTip.Tip="Hledat aktualizace">
                            <TextBlock Text="🔄" Foreground="#5B6078" FontSize="11"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║                  MAIN CONTENT                    ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <Border Grid.Column="1" Background="#111218">
            <Grid>

                <!-- ══════════ VIEW 1: LIBRARY ══════════ -->
                <ScrollViewer IsVisible="{Binding IsLibraryView}" HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="32,28,32,80">
                        <StackPanel Spacing="24">
                            <!-- Header Toolbar -->
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="Knihovna" FontSize="28" FontWeight="ExtraBold" Foreground="#E2E8F0"/>
                                    <TextBlock Text="{Binding Greeting}" FontSize="13" Foreground="#5B6078"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Width="220" Watermark="Hledat modpack..." Margin="0,0,12,0" VerticalAlignment="Center" FontSize="12"/>
                                <Button Grid.Column="2" Content="+ Nový profil" Command="{Binding OpenCreateProfileModalCommand}"
                                        Classes="primary" FontSize="12" Padding="16,10" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Modpack Grid -->
                            <ItemsControl ItemsSource="{Binding InstalledModpacks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Grid Margin="0,0,16,16" ClipToBounds="False">
                                            <!-- Hover/Press animations -->
                                            <Grid.Styles>
                                                <Style Selector="Grid.InstanceCard:pointerover">
                                                    <Setter Property="RenderTransform" Value="scale(1.02)"/>
                                                </Style>
                                                <Style Selector="Grid.InstanceCard:pointerover Border.InstanceBorder">
                                                    <Setter Property="BorderBrush" Value="#1BD96A"/>
                                                    <Setter Property="BoxShadow" Value="0 8 24 0 #44000000, 0 0 0 1 #661BD96A"/>
                                                </Style>
                                                <Style Selector="Grid.InstanceCard:pressed">
                                                    <Setter Property="RenderTransform" Value="scale(0.98)"/>
                                                </Style>
                                            </Grid.Styles>

                                            <Grid Classes="InstanceCard">
                                                <Grid.Transitions>
                                                    <Transitions>
                                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                    </Transitions>
                                                </Grid.Transitions>

                                                <Border Classes="InstanceBorder" Width="200" Height="270" Background="#1A1B26" CornerRadius="12"
                                                        BorderBrush="#24273A" BorderThickness="1" ClipToBounds="True"
                                                        Cursor="Hand" PointerPressed="PointerPressedHandler"
                                                        BoxShadow="0 2 8 0 #33000000">
                                                    <Border.Transitions>
                                                        <Transitions>
                                                            <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                                                            <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                                                        </Transitions>
                                                    </Border.Transitions>

                                                    <!-- Context Menu -->
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="▶ Spustit" Command="{Binding #RootWindow.DataContext.SelectAndPlayCommand}" CommandParameter="{Binding}"/>
                                                            <Separator/>
                                                            <MenuItem Header="🔄 Přeinstalovat" Command="{Binding #RootWindow.DataContext.ReinstallModpackContextCommand}" CommandParameter="{Binding}"/>
                                                            <MenuItem Header="📂 Otevřít složku" Command="{Binding #RootWindow.DataContext.OpenModpackFolderContextCommand}" CommandParameter="{Binding}"/>
                                                            <Separator/>
                                                            <MenuItem Header="🗑 Smazat" Command="{Binding #RootWindow.DataContext.DeleteModpackContextCommand}" CommandParameter="{Binding}"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>

                                                    <Grid RowDefinitions="140,*">
                                                        <!-- Image Area -->
                                                        <Border Grid.Row="0" CornerRadius="12,12,0,0" ClipToBounds="True" Background="#24273A">
                                                            <asyncImage:AdvancedImage Source="{Binding LogoUrl}" Stretch="UniformToFill"/>
                                                        </Border>

                                                        <!-- Info Area -->
                                                        <StackPanel Grid.Row="1" Margin="14,12,14,14" Spacing="6" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#E2E8F0" FontSize="14"
                                                                       TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" LineHeight="18"/>

                                                            <TextBlock Text="{Binding VersionTransitionText}" Foreground="#5B6078" FontSize="11"
                                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                                            <!-- Status Badge -->
                                                            <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Left" Margin="0,2,0,0">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="#1BD96A" Opacity="0.12"/>
                                                                </Border.Background>
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <Border Width="5" Height="5" CornerRadius="2.5" Background="#1BD96A" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="Připraveno" FontSize="10" Foreground="#1BD96A" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>

                                                        <!-- ── Stop button overlay (when game running) ── -->
                                                        <Border Grid.RowSpan="2" Background="#CC111218" CornerRadius="12">
                                                            <Border.IsVisible>
                                                                <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                                    <Binding Path="#RootWindow.DataContext.RunningModpack"/>
                                                                    <Binding Path="."/>
                                                                </MultiBinding>
                                                            </Border.IsVisible>
                                                            <Button Command="{Binding #RootWindow.DataContext.StopGameCommand}"
                                                                    Classes="danger" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                    Padding="20,12" CornerRadius="8">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="⏹" FontSize="14"/>
                                                                    <TextBlock Text="UKONČIT" FontSize="13" FontWeight="Bold"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </Border>

                                                        <!-- ── Progress overlay (when installing) ── -->
                                                        <Border Grid.RowSpan="2" VerticalAlignment="Bottom" CornerRadius="0,0,12,12"
                                                                Padding="12,8" Background="#EE111218">
                                                            <Border.IsVisible>
                                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                                    <Binding Path="#RootWindow.DataContext.IsLaunching"/>
                                                                    <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                                        <Binding Path="."/>
                                                                        <Binding Path="#RootWindow.DataContext.TargetModpack"/>
                                                                    </MultiBinding>
                                                                </MultiBinding>
                                                            </Border.IsVisible>
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Text="{Binding #RootWindow.DataContext.LaunchStatus}" FontSize="10" Foreground="#8892B0" TextTrimming="CharacterEllipsis"/>
                                                                <ProgressBar Value="{Binding #RootWindow.DataContext.LaunchProgress}" Maximum="100"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <!-- ── Play Button (floating) ── -->
                                                <Grid VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,48">
                                                    <Grid.IsVisible>
                                                        <MultiBinding Converter="{StaticResource ObjectInequalityConverter}">
                                                            <Binding Path="#RootWindow.DataContext.RunningModpack"/>
                                                            <Binding Path="."/>
                                                        </MultiBinding>
                                                    </Grid.IsVisible>
                                                    <StackPanel x:Name="PlayButtonContainer">
                                                        <Border Background="#1BD96A" Width="44" Height="44" CornerRadius="22"
                                                                BoxShadow="0 4 12 0 #661BD96A">
                                                            <Button Classes="PlayButton"
                                                                    Command="{Binding #RootWindow.DataContext.SelectAndPlayCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                                    CornerRadius="22" Padding="0" Cursor="Hand">
                                                                <TextBlock Text="▶" Foreground="#111218" FontSize="18" FontWeight="Bold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Margin="2,0,0,0" IsHitTestVisible="False"/>
                                                            </Button>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Context menu for empty area -->
                            <Border Background="Transparent" MinHeight="50">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="➕ Vytvořit vlastní profil" Command="{Binding OpenCreateProfileModalCommand}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>


                <!-- ══════════ VIEW 2: SETTINGS ══════════ -->
                <ScrollViewer IsVisible="{Binding IsSettingsView}" HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="32,28,32,80">
                        <StackPanel Spacing="28" MaxWidth="900" HorizontalAlignment="Left">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Nastavení" FontSize="28" FontWeight="ExtraBold" Foreground="#E2E8F0"/>
                                <TextBlock Text="Globální konfigurace launcheru a herního běhu" Foreground="#5B6078" FontSize="13"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,24,*">
                                <!-- Column 1: System -->
                                <StackPanel Grid.Column="0" Spacing="16">
                                    <TextBlock Text="Systém" FontWeight="Bold" Foreground="#8892B0" FontSize="12" LetterSpacing="1" Margin="0,0,0,4"/>

                                    <!-- RAM Card -->
                                    <Border Classes="card">
                                        <StackPanel Spacing="20">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="Maximální RAM" FontWeight="Bold" Foreground="#E2E8F0" FontSize="15"/>
                                                    <TextBlock Text="Kolik paměti může hra využít" Foreground="#5B6078" FontSize="11"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#24273A" CornerRadius="6" Padding="10,6">
                                                    <TextBlock Text="{Binding Config.MaxRamMb, Converter={StaticResource RamValueConverter}}" FontWeight="ExtraBold" Foreground="#1BD96A" FontSize="15"/>
                                                </Border>
                                            </Grid>
                                            <Slider Minimum="2048" Maximum="{Binding SystemRamMb}" Value="{Binding Config.MaxRamMb}" TickFrequency="512" IsSnapToTickEnabled="True"/>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="Min: 2 GB" FontSize="10" Foreground="#5B6078"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SystemRamMb, Converter={StaticResource RamValueConverter}, StringFormat='Systém: {0}'}" FontSize="10" Foreground="#5B6078"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Column 2: Optimization -->
                                <StackPanel Grid.Column="2" Spacing="16">
                                    <TextBlock Text="Optimalizace" FontWeight="Bold" Foreground="#8892B0" FontSize="12" LetterSpacing="1" Margin="0,0,0,4"/>

                                    <Border Classes="card">
                                        <StackPanel Spacing="16">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="Optimalizační flagy" FontWeight="Bold" Foreground="#E2E8F0" FontSize="15"/>
                                                    <TextBlock Text="JVM argumenty pro lepší výkon" FontSize="11" Foreground="#5B6078"/>
                                                </StackPanel>
                                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding Config.EnableOptimizationFlags}" OnContent="" OffContent=""/>
                                            </Grid>

                                            <StackPanel IsVisible="{Binding Config.EnableOptimizationFlags}" Spacing="10">
                                                <Border Height="1" Background="#24273A"/>
                                                <TextBlock Text="Garbage Collector" FontSize="12" Foreground="#8892B0" FontWeight="SemiBold"/>
                                                <ComboBox ItemsSource="{Binding GcTypes}" SelectedItem="{Binding Config.SelectedGc}" HorizontalAlignment="Stretch"/>
                                                <TextBlock Text="Doporučujeme ponechat výchozí nastavení." FontSize="10" Foreground="#5B6078"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Save Button -->
                            <Button Content="Uložit změny" Command="{Binding SaveSettingsCommand}"
                                    Classes="primary" FontSize="14" Padding="0,14" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>


                <!-- ══════════ VIEW 3: INSTANCE DETAIL ══════════ -->
                <Grid IsVisible="{Binding IsInstanceDetailView}" RowDefinitions="220,*">

                    <!-- Hero Banner -->
                    <Grid Grid.Row="0" ClipToBounds="True">
                        <asyncImage:AdvancedImage Source="{Binding CurrentModpack.LogoUrl}" Stretch="UniformToFill" Opacity="0.3">
                            <asyncImage:AdvancedImage.Effect>
                                <BlurEffect Radius="50"/>
                            </asyncImage:AdvancedImage.Effect>
                        </asyncImage:AdvancedImage>
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#77111218" Offset="0"/>
                                    <GradientStop Color="#FF111218" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Back Button -->
                        <Button Command="{Binding GoToHomeCommand}" Classes="ghost" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20,16">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="←" FontSize="16" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                <TextBlock Text="Knihovna" FontSize="13" Foreground="#E2E8F0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Content -->
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Bottom" Margin="32,0,32,24">
                            <Border Width="80" Height="80" CornerRadius="14" ClipToBounds="True" Background="#24273A" BorderBrush="#363A4F" BorderThickness="1">
                                <asyncImage:AdvancedImage Source="{Binding CurrentModpack.LogoUrl}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0" Spacing="4">
                                <TextBlock Text="{Binding CurrentModpack.Name}" FontSize="26" FontWeight="ExtraBold" Foreground="#E2E8F0">
                                    <TextBlock.Effect><DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.6"/></TextBlock.Effect>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding CurrentModpack.VersionTransitionText}" FontSize="12" Foreground="#8892B0" FontWeight="SemiBold"/>
                                    <Border CornerRadius="4" Padding="6,2" IsVisible="{Binding CurrentModpack.IsUpdateAvailable}">
                                        <Border.Background><SolidColorBrush Color="#FFAA00" Opacity="0.15"/></Border.Background>
                                        <TextBlock Text="Aktualizace" FontSize="10" Foreground="#FFAA00" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action Buttons -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Command="{Binding SelectAndPlayCommand}" CommandParameter="{Binding CurrentModpack}"
                                        Classes="primary" Padding="28,14" IsEnabled="{Binding !IsLaunching}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="▶" FontSize="14"/>
                                        <TextBlock Text="HRÁT" FontWeight="ExtraBold" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenModpackFolderCommand}" Classes="secondary" Padding="14" ToolTip.Tip="Otevřít složku">
                                    <TextBlock Text="📂" FontSize="15"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Tabs -->
                    <TabControl Grid.Row="1" Margin="24,8,24,0">

                        <!-- TAB: Přehled -->
                        <TabItem Header="Přehled">
                            <ScrollViewer Padding="8,16" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="16" MaxWidth="900">
                                    <Border Classes="card">
                                        <StackPanel Spacing="14">
                                            <TextBlock Text="Popis" FontWeight="Bold" Foreground="#E2E8F0" FontSize="16"/>
                                            <TextBlock Text="{Binding CurrentModpack.Description}" FontSize="13" Foreground="#8892B0" TextWrapping="Wrap" LineHeight="20"/>
                                            <StackPanel IsVisible="{Binding !CurrentModpack.Description.Length}">
                                                <TextBlock Text="Popis není k dispozici." Foreground="#5B6078" FontStyle="Italic" FontSize="13"/>
                                            </StackPanel>

                                            <Border Height="1" Background="#24273A" Margin="0,8"/>

                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="Autor:" Foreground="#5B6078" FontSize="13"/>
                                                    <TextBlock Text="{Binding CurrentModpack.Author, TargetNullValue='Neznámý'}" Foreground="#1BD96A" FontWeight="Bold" FontSize="13"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Command="{Binding OpenUrlCommand}" CommandParameter="{Binding CurrentModpack.WebLink}"
                                                        IsVisible="{Binding !!CurrentModpack.WebLink.Length}"
                                                        Classes="secondary" FontSize="12" Padding="12,8">
                                                    <TextBlock Text="Navštívit web ↗"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB: Nastavení Instance -->
                        <TabItem Header="Nastavení">
                            <Grid RowDefinitions="*,Auto">
                                <ScrollViewer Grid.Row="0" Padding="8,16" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Spacing="16" MaxWidth="900">

                                        <!-- Enable Override -->
                                        <Border Classes="card">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="Specifické nastavení" FontWeight="Bold" Foreground="#E2E8F0" FontSize="15"/>
                                                    <TextBlock Text="Ignorovat globální nastavení pro tento modpack" FontSize="11" Foreground="#5B6078"/>
                                                </StackPanel>
                                                <ToggleSwitch IsChecked="{Binding CurrentModpackConfig.IsEnabled}" Grid.Column="1" OnContent="" OffContent=""/>
                                            </Grid>
                                        </Border>

                                        <Grid ColumnDefinitions="*,16,*" IsVisible="{Binding CurrentModpackConfig.IsEnabled}">
                                            <!-- RAM -->
                                            <Border Grid.Column="0" Classes="card">
                                                <StackPanel Spacing="18">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="RAM" FontWeight="Bold" Foreground="#E2E8F0"/>
                                                        <Border Grid.Column="1" Background="#24273A" CornerRadius="6" Padding="8,4">
                                                            <TextBlock Text="{Binding CurrentModpackConfig.RamSliderValue, Converter={StaticResource RamValueConverter}}" FontWeight="Bold" Foreground="#1BD96A" FontSize="13"/>
                                                        </Border>
                                                    </Grid>
                                                    <Slider Minimum="0" Maximum="{Binding SystemRamMb}" Value="{Binding CurrentModpackConfig.RamSliderValue}" TickFrequency="512" IsSnapToTickEnabled="True"/>
                                                    <TextBlock Text="0 = Globální limit" FontSize="10" Foreground="#5B6078"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Potato Mode + Flags -->
                                            <StackPanel Grid.Column="2" Spacing="16">
                                                <Border Classes="card" BorderBrush="#FFAA00" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="🥔" FontSize="14" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Bramborový režim" FontWeight="Bold" Foreground="#FFAA00" FontSize="14" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding CurrentModpackConfig.PotatoModeEnabled}" OnContent="" OffContent=""/>
                                                        </Grid>
                                                        <TextBlock Text="Vypne náročné mody pro slabší PC." FontSize="11" Foreground="#5B6078" TextWrapping="Wrap"/>
                                                        <Button Content="Spravovat mody" Command="{Binding OpenPotatoConfigCommand}"
                                                                Classes="secondary" FontSize="11" Padding="12,6"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Classes="card">
                                                    <StackPanel Spacing="10">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Text="Optimalizace" FontWeight="Bold" Foreground="#E2E8F0" FontSize="14"/>
                                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding CurrentModpackConfig.OptimizationFlagsHelper}" OnContent="" OffContent=""/>
                                                        </Grid>
                                                        <StackPanel IsVisible="{Binding CurrentModpackConfig.OptimizationFlagsHelper}" Spacing="6">
                                                            <TextBlock Text="GC typ" FontSize="11" Foreground="#8892B0"/>
                                                            <ComboBox ItemsSource="{Binding GcTypes}" SelectedItem="{Binding CurrentModpackConfig.OverrideGcType}" HorizontalAlignment="Stretch"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Options Presets -->
                                        <Border Classes="card">
                                            <StackPanel Spacing="14">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="Options Presets" FontWeight="Bold" Foreground="#E2E8F0" FontSize="15"/>
                                                    <TextBlock Text="Přenášejte klávesové zkratky a nastavení mezi modpacky" Foreground="#5B6078" FontSize="11"/>
                                                </StackPanel>
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBox Text="{Binding NewOptionsPresetName}" Watermark="Název presetu" FontSize="12"/>
                                                    <Button Grid.Column="1" Content="Uložit" Command="{Binding SaveOptionsPresetCommand}"
                                                            Classes="secondary" FontSize="12" Padding="14,8"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                    <ComboBox ItemsSource="{Binding OptionsPresetNames}" SelectedItem="{Binding SelectedOptionsPresetName}"
                                                              PlaceholderText="Vyber preset..." HorizontalAlignment="Stretch"/>
                                                    <Button Grid.Column="1" Content="Načíst" Command="{Binding LoadOptionsPresetToCurrentModpackCommand}"
                                                            Classes="accent" FontSize="12" Padding="14,8"/>
                                                    <Button Grid.Column="2" Content="Smazat" Command="{Binding DeleteOptionsPresetCommand}"
                                                            Classes="danger" FontSize="12" Padding="14,8"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Bottom Bar -->
                                <Border Grid.Row="1" Background="#1A1B26" Padding="24,14" BorderBrush="#24273A" BorderThickness="0,1,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Content="💾 Uložit" Command="{Binding SaveModpackSettingsCommand}"
                                                Classes="primary" FontSize="13" Padding="24,10"/>
                                        <Button Content="🗑 Odstranit" Command="{Binding DeleteModpackCommand}"
                                                IsVisible="{Binding CurrentModpack.IsDeletable}"
                                                Classes="danger" FontSize="13" Padding="18,10"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- TAB: Mody -->
                        <TabItem Header="Mody">
                            <ScrollViewer Padding="8,16" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="16" MaxWidth="900">

                                    <!-- Installed Mods -->
                                    <Border Classes="card">
                                        <StackPanel Spacing="14">
                                            <TextBlock Text="Nainstalované mody" FontWeight="Bold" Foreground="#E2E8F0" FontSize="16"/>
                                            <TextBlock Text="Zatím žádné mody." Foreground="#5B6078" FontSize="12" IsVisible="{Binding !InstalledMods.Count}"/>

                                            <ItemsControl ItemsSource="{Binding InstalledMods}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:CompileBindings="False">
                                                        <Border Background="#1E2030" CornerRadius="8" Padding="10" Margin="0,0,0,8" BorderBrush="#24273A" BorderThickness="1">
                                                            <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="12">
                                                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" ClipToBounds="True" Background="#24273A" VerticalAlignment="Center">
                                                                    <asyncImage:AdvancedImage Source="{Binding IconUrl}" Width="32" Height="32" Stretch="UniformToFill"
                                                                                            IsVisible="{Binding IconUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#E2E8F0" FontSize="13"/>
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#5B6078"/>
                                                                        <Button Command="{Binding #RootWindow.DataContext.OpenUrlCommand}" CommandParameter="{Binding WebLink}"
                                                                                Background="Transparent" BorderThickness="0" Foreground="#1BD96A" FontSize="10" Padding="0"
                                                                                IsVisible="{Binding WebLink, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Cursor="Hand">
                                                                            <TextBlock Text="Web ↗"/>
                                                                        </Button>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <Button Grid.Column="2" Content="Odebrat"
                                                                        Command="{Binding DataContext.RemoveModFromProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Classes="danger" FontSize="11" Padding="10,6" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Search & Add Mods (Custom Profile) -->
                                    <Border Classes="card" IsVisible="{Binding CurrentModpack.IsCustomProfile}">
                                        <StackPanel Spacing="14">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Přidat mody" FontWeight="Bold" Foreground="#E2E8F0" FontSize="16"/>
                                                <TextBlock Foreground="#5B6078" FontSize="11">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="MC {0} | {1}">
                                                            <Binding Path="CurrentModpack.CustomMcVersion"/>
                                                            <Binding Path="CurrentModpack.CustomModLoader"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>

                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBox Text="{Binding ProfileModSearchQuery}" Watermark="Hledat mod..." FontSize="12">
                                                    <TextBox.KeyBindings>
                                                        <KeyBinding Gesture="Enter" Command="{Binding SearchModsForProfileCommand}"/>
                                                    </TextBox.KeyBindings>
                                                </TextBox>
                                                <Button Grid.Column="1" Content="Vyhledat" Command="{Binding SearchModsForProfileCommand}"
                                                        Classes="accent" FontSize="12" Padding="16,10"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding ProfileModSearchResults}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:CompileBindings="False">
                                                        <Border Background="#1E2030" CornerRadius="8" Padding="10" Margin="0,0,0,8" BorderBrush="#24273A" BorderThickness="1">
                                                            <Grid ColumnDefinitions="42,*,Auto" ColumnSpacing="12">
                                                                <Border Width="38" Height="38" CornerRadius="8" ClipToBounds="True" Background="#24273A" VerticalAlignment="Center">
                                                                    <asyncImage:AdvancedImage Source="{Binding IconUrl}" Width="38" Height="38" Stretch="UniformToFill"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#E2E8F0" FontSize="13"/>
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#1BD96A" FontWeight="SemiBold"/>
                                                                        <TextBlock Text="{Binding DownloadCount, StringFormat='⬇ {0}'}" FontSize="10" Foreground="#5B6078"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <Button Grid.Column="2" Content="+ Přidat"
                                                                        Command="{Binding DataContext.AddModToProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Classes="primary" FontSize="11" Padding="12,6" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB: Screenshoty -->
                        <TabItem Header="Galerie">
                            <ScrollViewer Padding="8,16" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Screenshoty" FontWeight="Bold" Foreground="#E2E8F0" FontSize="16"/>
                                    <TextBlock Text="Žádné screenshoty zatím nebyly nalezeny." Foreground="#5B6078" FontSize="12" IsVisible="{Binding !HasCurrentModpackScreenshots}"/>

                                    <ItemsControl ItemsSource="{Binding CurrentModpackScreenshots}" IsVisible="{Binding HasCurrentModpackScreenshots}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:CompileBindings="False">
                                                <Button Width="240" Height="135" Margin="0,0,12,12" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                        Command="{Binding DataContext.OpenScreenshotCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding .}">
                                                    <Border CornerRadius="10" ClipToBounds="True" BorderBrush="#24273A" BorderThickness="1">
                                                        <asyncImage:AdvancedImage Source="{Binding .}" Stretch="UniformToFill">
                                                            <asyncImage:AdvancedImage.Transitions>
                                                                <Transitions>
                                                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                                                                </Transitions>
                                                            </asyncImage:AdvancedImage.Transitions>
                                                        </asyncImage:AdvancedImage>
                                                    </Border>
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover asyncImage|AdvancedImage">
                                                            <Setter Property="RenderTransform" Value="scale(1.04)"/>
                                                        </Style>
                                                    </Button.Styles>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>


                <!-- ══════════ VIEW 4: DISCOVER ══════════ -->
                <Grid IsVisible="{Binding IsDiscoverView}" RowDefinitions="Auto,*">
                    <!-- Search Header -->
                    <Border Grid.Row="0" Background="#1A1B26" BorderBrush="#24273A" BorderThickness="0,0,0,1" Padding="32,24">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Procházet" FontSize="28" FontWeight="ExtraBold" Foreground="#E2E8F0"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Border Background="#1E2030" CornerRadius="8" BorderBrush="#363A4F" BorderThickness="1">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="14,0,6,0" Foreground="#5B6078" FontSize="15"/>
                                        <TextBox Grid.Column="1" Text="{Binding BrowserSearchQuery}" Watermark="Hledat modpacky..."
                                                 BorderThickness="0" Background="Transparent" FontSize="13" Padding="4,10">
                                            <TextBox.KeyBindings>
                                                <KeyBinding Gesture="Enter" Command="{Binding SearchModpacksCommand}"/>
                                            </TextBox.KeyBindings>
                                        </TextBox>
                                        <Button Grid.Column="2" Command="{Binding SearchModpacksCommand}" Content="↵" IsEnabled="{Binding !IsSearching}"
                                                Background="Transparent" Foreground="#5B6078" FontSize="16" Padding="12,0" Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <!-- Source Toggle -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Button Command="{Binding SetBrowserSourceCommand}" CommandParameter="CurseForge" CornerRadius="8" Padding="14,10" Cursor="Hand" FontWeight="Bold" FontSize="12">
                                        <Classes.active>
                                            <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                <Binding Path="BrowserSource"/>
                                                <Binding><Binding.Source>CurseForge</Binding.Source></Binding>
                                            </MultiBinding>
                                        </Classes.active>
                                        <Button.Styles>
                                            <Style Selector="Button"><Setter Property="Background" Value="#24273A"/><Setter Property="Foreground" Value="#8892B0"/></Style>
                                            <Style Selector="Button.active"><Setter Property="Background" Value="#F16436"/><Setter Property="Foreground" Value="White"/></Style>
                                        </Button.Styles>
                                        <TextBlock Text="CurseForge" FontWeight="Bold" FontSize="12"/>
                                    </Button>
                                    <Button Command="{Binding SetBrowserSourceCommand}" CommandParameter="Modrinth" CornerRadius="8" Padding="14,10" Cursor="Hand" FontWeight="Bold" FontSize="12">
                                        <Classes.active>
                                            <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                <Binding Path="BrowserSource"/>
                                                <Binding><Binding.Source>Modrinth</Binding.Source></Binding>
                                            </MultiBinding>
                                        </Classes.active>
                                        <Button.Styles>
                                            <Style Selector="Button"><Setter Property="Background" Value="#24273A"/><Setter Property="Foreground" Value="#8892B0"/></Style>
                                            <Style Selector="Button.active"><Setter Property="Background" Value="#1BD96A"/><Setter Property="Foreground" Value="#111218"/></Style>
                                        </Button.Styles>
                                        <TextBlock Text="Modrinth" FontWeight="Bold" FontSize="12"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Results -->
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                        <Border Padding="32,24,32,80">
                            <StackPanel MaxWidth="1000">
                                <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsSearching}" Margin="0,0,0,16"/>

                                <!-- Empty State -->
                                <StackPanel IsVisible="{Binding !BrowserResults.Count}" HorizontalAlignment="Center" Margin="0,60,0,0" Spacing="10">
                                    <TextBlock Text="🔍" FontSize="40" HorizontalAlignment="Center" Opacity="0.4"/>
                                    <TextBlock Text="Žádné výsledky" FontSize="16" FontWeight="SemiBold" Foreground="#5B6078" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Zkuste jiný hledaný výraz" FontSize="13" Foreground="#363A4F" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding BrowserResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1A1B26" BorderBrush="#24273A" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,10">
                                                <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="16">
                                                    <Border Width="72" Height="72" CornerRadius="10" ClipToBounds="True" Background="#24273A" VerticalAlignment="Top">
                                                        <asyncImage:AdvancedImage Source="{Binding IconUrl}" Stretch="UniformToFill"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Spacing="6">
                                                        <TextBlock Text="{Binding Name}" FontWeight="ExtraBold" FontSize="17" Foreground="#E2E8F0"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <TextBlock Text="{Binding Author, StringFormat='Od {0}'}" FontSize="12" Foreground="#5B6078"/>
                                                            <Border CornerRadius="4" Padding="6,2">
                                                                <Border.Background><SolidColorBrush Color="#1BD96A" Opacity="0.15"/></Border.Background>
                                                                <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#1BD96A" FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding DownloadCount, StringFormat='⬇ {0}'}" FontSize="11" Foreground="#5B6078" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#8892B0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" LineHeight="17"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center" MinWidth="130">
                                                        <Button Content="Přidat do knihovny"
                                                                Command="{Binding $parent[Window].DataContext.InstallModpackFromBrowserCommand}"
                                                                CommandParameter="{Binding}"
                                                                IsVisible="{Binding !IsInstalled}"
                                                                Classes="primary" FontSize="12" Padding="0,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                        <Button Content="✅ Přidáno"
                                                                IsVisible="{Binding IsInstalled}"
                                                                IsEnabled="False"
                                                                Background="#24273A" Foreground="#1BD96A" FontWeight="Bold" FontSize="12"
                                                                Padding="0,10" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                        <Button Content="Web ↗" Command="{Binding $parent[Window].DataContext.OpenUrlCommand}" CommandParameter="{Binding WebLink}"
                                                                Classes="ghost" FontSize="11" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Load More -->
                                <Button Command="{Binding LoadMoreModpacksCommand}" IsVisible="{Binding HasMoreResults}"
                                        Content="Načíst další" Classes="secondary" FontSize="13" Padding="20,12"
                                        HorizontalAlignment="Center" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>


        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║               LOGIN MODAL                        ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <Grid Grid.ColumnSpan="2" IsVisible="{Binding IsLoginModalVisible}" Background="#CC111218">
            <Border Background="#1A1B26" CornerRadius="16" BorderBrush="#24273A" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Width="420" Padding="0">
                <Border.Effect><DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.8"/></Border.Effect>

                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Border Background="#1E2030" CornerRadius="16,16,0,0" Padding="24,18" BorderBrush="#24273A" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Přihlášení" FontSize="20" FontWeight="Bold" Foreground="#E2E8F0"/>
                            <Button Grid.Column="1" Content="✕" Command="{Binding CloseLoginModalCommand}"
                                    Background="Transparent" Foreground="#5B6078" FontSize="16" Padding="6" Cursor="Hand" CornerRadius="4"/>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <Border Grid.Row="1" Padding="24,20">
                        <TabControl>
                            <TabItem Header="Microsoft">
                                <StackPanel Spacing="14" Margin="0,14,0,0">
                                    <TextBlock Text="Bezpečné přihlášení přes Microsoft účet." TextWrapping="Wrap" Foreground="#5B6078" FontSize="12" TextAlignment="Center"/>
                                    <Button Content="Přihlásit přes Microsoft" Command="{Binding LoginMicrosoftCommand}"
                                            IsEnabled="{Binding !IsLoginInProgress}"
                                            Classes="accent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,14" FontSize="14"/>

                                    <Border Background="#1E2030" CornerRadius="8" Padding="14" BorderBrush="#363A4F" BorderThickness="1" IsVisible="{Binding IsLoginInProgress}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding LoginStatus}" Foreground="#FFAA00" TextWrapping="Wrap" FontSize="11"/>
                                            <TextBlock Text="{Binding ManualLoginCode, StringFormat='Kód: {0}'}" Foreground="#E2E8F0" FontWeight="Bold" FontSize="13" IsVisible="{Binding IsLoginInProgress}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Zkopírovat kód" Command="{Binding CopyLoginCodeCommand}" Classes="secondary" FontSize="11" Padding="10,6"/>
                                                <Button Content="Otevřít web" Command="{Binding OpenUrlCommand}" CommandParameter="{Binding AuthUrl}" Classes="secondary" FontSize="11" Padding="10,6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Offline">
                                <StackPanel Spacing="14" Margin="0,14,0,0">
                                    <TextBlock Text="Hra bez originálu. Skiny nebudou fungovat mimo servery s pluginem." TextWrapping="Wrap" Foreground="#5B6078" FontSize="11" TextAlignment="Center"/>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Herní jméno" FontWeight="SemiBold" Foreground="#E2E8F0" FontSize="13"/>
                                        <TextBox Text="{Binding OfflineUsername}" Watermark="Player123"/>
                                    </StackPanel>
                                    <Button Content="Přihlásit offline" Command="{Binding LoginOfflineCommand}"
                                            Classes="secondary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,14" FontSize="14"/>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Border>
        </Grid>


        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║          CREATE PROFILE MODAL                    ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <Grid Grid.ColumnSpan="2" IsVisible="{Binding IsCreateProfileModalVisible}" Background="#CC111218">
            <Border Background="#1A1B26" CornerRadius="16" BorderBrush="#24273A" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Width="520" Padding="0">
                <Border.Effect><DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.8"/></Border.Effect>

                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header -->
                    <Border Grid.Row="0" Background="#1E2030" CornerRadius="16,16,0,0" Padding="24,18" BorderBrush="#24273A" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Nový profil" FontSize="22" FontWeight="Bold" Foreground="#E2E8F0"/>
                                <TextBlock Text="Vlastní modpack s mody z CurseForge a Modrinth" Foreground="#5B6078" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✕" Command="{Binding CloseCreateProfileModalCommand}"
                                    Background="Transparent" Foreground="#5B6078" FontSize="16" Padding="6" Cursor="Hand" CornerRadius="4" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <StackPanel Grid.Row="1" Spacing="20" Margin="24,20">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Název" FontWeight="SemiBold" FontSize="13" Foreground="#8892B0"/>
                            <TextBox Text="{Binding NewProfileName}" Watermark="Např. My Epic Survival"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="MC verze" FontWeight="SemiBold" FontSize="13" Foreground="#8892B0"/>
                                <ComboBox SelectedItem="{Binding NewProfileMcVersion}" ItemsSource="{Binding AvailableMcVersions}"
                                          PlaceholderText="1.21.1" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Loader" FontWeight="SemiBold" FontSize="13" Foreground="#8892B0"/>
                                <ComboBox SelectedItem="{Binding NewProfileModLoader}" HorizontalAlignment="Stretch">
                                    <x:String>fabric</x:String>
                                    <x:String>forge</x:String>
                                    <x:String>neoforge</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding NewProfileModLoader, StringFormat='Verze {0}'}" FontWeight="SemiBold" FontSize="13" Foreground="#8892B0"/>
                            <ComboBox SelectedItem="{Binding NewProfileModLoaderVersion}" ItemsSource="{Binding AvailableModLoaderVersions}"
                                      PlaceholderText="Výchozí" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer -->
                    <Border Grid.Row="2" Background="#1E2030" CornerRadius="0,0,16,16" Padding="24,16" BorderBrush="#24273A" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="Auto,*">
                            <Button Content="Zrušit" Command="{Binding CloseCreateProfileModalCommand}"
                                    Classes="ghost" FontSize="13" Padding="16,10"/>
                            <Button Grid.Column="1" Content="Vytvořit" Command="{Binding CreateCustomProfileCommand}"
                                    Classes="primary" FontSize="14" Padding="28,10" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
