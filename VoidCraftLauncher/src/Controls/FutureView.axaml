<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             xmlns:models="using:VoidCraftLauncher.Models"
             xmlns:controls="using:VoidCraftLauncher.Controls"
             x:Class="VoidCraftLauncher.Controls.FutureView"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="{DynamicResource BgShellBrush}" Padding="24,16"
                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{StaticResource IconFuture}" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="FUTURE" FontSize="18" FontWeight="ExtraBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding OpenFutureRoadmapSourceCommand}"
                        Classes="secondary" Padding="14,8" Content="Otevřít GitHub"/>

                <Button Grid.Column="2" Command="{Binding RefreshFutureRoadmapCommand}"
                        Classes="secondary" Padding="14,8" Content="Obnovit"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="28" Margin="32,28,32,60" MaxWidth="1220">
                <Border CornerRadius="20" Padding="32"
                        BorderBrush="{DynamicResource PrimaryGlowBrush}" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#121320" Offset="0"/>
                            <GradientStop Color="#1B1734" Offset="0.55"/>
                            <GradientStop Color="#112431" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,28,300" RowSpacing="24">
                        <StackPanel Spacing="14">
                            <Border Background="{DynamicResource BgInteractiveBrush}"
                                    CornerRadius="{DynamicResource RadiusPill}" Padding="12,6"
                                    HorizontalAlignment="Left" BorderBrush="{DynamicResource StrokeSoftBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="GitHub-backed product compass" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryGlowBrush}"/>
                            </Border>

                            <TextBlock Text="{Binding FutureRoadmapHeadline}" FontSize="34" FontWeight="ExtraBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"
                                       MaxWidth="760"/>

                            <TextBlock Text="{Binding FutureRoadmapIntro}" FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                       LineHeight="24" MaxWidth="760"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="12">
                            <Border Background="#140F24" CornerRadius="14" Padding="18,16"
                                    BorderBrush="#4A4183" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Roadmap scale" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding FutureRoadmapStatsLabel}" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="Od guide sekcí po konkrétní feature s nejvyšším dopadem." FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#0F1D27" CornerRadius="14" Padding="18,16"
                                    BorderBrush="#315D74" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Source state" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding FutureRoadmapSourceStatus}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding FutureRoadmapLastUpdated}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <ItemsControl Grid.Row="1" Grid.ColumnSpan="3" ItemsSource="{Binding FutureRoadmapSignals}"
                                      IsVisible="{Binding HasFutureRoadmapSignals}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:FutureRoadmapSignal">
                                    <Border Width="368" Margin="0,0,18,18" Padding="18"
                                            Background="{Binding SurfaceBrush}" BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="1" CornerRadius="16">
                                        <StackPanel Spacing="10">
                                            <Border Background="{Binding SurfaceBrush}" BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="{DynamicResource RadiusPill}"
                                                    Padding="10,5" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding AccentBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                       LineHeight="20"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <controls:LoadingSkeleton IsVisible="{Binding IsFutureRoadmapLoading}"/>

                <controls:EmptyState Icon="{StaticResource IconFuture}"
                                     Title="{Binding FutureRoadmapEmptyTitle}"
                                     Subtitle="{Binding FutureRoadmapEmptySubtitle}"
                                     IsVisible="{Binding ShouldShowFutureRoadmapEmptyState}"/>

                <ItemsControl ItemsSource="{Binding FutureRoadmapSections}" IsVisible="{Binding HasFutureRoadmapSections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:FutureRoadmapSection">
                            <Border Background="{Binding SurfaceBrush}" BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="1" CornerRadius="20"
                                    Padding="26" Margin="0,0,0,4">
                                <StackPanel Spacing="20">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                        <StackPanel Spacing="10">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border Background="{Binding SurfaceBrush}" BorderBrush="{Binding BorderBrush}"
                                                        BorderThickness="1" CornerRadius="{DynamicResource RadiusPill}"
                                                        Padding="10,5" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding BadgeLabel}" FontSize="10" FontWeight="Bold"
                                                               Foreground="{Binding AccentBrush}"/>
                                                </Border>

                                                <Border Background="{DynamicResource BgCanvasBrush}" BorderBrush="{Binding BorderBrush}"
                                                        BorderThickness="1" CornerRadius="{DynamicResource RadiusPill}"
                                                        Padding="10,5" HorizontalAlignment="Left"
                                                        IsVisible="{Binding HasEntryCount}">
                                                    <TextBlock Text="{Binding EntryCountLabel}" FontSize="10" FontWeight="Bold"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="ExtraBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" Width="64" Height="64"
                                                CornerRadius="18" Background="{DynamicResource BgCanvasBrush}"
                                                BorderBrush="{Binding BorderBrush}" BorderThickness="1">
                                            <TextBlock Text="{Binding BadgeLabel}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{Binding AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <Border Background="{DynamicResource BgCanvasBrush}" CornerRadius="14"
                                            Padding="18" BorderBrush="{Binding BorderBrush}" BorderThickness="1"
                                            IsVisible="{Binding HasBody}">
                                        <Grid ColumnDefinitions="4,*" ColumnSpacing="14">
                                            <Border Background="{Binding AccentBrush}" CornerRadius="999"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Body}" TextWrapping="Wrap"
                                                       LineHeight="23" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="13"/>
                                        </Grid>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Entries}" IsVisible="{Binding HasEntries}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:FutureRoadmapEntry">
                                                <Border Width="556" Margin="0,0,18,18"
                                                        Background="{DynamicResource BgCanvasBrush}"
                                                        BorderBrush="{Binding BorderBrush}"
                                                        BorderThickness="1" CornerRadius="18">
                                                    <StackPanel Spacing="0">
                                                        <Border Padding="18,16" BorderBrush="{Binding BorderBrush}"
                                                                BorderThickness="0,0,0,1">
                                                            <StackPanel Spacing="10">
                                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                                    <Border Background="{Binding SurfaceBrush}" BorderBrush="{Binding BorderBrush}"
                                                                            BorderThickness="1" CornerRadius="{DynamicResource RadiusPill}"
                                                                            Padding="10,5" IsVisible="{Binding HasIndexLabel}">
                                                                        <TextBlock Text="{Binding IndexLabel}" FontSize="10" FontWeight="Bold"
                                                                                   Foreground="{Binding AccentBrush}"/>
                                                                    </Border>

                                                                    <Border Background="{DynamicResource BgInteractiveBrush}" BorderBrush="{Binding BorderBrush}"
                                                                            BorderThickness="1" CornerRadius="{DynamicResource RadiusPill}"
                                                                            Padding="10,5">
                                                                        <TextBlock Text="Future card" FontSize="10" FontWeight="Bold"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                    </Border>
                                                                </StackPanel>

                                                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <StackPanel Spacing="12" Margin="18,16,18,18">
                                                            <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="12"
                                                                    Padding="14" BorderBrush="{Binding BorderBrush}" BorderThickness="1"
                                                                    IsVisible="{Binding HasDescription}">
                                                                <StackPanel Spacing="5">
                                                                    <TextBlock Text="Popis" FontSize="10" FontWeight="Bold"
                                                                               Foreground="{Binding AccentBrush}"/>
                                                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               TextWrapping="Wrap" LineHeight="20"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <Border Background="{Binding SurfaceBrush}" CornerRadius="12"
                                                                    Padding="14" BorderBrush="{Binding BorderBrush}" BorderThickness="1"
                                                                    IsVisible="{Binding HasImplementation}">
                                                                <StackPanel Spacing="5">
                                                                    <TextBlock Text="Možná implementace" FontSize="10" FontWeight="Bold"
                                                                               Foreground="{Binding AccentBrush}"/>
                                                                    <TextBlock Text="{Binding Implementation}" FontSize="11"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               TextWrapping="Wrap" LineHeight="18"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12"
                                                                    Padding="14" BorderBrush="{Binding BorderBrush}" BorderThickness="1"
                                                                    IsVisible="{Binding HasWhyItMatters}">
                                                                <StackPanel Spacing="5">
                                                                    <TextBlock Text="Proč to dává smysl" FontSize="10" FontWeight="Bold"
                                                                               Foreground="{Binding AccentBrush}"/>
                                                                    <TextBlock Text="{Binding WhyItMatters}" FontSize="11"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               TextWrapping="Wrap" LineHeight="18"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>