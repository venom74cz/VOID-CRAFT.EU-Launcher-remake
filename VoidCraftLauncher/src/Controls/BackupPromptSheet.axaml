<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             x:Class="VoidCraftLauncher.Controls.BackupPromptSheet"
             x:DataType="vm:MainViewModel">

    <!-- Backup Prompt Sheet — shown before destructive operations (reinstall, delete, update) -->
    <Grid IsVisible="{Binding IsBackupPromptVisible}">
        <!-- Scrim -->
        <Border Background="{DynamicResource BgCanvasBrush}" Opacity="0.82"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <!-- Sheet -->
        <Border Background="{DynamicResource BgShellBrush}" CornerRadius="{DynamicResource RadiusCard}"
                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="480" Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.85"/>
            </Border.Effect>

            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <Border Grid.Row="0" Background="{DynamicResource BgElevatedBrush}"
                        CornerRadius="16,16,0,0" Padding="28,20"
                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="{DynamicResource WarningBrush}" Opacity="0.15">
                            <TextBlock Text="{StaticResource IconBackup}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Vytvořit zálohu?" FontSize="20" FontWeight="ExtraBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Tato akce může změnit nebo smazat data instance"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Command="{Binding DismissBackupPromptCommand}"
                                Background="Transparent" Foreground="{DynamicResource TextMutedBrush}"
                                FontSize="16" Padding="6" Cursor="Hand"
                                CornerRadius="{DynamicResource RadiusSmall}" VerticalAlignment="Top">
                            <TextBlock Text="{StaticResource IconClose}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Body -->
                <Border Grid.Row="1" Padding="28,20">
                    <StackPanel Spacing="16">
                        <!-- Instance info -->
                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{DynamicResource RadiusSmall}"
                                Padding="14" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <TextBlock Text="{StaticResource IconLibrary}" FontSize="24" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding BackupTargetName}" FontWeight="Bold" FontSize="14"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Saves, konfigurace a nastavení budou zálohovány"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding BackupTargetPath}" FontSize="11" FontFamily="Consolas, monospace"
                                               Foreground="{DynamicResource AccentTealBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- What gets backed up -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Co bude zálohováno:" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <StackPanel Spacing="4" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{StaticResource IconSuccess}" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="Světy a saves" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{StaticResource IconSuccess}" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="Konfigurace modů" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{StaticResource IconSuccess}" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="Nastavení hry (options.txt, keybinds)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <Border Grid.Row="2" Background="{DynamicResource BgElevatedBrush}"
                        CornerRadius="0,0,16,16" Padding="28,16"
                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                    <Button Content="Zrušit" Command="{Binding DismissBackupPromptCommand}"
                        Classes="ghost" FontSize="13" Padding="16,10"/>
                        <Button Content="Přeskočit" Command="{Binding SkipBackupCommand}"
                        Classes="secondary" FontSize="13" Padding="16,10" Grid.Column="1"/>
                    <Button Grid.Column="3" Content="Zálohovat a pokračovat" Command="{Binding ConfirmBackupCommand}"
                                Classes="primary" FontSize="13" Padding="20,10"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
