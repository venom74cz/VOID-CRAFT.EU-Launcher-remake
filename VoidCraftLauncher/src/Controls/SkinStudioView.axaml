<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             xmlns:models="using:VoidCraftLauncher.Models"
             xmlns:controls="using:VoidCraftLauncher.Controls"
             xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="VoidCraftLauncher.Controls.SkinStudioView"
             x:DataType="vm:MainViewModel"
             x:Name="SkinStudioRoot">

    <Grid RowDefinitions="Auto,*">

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BgShellBrush}" Padding="24,16"
                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{StaticResource IconSkinStudio}" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="Skin Studio" FontSize="18" FontWeight="ExtraBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource PrimaryBBrush}" Opacity="0.12"
                        CornerRadius="{DynamicResource RadiusPill}" Padding="12,6">
                    <TextBlock Text="Profil účtu" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBBrush}"/>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="24" Margin="32,28,32,60" MaxWidth="980">
                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{DynamicResource RadiusCard}"
                        Padding="30" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                    <Grid ColumnDefinitions="*,300" ColumnSpacing="24">
                        <StackPanel Spacing="14" VerticalAlignment="Center">
                            <TextBlock Text="Tvůj Minecraft profil" FontSize="24" FontWeight="ExtraBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SkinStudioHeroDescription}" 
                                       FontSize="14" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="22"/>
                            <WrapPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusPill}" Padding="12,6" Margin="0,0,8,8">
                                    <TextBlock Text="{Binding SkinStudioIdentitySummary}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                                <Button Content="Otevřít NameMC profil" Classes="primary" Padding="18,10"
                                    Command="{Binding OpenSkinProfilePageCommand}"
                                    IsVisible="{Binding HasPublicSkinProfile}"/>
                                <Button Content="Přihlásit Microsoft účet" Classes="primary" Padding="18,10"
                                    Command="{Binding OpenLoginModalCommand}"
                                    IsVisible="{Binding !HasPublicSkinProfile}"/>
                                <Button Content="Kopírovat identitu" Classes="secondary" Padding="18,10"
                                        Command="{Binding CopySkinIdentityCommand}"/>
                                <Button Content="NameMC nástroje" Classes="secondary" Padding="18,10"
                                    Command="{Binding OpenSkinAccountToolsCommand}"
                                    IsVisible="{Binding IsMicrosoftSkinAccount}"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Classes="glow-pulse" Background="{DynamicResource BgShellBrush}" CornerRadius="22"
                                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" Padding="22">
                            <StackPanel Spacing="14" HorizontalAlignment="Center">
                                <Border Width="210" Height="260" CornerRadius="20" Background="{DynamicResource BgInteractiveBrush}"
                                        BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" ClipToBounds="True">
                                    <asyncImage:AdvancedImage Source="{Binding SkinStudioLargeRenderUrl}" Stretch="Uniform" Margin="0,12,0,0"/>
                                </Border>
                                <TextBlock Text="{Binding SkinStudioDisplayName}" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SkinStudioSelectedSkinTitle}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SkinStudioSelectedSkinSubtitle}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,16,*">
                    <Border Grid.Column="0" Background="{DynamicResource BgPanelBrush}"
                            CornerRadius="{DynamicResource RadiusControl}" Padding="22"
                            BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                        <StackPanel Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{StaticResource IconInfo}" FontSize="16"/>
                                <TextBlock Text="Identita účtu" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding SkinStudioIdentityDescription}" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="18"/>

                            <Border Background="{DynamicResource BgShellBrush}" CornerRadius="12" Padding="14"
                                    BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Typ účtu" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding SkinStudioAccountTypeLabel}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="UUID" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding SkinStudioUuid}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Avatar 256px" Classes="secondary" Padding="16,10"
                                    Command="{Binding OpenSkinAvatarPreviewCommand}"/>
                                <Button Content="Otevřít detail skinu" Classes="secondary" Padding="16,10"
                                        Command="{Binding OpenSelectedSkinPageCommand}" IsEnabled="{Binding HasSkinHistory}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{DynamicResource BgPanelBrush}"
                            CornerRadius="{DynamicResource RadiusControl}" Padding="22"
                            BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Historie skinů účtu" FontWeight="Bold" FontSize="14"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Veřejná historie skinů z NameMC profilu. První karta je aktuálně nošený skin." FontSize="12"
                                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Obnovit" Classes="secondary" Padding="14,8"
                                    Command="{Binding RefreshSkinHistoryCommand}"
                                    IsEnabled="{Binding IsMicrosoftSkinAccount}"/>
                            </Grid>

                            <controls:LoadingSkeleton IsVisible="{Binding IsSkinHistoryLoading}"/>

                            <controls:EmptyState Icon="{StaticResource IconSkinStudio}"
                                                 Title="{Binding SkinHistoryEmptyTitle}"
                                                 Subtitle="{Binding SkinHistoryEmptySubtitle}">
                                <controls:EmptyState.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="!HasSkinHistory"/>
                                        <Binding Path="!IsSkinHistoryLoading"/>
                                    </MultiBinding>
                                </controls:EmptyState.IsVisible>
                            </controls:EmptyState>

                            <ItemsControl ItemsSource="{Binding SkinHistoryItems}" IsVisible="{Binding HasSkinHistory}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:SkinHistoryItem">
                                        <Border Background="{DynamicResource BgShellBrush}" CornerRadius="14" Padding="12" Margin="0,0,12,12"
                                                Width="138" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <Border Background="{DynamicResource PrimaryBBrush}" Opacity="0.14" CornerRadius="999" Padding="8,3"
                                                            IsVisible="{Binding IsCurrent}">
                                                        <TextBlock Text="Aktivní" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                    </Border>
                                                    <Button Grid.Column="1" Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).OpenUrlCommand}"
                                                            CommandParameter="{Binding PageUrl}" Background="Transparent" Padding="4" CornerRadius="6">
                                                        <TextBlock Text="{StaticResource IconOpen}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </Button>
                                                </Grid>
                                                <Border Width="88" Height="88" CornerRadius="44" ClipToBounds="True"
                                                        Background="{DynamicResource BgInteractiveBrush}" HorizontalAlignment="Center">
                                                    <asyncImage:AdvancedImage Source="{Binding PreviewUrl}" Stretch="UniformToFill"/>
                                                </Border>
                                                <TextBlock Text="{Binding SeenAtLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" TextAlignment="Center" LineHeight="15"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
