<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             xmlns:models="using:VoidCraftLauncher.Models"
             xmlns:creatorModels="using:VoidCraftLauncher.Models.CreatorStudio"
             xmlns:controls="using:VoidCraftLauncher.Controls"
             xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="VoidCraftLauncher.Controls.StreamingToolsView"
             x:DataType="vm:MainViewModel"
             x:Name="StreamingToolsRoot">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+1" Command="{Binding SwitchCreatorTabCommand}" CommandParameter="Overview"/>
        <KeyBinding Gesture="Ctrl+2" Command="{Binding SwitchCreatorTabCommand}" CommandParameter="Identity"/>
        <KeyBinding Gesture="Ctrl+3" Command="{Binding SwitchCreatorTabCommand}" CommandParameter="Mods"/>
        <KeyBinding Gesture="Ctrl+4" Command="{Binding SwitchCreatorTabCommand}" CommandParameter="Files"/>
        <KeyBinding Gesture="Ctrl+5" Command="{Binding SwitchCreatorTabCommand}" CommandParameter="Notes"/>
        <KeyBinding Gesture="Ctrl+6" Command="{Binding SwitchCreatorTabCommand}" CommandParameter="Git"/>
        <KeyBinding Gesture="Ctrl+7" Command="{Binding SwitchCreatorTabCommand}" CommandParameter="Release"/>
        <KeyBinding Gesture="Ctrl+K" Command="{Binding ToggleCreatorGlobalSearchCommand}"/>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding OpenCreatorNotesDrawerCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveActiveCreatorSurfaceCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAllCreatorSurfaceCommand}"/>
        <KeyBinding Gesture="Ctrl+E" Command="{Binding QuickCreatorExportCommand}"/>
        <KeyBinding Gesture="Ctrl+D" Command="{Binding OpenCreatorWorkbenchDiffModeCommand}"/>
        <KeyBinding Gesture="Ctrl+OemQuestion" Command="{Binding FocusCreatorCopilotDeskCommand}"/>
        <KeyBinding Gesture="Escape" Command="{Binding HandleCreatorEscapeCommand}"/>
    </UserControl.KeyBindings>

    <Panel>
        <Grid RowDefinitions="Auto,*">
            <!-- ═══════════════════ HEADER — 2-Row Compact ═══════════════════ -->
            <Border Background="{DynamicResource BgPanelBrush}" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1" Padding="24,14,24,12">
                <Grid RowDefinitions="Auto,8,Auto">
                    <!-- Row 1: Identity -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Width="40" Height="40" ClipToBounds="True">
                                <Grid>
                                    <asyncImage:AdvancedImage Source="{Binding BrandingLogoFallback}" Stretch="Uniform" IsVisible="{Binding HasBrandingLogo}"/>
                                    <TextBlock Text="CS" FontSize="16" FontWeight="Black" Foreground="{DynamicResource PrimaryBBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !HasBrandingLogo}"/>
                                </Grid>
                            </Border>
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CreatorHeaderPackIdentity}" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CreatorHeaderTechStack}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Command="{Binding UseCreatorCopilotDeskCommand}" Classes="primary" Padding="12,7" FontSize="12">
                                <TextBlock Text="Copilot Desk"/>
                            </Button>
                            <Button Command="{Binding UseDefaultContextDockCommand}" Classes="secondary" Padding="12,7" FontSize="12">
                                <TextBlock Text="Context Dock"/>
                            </Button>
                            <Button Command="{Binding OpenCreatorNotesDrawerCommand}" Classes="secondary" Padding="12,7" FontSize="12">
                                <TextBlock Text="Notes"/>
                            </Button>
                            <Button Command="{Binding ToggleCreatorGlobalSearchCommand}" Classes="secondary" Padding="12,7" FontSize="12" ToolTip.Tip="Ctrl+K">
                                <TextBlock Text="{StaticResource IconSearch}"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Status Badges -->
                    <WrapPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="999" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding CreatorHeaderGitBadge}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="999" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding CreatorHeaderDirtyBadge}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="999" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding CreatorHeaderExportBadge}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="999" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding CreatorManifestStatus}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>

                        <!-- Quick Actions -->
                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="999" Padding="2" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <Button Command="{Binding OpenStreamingScreenshotsFolderCommand}" Classes="ghost" Padding="8,4" FontSize="10" ToolTip.Tip="Screenshoty" IsEnabled="{Binding HasStreamingContextModpack}">
                                    <TextBlock Text="{StaticResource IconGallery}" FontSize="12"/>
                                </Button>
                                <Button Command="{Binding OpenStreamingLogsFolderCommand}" Classes="ghost" Padding="8,4" FontSize="10" ToolTip.Tip="Logy" IsEnabled="{Binding HasStreamingContextModpack}">
                                    <TextBlock Text="{StaticResource IconInfo}" FontSize="12"/>
                                </Button>
                                <Button Command="{Binding OpenStreamingWorkspaceCommand}" Classes="ghost" Padding="8,4" FontSize="10" ToolTip.Tip="Workspace slozka" IsEnabled="{Binding HasStreamingContextModpack}">
                                    <TextBlock Text="{StaticResource IconFolder}" FontSize="12"/>
                                </Button>
                                <Button Command="{Binding CopyCreatorSessionSummaryCommand}" Classes="ghost" Padding="8,4" FontSize="10" ToolTip.Tip="Kopirovat summary">
                                    <TextBlock Text="{StaticResource IconCopy}" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════ TAB CONTENT ═══════════════════ -->
            <TabControl Grid.Row="1" Margin="24,16,24,16" SelectedIndex="{Binding CreatorSelectedTabIndex}">

                <!-- ======== TAB 0 — OVERVIEW ======== -->
                <TabItem Header="Overview">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="16" Margin="8,4,8,40" MaxWidth="1560">
                            <!-- Workspace Picker -->
                            <Grid ColumnDefinitions="*,16,*">
                                <Border Classes="card">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Workspace" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <ComboBox ItemsSource="{Binding SkinStudioInstanceOptions}" SelectedItem="{Binding SelectedSkinStudioInstance}" IsEnabled="{Binding HasCreatorStudioInstances}" HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="models:SelectionOption">
                                                    <TextBlock Text="{Binding Label}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="12,10">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding CreatorStudioInstancePath}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding CreatorHeaderTechStack}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding CreatorStudioModCountLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Project Stats -->
                                <Border Grid.Column="2" Classes="card">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Stav projektu" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="10">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Mody" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding CreatorStatMods}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="Soubory" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding CreatorStatFiles}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Spacing="2">
                                                <TextBlock Text="Notes" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding CreatorStatNotes}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                                <TextBlock Text="Snapshoty" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding CreatorStatSnapshots}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Spacing="2">
                                                <TextBlock Text="Exporty" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding CreatorStatExports}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Activity Timeline -->
                            <Border Classes="card">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Posledni aktivita" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CreatorLastActivityLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    </Grid>

                                    <controls:EmptyState IsVisible="{Binding !HasCreatorActivityTimeline}" Icon="{StaticResource IconInfo}" Title="Zatim zadna aktivita" Subtitle="Aktivita se zacne zaznamenavat po prvni akci v Creator Studio."/>

                                    <ScrollViewer MaxHeight="280" IsVisible="{Binding HasCreatorActivityTimeline}" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding CreatorActivityTimelinePreview}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="creatorModels:CreatorActivityEntry">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                                        <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="12">
                                                            <TextBlock Text="{Binding TimeLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Summary}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                            <Border Grid.Column="2" Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3">
                                                                <TextBlock Text="{Binding TabContext}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Button IsVisible="{Binding HasMoreCreatorActivity}"
                                            Content="{Binding CreatorActivityExpandLabel}"
                                            Command="{Binding ToggleCreatorActivityExpandedCommand}"
                                            HorizontalAlignment="Center"
                                            Classes="link" Padding="8,4" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Quick Links + Recent Workspaces -->
                            <Grid ColumnDefinitions="*,16,*">
                                <Border Classes="card">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Odkazy" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <controls:EmptyState IsVisible="{Binding !HasCreatorQuickLinks}" Icon="{StaticResource IconInfo}" Title="Zadne odkazy" Subtitle="Nastav Website, Discord, GitHub v Identity tabu."/>
                                        <ItemsControl ItemsSource="{Binding CreatorQuickLinks}" IsVisible="{Binding HasCreatorQuickLinks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="creatorModels:CreatorQuickLink">
                                                    <Button Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).OpenCreatorQuickLinkCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource BgElevatedBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,6"
                                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Cursor="Hand">
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <TextBlock Text="{Binding Kind}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Url}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Classes="card">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Recent workspaces" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <ItemsControl ItemsSource="{Binding CreatorWorkspaceContext.RecentWorkspaces}" IsVisible="{Binding HasCreatorRecentWorkspaces}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                                        <StackPanel Spacing="3">
                                                            <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding LastAccessedUtc, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <controls:EmptyState IsVisible="{Binding !HasCreatorRecentWorkspaces}" Icon="{StaticResource IconInfo}" Title="Zadne recent workspaces" Subtitle="Vybrane instance se persistuji do launcher configu."/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ======== TAB 1 — IDENTITY (dříve Metadata) ======== -->
                <TabItem Header="Identity">
                    <Grid>
                        <!-- Read-only Warning -->
                        <Border Classes="card" IsVisible="{Binding IsCreatorWorkspaceReadOnly}" Margin="8,4,8,0" VerticalAlignment="Top" ZIndex="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Read-only workspace" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text="{Binding CreatorWorkspaceEditabilityMessage}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TabControl SelectedIndex="{Binding CreatorIdentitySubTabIndex}" Margin="8,4,8,8">
                            <!-- ── Sub-tab: Profile ── -->
                            <TabItem Header="Profile">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Spacing="16" Margin="0,8,0,40" MaxWidth="1560">
                                        <!-- Source of Truth -->
                                        <Border Classes="card">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Source of truth" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding CreatorManifestStatus}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                                                    <Button Command="{Binding GenerateManifestFromExistingCommand}" Classes="secondary" Padding="14,8" IsVisible="{Binding CanImportCreatorSourceMetadata}">
                                                        <TextBlock Text="{Binding CreatorSourceMetadataActionLabel}"/>
                                                    </Button>
                                                    <Button Command="{Binding SaveCreatorMetadataCommand}" Classes="primary" Padding="14,8" IsEnabled="{Binding CanSaveCreatorMetadata}">
                                                        <TextBlock Text="{Binding CreatorMetadataActionLabel}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Form (Left) + Live Preview (Right) -->
                                        <Grid ColumnDefinitions="*,16,380">
                                            <Border Classes="card" IsEnabled="{Binding IsCreatorWorkspaceEditable}">
                                                <StackPanel Spacing="14">
                                                    <TextBlock Text="Identita" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.6"/>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Pack name" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBox Text="{Binding CreatorMetadataPackName}" Watermark="Nazev packu"/>
                                                    </StackPanel>
                                                    <Grid ColumnDefinitions="*,12,*">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Slug" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorMetadataSlug}" Watermark="voidcraft-pack"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="6">
                                                            <TextBlock Text="Version" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorMetadataVersion}" Watermark="0.1.0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Summary" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBox Text="{Binding CreatorMetadataSummary}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="68" Watermark="Kratky popis packu a prvni release zamer."/>
                                                    </StackPanel>
                                                    <Grid ColumnDefinitions="*,12,*">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Authors" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorMetadataAuthors}" Watermark="VOIDIVIDE, VOID-CRAFT team"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="6">
                                                            <TextBlock Text="Release channel" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <ComboBox SelectedItem="{Binding CreatorMetadataReleaseChannel}" HorizontalAlignment="Stretch">
                                                                <x:String>alpha</x:String>
                                                                <x:String>beta</x:String>
                                                                <x:String>playtest</x:String>
                                                                <x:String>stable</x:String>
                                                            </ComboBox>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="Distribuce" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.6" Margin="0,8,0,0"/>
                                                    <Grid ColumnDefinitions="*,12,*">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Primary server" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorMetadataPrimaryServer}" Watermark="play.void-craft.eu"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="6">
                                                            <TextBlock Text="Recommended RAM (MB)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorMetadataRecommendedRamMb}" Watermark="12288"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="Odkazy" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.6" Margin="0,8,0,0"/>
                                                    <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,12,Auto">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Website" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorBrandWebsite}" Watermark="https://..."/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="6">
                                                            <TextBlock Text="Discord" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorBrandDiscord}" Watermark="https://discord.gg/..."/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Row="2" Spacing="6">
                                                            <TextBlock Text="GitHub" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorBrandGitHub}" Watermark="https://github.com/owner/repo"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Row="2" Grid.Column="2" Spacing="6">
                                                            <TextBlock Text="Support link" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorBrandSupportLink}" Watermark="https://..."/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Button Command="{Binding SaveCreatorMetadataCommand}" Classes="primary" Padding="16,10" HorizontalAlignment="Left" IsEnabled="{Binding CanSaveCreatorMetadata}" Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding CreatorMetadataActionLabel}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>

                                            <!-- Live Preview -->
                                            <Border Grid.Column="2" Classes="card">
                                                <StackPanel Spacing="14">
                                                    <TextBlock Text="Launcher preview" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <Border Background="#2A7FDB" CornerRadius="12" Padding="20,20" Height="300">
                                                        <Grid RowDefinitions="Auto,*">
                                                            <asyncImage:AdvancedImage Source="{Binding LauncherPreviewBackdrop}" Stretch="UniformToFill" IsVisible="{Binding HasLauncherPreviewBackdrop}"/>
                                                            <Border Background="#B8141725" CornerRadius="12" IsVisible="{Binding HasLauncherPreviewBackdrop}"/>
                                                            <Border Background="#1A1A1A" CornerRadius="16" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,6,0,0">
                                                                <Grid>
                                                                    <asyncImage:AdvancedImage Source="{Binding BrandingLogoFallback}" Stretch="Uniform" IsVisible="{Binding HasBrandingLogo}"/>
                                                                    <TextBlock Text="VC" FontSize="24" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !HasBrandingLogo}"/>
                                                                </Grid>
                                                            </Border>
                                                            <Border Grid.Row="1" Background="#99101924" CornerRadius="14" Padding="14,10" VerticalAlignment="Bottom" Margin="6,0,6,4">
                                                                <StackPanel Spacing="8">
                                                                    <TextBlock Text="{Binding LauncherPreviewTitle}" FontSize="16" FontWeight="ExtraBold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding LauncherPreviewDescription}" FontSize="10" Foreground="#E0E0E0" TextAlignment="Center" TextWrapping="Wrap" MaxLines="3" TextTrimming="CharacterEllipsis"/>
                                                                    <Grid ColumnDefinitions="Auto,*">
                                                                        <Border Background="#1E5A9D" CornerRadius="12" Padding="8,3">
                                                                            <TextBlock Text="{Binding LauncherPreviewAssetStatus}" FontSize="9" Foreground="White"/>
                                                                        </Border>
                                                                        <Border Grid.Column="1" Background="#1E5A9D" CornerRadius="12" Padding="8,3" HorizontalAlignment="Right">
                                                                            <TextBlock Text="{Binding LauncherPreviewChannel}" FontSize="9" Foreground="White"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Workspace Baseline Info -->
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="14,10">
                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                                            <TextBlock Text="Pack" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding CreatorMetadataPackName}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Row="1" Text="Autori" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CreatorMetadataAuthorsPreview}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Row="2" Text="MC" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CreatorWorkspaceContext.MinecraftVersion}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Grid.Row="3" Text="Loader" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CreatorWorkspaceContext.LoaderLabel}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Grid.Row="4" Text="Channel" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CreatorMetadataReleaseChannel}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ── Sub-tab: Branding ── -->
                            <TabItem Header="Branding">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Spacing="16" Margin="0,8,0,40" MaxWidth="1560">
                                        <!-- Brand Profile -->
                                        <Grid ColumnDefinitions="*,16,*">
                                            <Border Classes="card" IsEnabled="{Binding IsCreatorWorkspaceEditable}">
                                                <StackPanel Spacing="14">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <TextBlock Text="Brand profile" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <Button Grid.Column="1" Command="{Binding OpenCreatorBrandingFolderCommand}" Classes="secondary" Padding="12,7" FontSize="11">
                                                            <TextBlock Text="Brand slozka"/>
                                                        </Button>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="*,12,*">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="Accent color" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorBrandAccentColor}" Watermark="#3AA0FF"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="6">
                                                            <TextBlock Text="Launcher card title" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBox Text="{Binding CreatorBrandLauncherCardTitle}" Watermark="Kratsi marketingovy nazev"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="One-liner" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBox Text="{Binding CreatorBrandOneLiner}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="50" Watermark="Jedna veta, ktera vysvetli atmosferu a pointu packu."/>
                                                    </StackPanel>
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="12,10">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding BrandStorageStatus}" FontSize="11" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                            <TextBlock Text="{Binding BrandStoragePath}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- Asset Checklist -->
                                            <Border Grid.Column="2" Classes="card" IsEnabled="{Binding IsCreatorWorkspaceEditable}">
                                                <StackPanel Spacing="12">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                        <TextBlock Text="Asset sloty" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                            <Button Command="{Binding SaveCreatorMetadataCommand}" Classes="primary" Padding="12,7" FontSize="11" IsEnabled="{Binding CanSaveCreatorMetadata}">
                                                                <TextBlock Text="{Binding CreatorMetadataActionLabel}"/>
                                                            </Button>
                                                            <Button Command="{Binding ExportMediaKitCommand}" Classes="secondary" Padding="12,7" FontSize="11">
                                                                <TextBlock Text="Export kit"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Logo -->
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="64,12,*,Auto" ColumnSpacing="0">
                                                            <Border Width="56" Height="56" CornerRadius="10" ClipToBounds="True" Background="{DynamicResource BgPanelBrush}">
                                                                <Grid>
                                                                    <asyncImage:AdvancedImage Source="{Binding BrandingLogoFallback}" Stretch="Uniform" IsVisible="{Binding HasBrandingLogo}"/>
                                                                    <TextBlock Text="—" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !HasBrandingLogo}"/>
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="Logo (512x512)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                <TextBlock Text="{Binding HasBrandingLogoAsset, StringFormat='Nahrano: {0}'}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <Button Command="{Binding UploadBrandingAssetCommand}" CommandParameter="Logo" Classes="secondary" Padding="10,6" FontSize="10" Content="Nahraj"/>
                                                                <Button Command="{Binding RemoveBrandingAssetCommand}" CommandParameter="Logo" Classes="secondary" Padding="10,6" FontSize="10" IsVisible="{Binding HasBrandingLogoAsset}" Content="Odebrat"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Cover -->
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="100,12,*,Auto" ColumnSpacing="0">
                                                            <Border Width="96" Height="54" CornerRadius="8" ClipToBounds="True" Background="{DynamicResource BgPanelBrush}">
                                                                <Grid>
                                                                    <asyncImage:AdvancedImage Source="{Binding BrandingCoverPreview}" Stretch="UniformToFill" IsVisible="{Binding HasBrandingCover}"/>
                                                                    <TextBlock Text="—" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !HasBrandingCover}"/>
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="Cover (16:9)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <Button Command="{Binding UploadBrandingAssetCommand}" CommandParameter="Cover" Classes="secondary" Padding="10,6" FontSize="10" Content="Nahraj"/>
                                                                <Button Command="{Binding RemoveBrandingAssetCommand}" CommandParameter="Cover" Classes="secondary" Padding="10,6" FontSize="10" IsVisible="{Binding HasBrandingCover}" Content="Odebrat"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Square Icon -->
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="64,12,*,Auto" ColumnSpacing="0">
                                                            <Border Width="40" Height="40" CornerRadius="8" ClipToBounds="True" Background="{DynamicResource BgPanelBrush}">
                                                                <Grid>
                                                                    <asyncImage:AdvancedImage Source="{Binding BrandingSquareIconPreview}" Stretch="Uniform" IsVisible="{Binding HasBrandingSquareIcon}"/>
                                                                    <TextBlock Text="—" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !HasBrandingSquareIcon}"/>
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="Square Icon (256x256)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <Button Command="{Binding UploadBrandingAssetCommand}" CommandParameter="SquareIcon" Classes="secondary" Padding="10,6" FontSize="10" Content="Nahraj"/>
                                                                <Button Command="{Binding RemoveBrandingAssetCommand}" CommandParameter="SquareIcon" Classes="secondary" Padding="10,6" FontSize="10" IsVisible="{Binding HasBrandingSquareIcon}" Content="Odebrat"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Wide Hero -->
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="100,12,*,Auto" ColumnSpacing="0">
                                                            <Border Width="96" Height="30" CornerRadius="6" ClipToBounds="True" Background="{DynamicResource BgPanelBrush}">
                                                                <Grid>
                                                                    <asyncImage:AdvancedImage Source="{Binding BrandingWideHeroPreview}" Stretch="UniformToFill" IsVisible="{Binding HasBrandingWideHero}"/>
                                                                    <TextBlock Text="—" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !HasBrandingWideHero}"/>
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="Wide Hero (32:9)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <Button Command="{Binding UploadBrandingAssetCommand}" CommandParameter="WideHero" Classes="secondary" Padding="10,6" FontSize="10" Content="Nahraj"/>
                                                                <Button Command="{Binding RemoveBrandingAssetCommand}" CommandParameter="WideHero" Classes="secondary" Padding="10,6" FontSize="10" IsVisible="{Binding HasBrandingWideHero}" Content="Odebrat"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Social Preview -->
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="100,12,*,Auto" ColumnSpacing="0">
                                                            <Border Width="96" Height="50" CornerRadius="6" ClipToBounds="True" Background="{DynamicResource BgPanelBrush}">
                                                                <Grid>
                                                                    <asyncImage:AdvancedImage Source="{Binding BrandingSocialPreviewPreview}" Stretch="UniformToFill" IsVisible="{Binding HasBrandingSocialPreview}"/>
                                                                    <TextBlock Text="—" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !HasBrandingSocialPreview}"/>
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="Social Preview (1200x630)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                <Button Command="{Binding UploadBrandingAssetCommand}" CommandParameter="SocialPreview" Classes="secondary" Padding="10,6" FontSize="10" Content="Nahraj"/>
                                                                <Button Command="{Binding RemoveBrandingAssetCommand}" CommandParameter="SocialPreview" Classes="secondary" Padding="10,6" FontSize="10" IsVisible="{Binding HasBrandingSocialPreview}" Content="Odebrat"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Promo Gallery -->
                                        <Border Classes="card" IsEnabled="{Binding IsCreatorWorkspaceEditable}">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                    <TextBlock Text="Promo galerie" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <Button Grid.Column="1" Command="{Binding RefreshCreatorScreenshotsCommand}" Classes="secondary" Padding="12,7" FontSize="11">
                                                        <TextBlock Text="Obnovit"/>
                                                    </Button>
                                                    <Button Grid.Column="2" Command="{Binding OpenCreatorScreenshotFolderCommand}" Classes="secondary" Padding="12,7" FontSize="11">
                                                        <TextBlock Text="Otevrit slozku"/>
                                                    </Button>
                                                </Grid>

                                                <!-- Featured Screenshot -->
                                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="14" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding HasFeaturedCreatorScreenshot}">
                                                    <Grid ColumnDefinitions="164,16,*">
                                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="10" Height="92" ClipToBounds="True">
                                                            <asyncImage:AdvancedImage Source="{Binding FeaturedCreatorScreenshotPreview}" Stretch="UniformToFill"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FeaturedCreatorScreenshotStatus}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding FeaturedCreatorScreenshotCaption}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <controls:EmptyState IsVisible="{Binding !HasCreatorScreenshots}" Icon="{StaticResource IconGallery}" Title="Zatim zadne screenshoty" Subtitle="Otevri screenshot slozku workspace, pridej obrazky a pak je tady oznac."/>

                                                <!-- Screenshot Grid -->
                                                <ItemsControl ItemsSource="{Binding CreatorScreenshotGallery}" IsVisible="{Binding HasCreatorScreenshots}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:CompileBindings="False">
                                                            <Border Width="240" Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="10" Margin="0,0,10,10" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                                <StackPanel Spacing="8">
                                                                    <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                                            Command="{Binding DataContext.OpenScreenshotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding PreviewUri}">
                                                                        <Border Height="128" CornerRadius="8" ClipToBounds="True" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                                            <asyncImage:AdvancedImage Source="{Binding PreviewUri}" Stretch="UniformToFill"/>
                                                                        </Border>
                                                                    </Button>
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="{Binding FileName}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding CapturedLabel}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                    </StackPanel>
                                                                    <WrapPanel Orientation="Horizontal">
                                                                        <Border Background="{DynamicResource PrimaryBBrush}" CornerRadius="999" Padding="7,2" Margin="0,0,4,4" IsVisible="{Binding IsFavorite}">
                                                                            <TextBlock Text="Favorit" FontSize="9" Foreground="White"/>
                                                                        </Border>
                                                                        <Border Background="#245B8B" CornerRadius="999" Padding="7,2" Margin="0,0,4,4" IsVisible="{Binding IsOfficial}">
                                                                            <TextBlock Text="Official" FontSize="9" Foreground="White"/>
                                                                        </Border>
                                                                        <Border Background="#8B6A24" CornerRadius="999" Padding="7,2" Margin="0,0,4,4" IsVisible="{Binding IsReleaseCandidate}">
                                                                            <TextBlock Text="RC" FontSize="9" Foreground="White"/>
                                                                        </Border>
                                                                        <Border Background="#5A5A5A" CornerRadius="999" Padding="7,2" Margin="0,0,4,4" IsVisible="{Binding IsArchive}">
                                                                            <TextBlock Text="Archive" FontSize="9" Foreground="White"/>
                                                                        </Border>
                                                                    </WrapPanel>
                                                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                                                                        <Button Command="{Binding DataContext.ToggleCreatorScreenshotFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" Classes="secondary" Padding="6,5" FontSize="9" Content="{Binding FavoriteActionLabel}"/>
                                                                        <Button Grid.Column="1" Command="{Binding DataContext.MarkCreatorScreenshotOfficialCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" Classes="secondary" Padding="6,5" FontSize="9" Content="Official"/>
                                                                        <Button Grid.Column="2" Command="{Binding DataContext.ClearCreatorScreenshotStageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" Classes="secondary" Padding="6,5" FontSize="9" Content="Reset"/>
                                                                    </Grid>
                                                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                                                                        <Button Command="{Binding DataContext.UseCreatorScreenshotAsCoverCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" Classes="secondary" Padding="6,5" FontSize="9" Content="Na cover"/>
                                                                        <Button Grid.Column="1" Command="{Binding DataContext.UseCreatorScreenshotAsSocialPreviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" Classes="secondary" Padding="6,5" FontSize="9" Content="Na social"/>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <!-- ======== TAB 2 — MODS ======== -->
            <TabItem Header="Mods">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="8,4,8,40" MaxWidth="1560">
                        <Border Classes="card" IsVisible="{Binding IsCreatorWorkspaceReadOnly}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Read-only workspace" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text="{Binding CreatorWorkspaceEditabilityMessage}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="Správa modů" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding CreatorModsWorkspaceStatus}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding CreatorModsFolderPath}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding RefreshInstalledModsCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Top">
                                    <TextBlock Text="Obnovit"/>
                                </Button>
                                <Button Grid.Column="2" Command="{Binding OpenCreatorModsFolderCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Top">
                                    <TextBlock Text="Mods slozka"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="1.1*,16,0.9*" IsVisible="{Binding CanManageCreatorModsInPlace}">
                            <Border Grid.Column="0" Classes="card">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Katalog modů" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CreatorModsSearchResultsSummary}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <WrapPanel Orientation="Horizontal">
                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="12,6" Margin="0,0,8,8">
                                            <TextBlock Text="{Binding CreatorModsRuntimeLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>
                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="12,6" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding CreatorModsCatalogModeLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                        </Border>
                                    </WrapPanel>

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Text="{StaticResource IconSearch}" VerticalAlignment="Center" Margin="14,0,8,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="14"/>
                                                <TextBox Grid.Column="1" Text="{Binding ProfileModSearchQuery}" Watermark="Hledej mod podle názvu, klíčového slova nebo feature..."
                                                         BorderThickness="0" Background="Transparent" FontSize="13" Padding="4,12">
                                                    <TextBox.KeyBindings>
                                                        <KeyBinding Gesture="Enter" Command="{Binding SearchModsForProfileCommand}"/>
                                                    </TextBox.KeyBindings>
                                                </TextBox>
                                            </Grid>
                                        </Border>
                                        <Button Grid.Column="1" Content="{Binding CreatorModsSearchActionLabel}" Command="{Binding SearchModsForProfileCommand}" Classes="primary" FontSize="12" Padding="18,12" MinWidth="110"/>
                                    </Grid>

                                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="{Binding ProfileModSearchSelectionSummary}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                            <WrapPanel Orientation="Horizontal">
                                                <Button Command="{Binding SelectAllProfileSearchModsCommand}" Classes="secondary" Padding="12,8" Margin="0,0,8,8" IsEnabled="{Binding HasProfileModSearchResults}">
                                                    <TextBlock Text="Vybrat vsechny vysledky"/>
                                                </Button>
                                                <Button Command="{Binding ClearProfileSearchModSelectionCommand}" Classes="secondary" Padding="12,8" Margin="0,0,8,8" IsEnabled="{Binding HasSelectedProfileSearchMods}">
                                                    <TextBlock Text="Zrusit vyber"/>
                                                </Button>
                                                <Button Command="{Binding AddSelectedModsToProfileCommand}" Classes="primary" Padding="12,8" Margin="0,0,8,8" IsEnabled="{Binding HasSelectedProfileSearchMods}">
                                                    <TextBlock Text="Pridat vybrane"/>
                                                </Button>
                                                <Button Command="{Binding AddLocalModsToProfileCommand}" Classes="secondary" Padding="12,8" Margin="0,0,0,8">
                                                    <TextBlock Text="Pridat local .jar"/>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="14" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding IsProfileModSearchLoading}">
                                        <TextBlock Text="Načítám výsledky z CurseForge a Modrinth. Když přesný runtime filtr nic nevrátí, launcher zkusí širší katalog." FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </Border>

                                    <controls:EmptyState IsVisible="{Binding ShowCreatorModsSearchEmptyState}" Icon="{StaticResource IconSearch}" Title="Nic se nenašlo" Subtitle="{Binding CreatorModsSearchResultsSummary}"/>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="760" IsVisible="{Binding HasProfileModSearchResults}">
                                        <ItemsControl ItemsSource="{Binding ProfileModSearchResults}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,10" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="Auto,60,*,Auto" ColumnSpacing="14">
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Top" Margin="0,4,0,0" IsVisible="{Binding !IsInstalled}"/>

                                                            <Border Grid.Column="1" Width="56" Height="56" CornerRadius="12" ClipToBounds="True" Background="{DynamicResource BgInteractiveBrush}" VerticalAlignment="Top">
                                                                <asyncImage:AdvancedImage Source="{Binding IconUrl}" Width="56" Height="56" Stretch="UniformToFill"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="2" Spacing="5">
                                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                                    <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3" Margin="0,0,6,0">
                                                                            <TextBlock Text="{Binding Source}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                                        </Border>
                                                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3">
                                                                            <TextBlock Text="{Binding DownloadCount, StringFormat='↓ {0}'}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                        </Border>
                                                                    </WrapPanel>
                                                                </Grid>

                                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxLines="3" IsVisible="{Binding Description.Length}"/>
                                                                <TextBlock Text="{Binding Author, StringFormat='Autor: {0}'}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" IsVisible="{Binding Author.Length}"/>

                                                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="10" Padding="10" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding !IsInstalled}">
                                                                    <StackPanel Spacing="8">
                                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                            <StackPanel Spacing="2">
                                                                                <TextBlock Text="Verze pro instalaci" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                                <TextBlock Text="{Binding VersionSelectionStatusLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" IsVisible="{Binding VersionSelectionStatusLabel.Length}"/>
                                                                            </StackPanel>
                                                                            <Button Grid.Column="1" Command="{Binding DataContext.LoadModVersionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                    CommandParameter="{Binding}"
                                                                                    Classes="secondary"
                                                                                    Padding="10,6"
                                                                                    FontSize="10"
                                                                                    VerticalAlignment="Top"
                                                                                    IsEnabled="{Binding !IsLoadingVersionOptions}">
                                                                                <TextBlock Text="Nacist verze" IsVisible="{Binding !IsLoadingVersionOptions}"/>
                                                                            </Button>
                                                                        </Grid>

                                                                        <ComboBox ItemsSource="{Binding AvailableVersionOptions}"
                                                                                  SelectedItem="{Binding SelectedVersionOption, Mode=TwoWay}"
                                                                                  IsVisible="{Binding HasAvailableVersionOptions}"
                                                                                  HorizontalAlignment="Stretch"
                                                                                  MinWidth="260">
                                                                            <ComboBox.ItemTemplate>
                                                                                <DataTemplate x:DataType="models:ModInstallVersionOption">
                                                                                    <StackPanel Spacing="1">
                                                                                        <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"/>
                                                                                        <TextBlock Text="{Binding Summary}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                                                    </StackPanel>
                                                                                </DataTemplate>
                                                                            </ComboBox.ItemTemplate>
                                                                        </ComboBox>
                                                                    </StackPanel>
                                                                </Border>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="3" Spacing="8" VerticalAlignment="Center">
                                                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3" HorizontalAlignment="Right" IsVisible="{Binding IsInstalled}">
                                                                    <TextBlock Text="Uz je ve workspace" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                </Border>
                                                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="10,5" HorizontalAlignment="Right" IsVisible="{Binding IsDownloading}">
                                                                    <TextBlock Text="{Binding DownloadStatusLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                                </Border>
                                                                <Button Command="{Binding DataContext.AddModToProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Classes="primary"
                                                                        Padding="14,8"
                                                                        MinWidth="104"
                                                                        IsEnabled="{Binding !IsInstalled}"
                                                                        IsVisible="{Binding !IsDownloading}">
                                                                    <TextBlock Text="Pridat"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Load More / Infinite scroll trigger -->
                                    <Button Command="{Binding LoadMoreModsForProfileCommand}"
                                            IsVisible="{Binding CanLoadMoreMods}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Classes="secondary" Padding="14,12" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Nacist dalsi mody..." FontSize="12" IsVisible="{Binding !IsLoadingMoreMods}"/>
                                            <TextBlock Text="Nacitam..." FontSize="12" IsVisible="{Binding IsLoadingMoreMods}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Nainstalováno ve workspace" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CreatorInstalledModsSummary}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="12,6" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding CreatorStudioModCountLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                        </Border>
                                    </Grid>

                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Text="{StaticResource IconSearch}" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                                            <TextBox Grid.Column="1" Text="{Binding InstalledModsSearchQuery}" Watermark="Filtrovat nainstalované mody podle názvu, autora, source nebo souboru..."
                                                     BorderThickness="0" Background="Transparent" FontSize="12" Padding="4,10"/>
                                        </Grid>
                                    </Border>

                                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="{Binding InstalledModsSelectionSummary}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                            <WrapPanel Orientation="Horizontal">
                                                <Button Command="{Binding SelectAllInstalledModsCommand}" Classes="secondary" Padding="12,8" Margin="0,0,8,8">
                                                    <TextBlock Text="Vybrat vse"/>
                                                </Button>
                                                <Button Command="{Binding ClearInstalledModSelectionCommand}" Classes="secondary" Padding="12,8" Margin="0,0,8,8" IsEnabled="{Binding HasSelectedInstalledMods}">
                                                    <TextBlock Text="Zrusit vyber"/>
                                                </Button>
                                                <Button Command="{Binding EnableSelectedInstalledModsCommand}" Classes="secondary" Padding="12,8" Margin="0,0,8,8" IsEnabled="{Binding HasSelectedInstalledMods}">
                                                    <TextBlock Text="Zapnout"/>
                                                </Button>
                                                <Button Command="{Binding DisableSelectedInstalledModsCommand}" Classes="secondary" Padding="12,8" Margin="0,0,8,8" IsEnabled="{Binding HasSelectedInstalledMods}">
                                                    <TextBlock Text="Vypnout"/>
                                                </Button>
                                                <Button Command="{Binding RemoveSelectedModsFromProfileCommand}" Classes="primary" Padding="12,8" Margin="0,0,0,8" IsEnabled="{Binding HasSelectedInstalledMods}">
                                                    <TextBlock Text="Odebrat"/>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <controls:EmptyState IsVisible="{Binding !HasFilteredInstalledMods}" Icon="{StaticResource IconSearch}" Title="{Binding InstalledModsEmptyTitle}" Subtitle="{Binding InstalledModsEmptySubtitle}"/>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="760" IsVisible="{Binding HasFilteredInstalledMods}">
                                        <ItemsControl ItemsSource="{Binding FilteredInstalledMods}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,8" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="Auto,40,*,Auto" ColumnSpacing="10">
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Top" Margin="0,6,0,0"/>

                                                            <Border Grid.Column="1" Width="36" Height="36" CornerRadius="10" ClipToBounds="True" Background="{DynamicResource BgPanelBrush}" VerticalAlignment="Top">
                                                                <asyncImage:AdvancedImage Source="{Binding IconUrl}" Width="36" Height="36" Stretch="UniformToFill"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="2" Spacing="3">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                    <TextBlock Text="{Binding Source}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,2" IsVisible="{Binding !IsEnabled}">
                                                                        <TextBlock Text="Vypnuto" FontSize="9" Foreground="{DynamicResource WarningBrush}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxLines="2" IsVisible="{Binding Description.Length}"/>
                                                                <TextBlock Text="{Binding Author, StringFormat='Autor: {0}'}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}" IsVisible="{Binding Author.Length}"/>
                                                                <TextBlock Text="{Binding InstalledFileName}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                                <Button Command="{Binding DataContext.ToggleInstalledModEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Classes="secondary" Padding="10,6"
                                                                        IsVisible="{Binding IsEnabled}">
                                                                    <TextBlock Text="Vypnout"/>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.ToggleInstalledModEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Classes="secondary" Padding="10,6"
                                                                        IsVisible="{Binding !IsEnabled}">
                                                                    <TextBlock Text="Zapnout"/>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.RemoveModFromProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Classes="secondary" Padding="10,6">
                                                                    <TextBlock Text="Odebrat"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Classes="card" IsVisible="{Binding !CanManageCreatorModsInPlace}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Nainstalované mody" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CreatorInstalledModsSummary}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                <controls:EmptyState IsVisible="{Binding !HasFilteredInstalledMods}" Icon="{StaticResource IconSearch}" Title="{Binding InstalledModsEmptyTitle}" Subtitle="{Binding InstalledModsEmptySubtitle}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="720" IsVisible="{Binding HasFilteredInstalledMods}">
                                    <ItemsControl ItemsSource="{Binding FilteredInstalledMods}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:CompileBindings="False">
                                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,8" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" IsVisible="{Binding Description.Length}"/>
                                                        <TextBlock Text="{Binding InstalledFileName}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Files">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="8,4,8,40" MaxWidth="1560">
                        <Border Classes="card" IsVisible="{Binding IsCreatorWorkspaceReadOnly}">
                            <TextBlock Text="{Binding CreatorWorkspaceEditabilityMessage}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </Border>

                        <Grid ColumnDefinitions="340,16,*">
                            <Border Grid.Column="0" Classes="card">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Seznam souborů" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CreatorWorkbenchSearchSummary}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <TextBox Text="{Binding CreatorWorkbenchSearchQuery}" Watermark="Hledej podle názvu, cesty nebo typu..."/>

                                    <controls:EmptyState IsVisible="{Binding !HasVisibleCreatorWorkbenchFiles}" Icon="{StaticResource IconFolder}" Title="{Binding CreatorWorkbenchEmptyTitle}" Subtitle="{Binding CreatorWorkbenchEmptySubtitle}"/>

                                    <ListBox ItemsSource="{Binding FilteredCreatorWorkbenchFiles}" SelectedItem="{Binding SelectedCreatorWorkbenchFile}" IsVisible="{Binding HasVisibleCreatorWorkbenchFiles}" Height="860">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:CreatorWorkbenchFile">
                                                <StackPanel Spacing="3" Margin="2">
                                                    <TextBlock Text="{Binding RelativePath}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                        <TextBlock Text="{Binding SizeLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Soubory workspace" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CreatorWorkbenchBreadcrumb}" FontSize="11" Foreground="{DynamicResource PrimaryBBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CreatorWorkbenchSelectionLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CreatorWorkbenchSelectionMeta}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Slozka souboru" Command="{Binding OpenCreatorWorkbenchFileLocationCommand}" Classes="secondary" Padding="12,8" FontSize="11" IsEnabled="{Binding CanOpenCreatorWorkbenchFileLocation}" VerticalAlignment="Top"/>
                                        <Button Grid.Column="2" Content="Ulozit zmeny" Command="{Binding SaveCreatorWorkbenchFileCommand}" Classes="primary" Padding="12,8" FontSize="11" IsEnabled="{Binding CanSaveCreatorWorkbenchFile}" VerticalAlignment="Top"/>
                                    </Grid>

                                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                        <StackPanel Spacing="8">
                                            <WrapPanel Orientation="Horizontal">
                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding CreatorWorkbenchDocumentKindLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                </Border>
                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding CreatorWorkbenchDirtyStateLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                                    <TextBlock Text="{Binding CreatorWorkbenchParserLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="999" Padding="10,5" Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding CreatorWorkbenchValidationSummary}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Text="{Binding CreatorWorkbenchDocumentSummary}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CreatorWorkbenchStatus}" FontSize="11" Foreground="{DynamicResource PrimaryBBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid ColumnDefinitions="*">
                                        <StackPanel Spacing="12">
                                            <Grid ColumnDefinitions="200,12,*,12,Auto" ColumnSpacing="0">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Režim" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <ComboBox ItemsSource="{Binding CreatorWorkbenchModeOptions}" SelectedItem="{Binding SelectedCreatorWorkbenchMode}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate x:DataType="models:SelectionOption">
                                                                <TextBlock Text="{Binding Label}"/>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Spacing="4" IsVisible="{Binding IsCreatorWorkbenchDiffMode}">
                                                    <TextBlock Text="Porovnat proti" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <ComboBox ItemsSource="{Binding CreatorWorkbenchComparisonTargets}" SelectedItem="{Binding SelectedCreatorWorkbenchComparisonTarget}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate x:DataType="creatorModels:CreatorWorkbenchComparisonTarget">
                                                                <StackPanel Spacing="1">
                                                                    <TextBlock Text="{Binding Label}"/>
                                                                    <TextBlock Text="{Binding Summary}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>

                                                <Button Grid.Column="4" Command="{Binding RefreshCreatorWorkbenchCommand}" Classes="secondary" Padding="12,8" FontSize="11" VerticalAlignment="Bottom">
                                                    <TextBlock Text="Obnovit soubory"/>
                                                </Button>
                                            </Grid>

                                            <!-- Empty state -->
                                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding !HasSelectedCreatorWorkbenchFile}">
                                                <controls:EmptyState Icon="{StaticResource IconFolder}" Title="Vyber soubor vlevo" Subtitle="Po výběru se otevře editor s vizuální editací hodnot."/>
                                            </Border>

                                            <!-- Structure warning -->
                                            <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="10" Padding="12" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" IsVisible="{Binding HasCreatorWorkbenchStructureWarning}">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Pozor při uložení" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding CreatorWorkbenchStructureWarning}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- ═══ Form mode — structured key-value editor ═══ -->
                                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="0" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding ShowCreatorWorkbenchStructuredPreview}">
                                                <StackPanel Spacing="0">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12,12,0,0" Padding="14,10">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                <TextBlock Text="Strukturovaný editor" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3">
                                                                    <TextBlock Text="{Binding CreatorWorkbenchParserLabel}" FontSize="9" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                                </Border>
                                                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3" IsVisible="{Binding IsCreatorWorkspaceReadOnly}">
                                                                    <TextBlock Text="READ-ONLY" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding CreatorWorkbenchStructuredSummary}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding CreatorWorkbenchDocumentKindLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Structured fields form -->
                                                    <Border Padding="14,10" CornerRadius="0,0,0,0" IsVisible="{Binding HasFilteredCreatorWorkbenchStructuredFields}">
                                                        <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
                                                            <ItemsControl ItemsSource="{Binding FilteredCreatorWorkbenchStructuredFields}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:CompileBindings="False">
                                                                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12,8" Margin="0,0,0,6" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                                            <Grid ColumnDefinitions="*,2*,Auto" ColumnSpacing="12">
                                                                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding DisplayPath}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                                                    <TextBlock Text="{Binding SectionLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
                                                                                </StackPanel>
                                                                                <TextBox Grid.Column="1" Text="{Binding EditableValue, UpdateSourceTrigger=PropertyChanged}"
                                                                                         IsEnabled="{Binding !DataContext.IsCreatorWorkspaceReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                         FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                                                                                         Background="#1E1E2E" Foreground="#CDD6F4" Padding="10,6" CornerRadius="6"/>
                                                                                <Border Grid.Column="2" Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3" VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding ValueTypeLabel}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                                </Border>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </ScrollViewer>
                                                    </Border>

                                                    <controls:EmptyState IsVisible="{Binding !HasFilteredCreatorWorkbenchStructuredFields}" Icon="{StaticResource IconInfo}" Title="Není co upravovat formulářově" Subtitle="Soubor nemá rozpoznané klíč-hodnota páry." Margin="12"/>

                                                    <!-- Raw preview of the full file below -->
                                                    <Border Background="{DynamicResource BgElevatedBrush}" Padding="14,8" CornerRadius="0">
                                                        <TextBlock Text="Výsledný soubor (raw preview)" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </Border>
                                                    <Border Padding="0" CornerRadius="0,0,12,12">
                                                        <TextBox Text="{Binding CreatorWorkbenchContent}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="300"
                                                                 FontFamily="Cascadia Mono, Consolas, monospace" FontSize="13" Padding="16,12"
                                                                 Background="#1E1E2E" Foreground="#CDD6F4" BorderThickness="0" CornerRadius="0,0,12,12"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- ═══ Raw editor mode ═══ -->
                                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="0" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding ShowCreatorWorkbenchRawEditor}">
                                                <StackPanel Spacing="0">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12,12,0,0" Padding="14,10">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                <TextBlock Text="Editor souboru" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3">
                                                                    <TextBlock Text="{Binding CreatorWorkbenchParserLabel}" FontSize="9" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                                </Border>
                                                                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="8,3" IsVisible="{Binding IsCreatorWorkspaceReadOnly}">
                                                                    <TextBlock Text="READ-ONLY" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding CreatorWorkbenchValidationSummary}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding CreatorWorkbenchDocumentKindLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <Border Padding="0" CornerRadius="0,0,12,12">
                                                        <TextBox Text="{Binding CreatorWorkbenchContent, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="NoWrap"
                                                                 MinHeight="680" IsEnabled="{Binding HasSelectedCreatorWorkbenchFile}" IsReadOnly="{Binding IsCreatorWorkspaceReadOnly}"
                                                                 FontFamily="Cascadia Mono, Consolas, monospace" FontSize="13" Padding="16,12"
                                                                 Background="#1E1E2E" Foreground="#CDD6F4" BorderThickness="0" CornerRadius="0,0,12,12"
                                                                 Watermark="Vyber soubor vlevo a jeho obsah se zobrazí tady."/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <!-- ═══ Diff viewer mode ═══ -->
                                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding ShowCreatorWorkbenchDiffViewer}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Porovnání změn" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding CreatorWorkbenchDiffSummary}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                    <controls:EmptyState IsVisible="{Binding !HasCreatorWorkbenchDiffLines}" Icon="{StaticResource IconInfo}" Title="Zatím bez rozdílů" Subtitle="Vyber porovnání nebo uprav obsah a diff se přepočítá."/>
                                                    <ScrollViewer Height="680" IsVisible="{Binding HasCreatorWorkbenchDiffLines}">
                                                        <ItemsControl ItemsSource="{Binding CreatorWorkbenchDiffLines}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="creatorModels:CreatorWorkbenchDiffLine">
                                                                    <Border Background="{Binding Background}" CornerRadius="8" Padding="6,4" Margin="0,0,0,4">
                                                                        <Grid ColumnDefinitions="24,56,56,*" ColumnSpacing="8">
                                                                            <TextBlock Text="{Binding ChangeMarker}" Foreground="{Binding Foreground}" FontWeight="Bold" VerticalAlignment="Top" FontFamily="Consolas, Cascadia Mono, monospace"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding OldLineLabel}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" VerticalAlignment="Top" FontFamily="Consolas, Cascadia Mono, monospace"/>
                                                                            <TextBlock Grid.Column="2" Text="{Binding NewLineLabel}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" VerticalAlignment="Top" FontFamily="Consolas, Cascadia Mono, monospace"/>
                                                                            <TextBlock Grid.Column="3" Text="{Binding Text}" Foreground="{Binding Foreground}" FontFamily="Consolas, Cascadia Mono, monospace" TextWrapping="Wrap"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </Border>

                                            <!-- Validation issues (inline, below editor) -->
                                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding HasCreatorWorkbenchValidationIssues}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Problémy" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <ItemsControl ItemsSource="{Binding CreatorWorkbenchValidationIssues}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="creatorModels:CreatorWorkbenchValidationIssue">
                                                                <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,0,4" BorderBrush="{Binding AccentBrush}" BorderThickness="1">
                                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding Scope}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding AccentBrush}" VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding Message}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ======== TAB 4 — NOTES ======== -->
            <TabItem Header="Notes">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="8,4,8,40" MaxWidth="1560">
                        <!-- Mode switcher + actions -->
                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Notes" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding CreatorNotesDocumentsSummary}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="12,6">
                                        <TextBlock Text="{Binding CreatorNotesModeLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="2" Command="{Binding CreateCreatorNoteDocumentCommand}" Classes="primary" Padding="14,8" VerticalAlignment="Top" IsEnabled="{Binding IsCreatorWorkspaceEditable}">
                                    <TextBlock Text="{Binding CreatorNotesPrimaryActionLabel}"/>
                                </Button>
                                <Button Grid.Column="3" Command="{Binding SaveActiveCreatorNotesSurfaceCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Top" IsEnabled="{Binding CanSaveActiveCreatorNotesSurface}">
                                    <TextBlock Text="Ulozit"/>
                                </Button>
                                <Button Grid.Column="4" Command="{Binding RefreshCreatorNotesCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Top">
                                    <TextBlock Text="Obnovit"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Mode tabs -->
                        <Border Classes="card" Padding="8">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="Docs" Command="{Binding SetCreatorNotesModeCommand}" CommandParameter="docs" Padding="14,8" FontSize="12"/>
                                <Button Content="Wiki" Command="{Binding SetCreatorNotesModeCommand}" CommandParameter="wiki" Padding="14,8" FontSize="12"/>
                                <Button Content="Canvas" Command="{Binding SetCreatorNotesModeCommand}" CommandParameter="canvas" Padding="14,8" FontSize="12"/>
                                <Button Content="Mind Map" Command="{Binding SetCreatorNotesModeCommand}" CommandParameter="mindmap" Padding="14,8" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- Docs mode: sidebar + editor -->
                        <Grid ColumnDefinitions="300,16,*" IsVisible="{Binding IsCreatorNotesModeDocs}">
                            <!-- Document sidebar -->
                            <Border Grid.Column="0" Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Dokumenty" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <controls:EmptyState IsVisible="{Binding !HasCreatorNoteDocuments}" Icon="{StaticResource IconFolder}" Title="Zadne poznamky" Subtitle="Vytvor novy dokument nebo pridej .md/.txt soubory do notes/ slozky workspace."/>
                                    <ListBox ItemsSource="{Binding CreatorNoteDocuments}" SelectedItem="{Binding SelectedCreatorNoteDocument}" IsVisible="{Binding HasCreatorNoteDocuments}" MaxHeight="700">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="creatorModels:CreatorNoteDocument">
                                                <Grid ColumnDefinitions="*,Auto" Margin="2">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding LocationLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            <TextBlock Text="{Binding ModifiedLabel}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Command="{Binding #StreamingToolsRoot.DataContext.DeleteCreatorNoteDocumentCommand}" CommandParameter="{Binding}" Classes="ghost" Padding="6,4" FontSize="10" VerticalAlignment="Center" IsEnabled="{Binding #StreamingToolsRoot.DataContext.IsCreatorWorkspaceEditable}">
                                                        <TextBlock Text="X" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <!-- Editor -->
                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding SelectedCreatorNoteDocument.Title, FallbackValue='Vyber dokument'}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedCreatorNoteDocument.LocationLabel, FallbackValue=''}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                            <TextBlock Text="{Binding SelectedCreatorNoteDocument.ModifiedLabel, FallbackValue=''}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <Button Command="{Binding SaveCreatorNoteCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Center" IsEnabled="{Binding CanSaveCreatorNote}">
                                            <TextBlock Text="Ulozit"/>
                                        </Button>
                                    </Grid>
                                    <controls:EmptyState IsVisible="{Binding !HasSelectedCreatorNoteDocument}" Icon="{StaticResource IconFolder}" Title="Vyber dokument vlevo" Subtitle="Po vyberu muzes okamzite upravovat obsah aktivni poznamky."/>
                                    <TextBox Text="{Binding CreatorNoteEditorContent, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="600" IsVisible="{Binding HasSelectedCreatorNoteDocument}" IsReadOnly="{Binding IsCreatorWorkspaceReadOnly}" FontFamily="Consolas, Cascadia Mono, monospace" Watermark="Pis poznamky..."/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- Wiki mode -->
                        <Grid ColumnDefinitions="300,16,*,16,300" IsVisible="{Binding IsCreatorNotesModeWiki}">
                            <Border Grid.Column="0" Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Wiki stranky" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <controls:EmptyState IsVisible="{Binding !HasCreatorWikiDocuments}" Icon="{StaticResource IconFolder}" Title="Zadne wiki stranky" Subtitle="Vytvor wiki stranku a prolinkuj ji pres [[NazevStranky]]."/>
                                    <ListBox ItemsSource="{Binding CreatorWikiDocuments}" SelectedItem="{Binding SelectedCreatorNoteDocument}" IsVisible="{Binding HasCreatorWikiDocuments}" MaxHeight="720">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="creatorModels:CreatorNoteDocument">
                                                <Grid ColumnDefinitions="*,Auto" Margin="2">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding LinkSummary}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                            <TextBlock Text="{Binding ModifiedLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Command="{Binding #StreamingToolsRoot.DataContext.DeleteCreatorNoteDocumentCommand}" CommandParameter="{Binding}" Classes="ghost" Padding="6,4" FontSize="10" VerticalAlignment="Center" IsEnabled="{Binding #StreamingToolsRoot.DataContext.IsCreatorWorkspaceEditable}">
                                                        <TextBlock Text="X" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding SelectedCreatorNoteDocument.Title, FallbackValue='Vyber wiki stranku'}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CreatorSelectedNoteLinkSummary}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                    <controls:EmptyState IsVisible="{Binding !HasSelectedCreatorNoteDocument}" Icon="{StaticResource IconFolder}" Title="Vyber wiki stranku vlevo" Subtitle="Po vyberu muzes editovat obsah a prochazet navazane odkazy."/>
                                    <TextBox Text="{Binding CreatorNoteEditorContent, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="620" IsVisible="{Binding HasSelectedCreatorNoteDocument}" IsReadOnly="{Binding IsCreatorWorkspaceReadOnly}" FontFamily="Consolas, Cascadia Mono, monospace" Watermark="Pouzij [[NazevStranky]] pro wiki odkazy..."/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Wiki odkazy" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Aktivni stranka muze odkazovat na dalsi dokumenty v notes workspace." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                    <controls:EmptyState IsVisible="{Binding !HasSelectedCreatorNoteDocument}" Icon="{StaticResource IconInfo}" Title="Bez aktivni stranky" Subtitle="Vyber wiki dokument pro kontext odkazu."/>
                                    <controls:EmptyState IsVisible="{Binding ShowCreatorWikiLinksEmptyState}" Icon="{StaticResource IconInfo}" Title="Zatim zadne wiki odkazy" Subtitle="Pridej do obsahu syntax [[NazevStranky]] a po ulozeni se objevi tady."/>
                                    <ItemsControl ItemsSource="{Binding SelectedCreatorNoteDocument.LinkedTitles}" IsVisible="{Binding HasSelectedCreatorNoteLinks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding #StreamingToolsRoot.DataContext.OpenCreatorWikiLinkCommand}" CommandParameter="{Binding}" Background="{DynamicResource BgElevatedBrush}" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                                    <TextBlock Text="{Binding .}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="300,16,*,16,320" IsVisible="{Binding IsCreatorNotesModeCanvas}">
                            <Border Grid.Column="0" Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Canvas grafy" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <controls:EmptyState IsVisible="{Binding !HasCreatorCanvasGraphs}" Icon="{StaticResource IconInfo}" Title="Zadne canvas grafy" Subtitle="Vytvor novy graph primo z Notes tabu."/>
                                    <ListBox ItemsSource="{Binding CreatorCanvasGraphs}" SelectedItem="{Binding SelectedCreatorCanvasGraph}" IsVisible="{Binding HasCreatorCanvasGraphs}" MaxHeight="720">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="creatorModels:CreatorCanvasGraph">
                                                <Grid ColumnDefinitions="*,Auto" Margin="2">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Summary}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                            <TextBlock Text="{Binding FileName}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Command="{Binding #StreamingToolsRoot.DataContext.DeleteCreatorCanvasGraphCommand}" CommandParameter="{Binding}" Classes="ghost" Padding="6,4" FontSize="10" VerticalAlignment="Center" IsEnabled="{Binding #StreamingToolsRoot.DataContext.IsCreatorWorkspaceEditable}">
                                                        <TextBlock Text="X" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Canvas editor" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CreatorSelectedCanvasGraphStatus}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding CreateCreatorCanvasNodeCommand}" Classes="secondary" Padding="12,8" VerticalAlignment="Top" IsEnabled="{Binding HasSelectedCreatorCanvasGraph}">
                                            <TextBlock Text="Pridat uzel"/>
                                        </Button>
                                        <Button Grid.Column="2" Command="{Binding SaveCreatorCanvasGraphCommand}" Classes="primary" Padding="12,8" VerticalAlignment="Top" IsEnabled="{Binding CanSaveCreatorCanvasGraph}">
                                            <TextBlock Text="Ulozit graph"/>
                                        </Button>
                                    </Grid>

                                    <controls:EmptyState IsVisible="{Binding !HasSelectedCreatorCanvasGraph}" Icon="{StaticResource IconInfo}" Title="Vyber graph vlevo" Subtitle="Po vyberu muzes upravovat nazev, uzly a propojeni."/>

                                    <StackPanel Spacing="10" IsVisible="{Binding HasSelectedCreatorCanvasGraph}">
                                        <TextBox Text="{Binding SelectedCreatorCanvasGraph.Name, UpdateSourceTrigger=PropertyChanged}" Watermark="Nazev graphu" IsReadOnly="{Binding IsCreatorWorkspaceReadOnly}"/>

                                        <controls:EmptyState IsVisible="{Binding !HasSelectedCreatorCanvasGraphNodes}" Icon="{StaticResource IconInfo}" Title="Graph je prazdny" Subtitle="Pridej prvni uzel a zacni skladat progression flow."/>

                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560" IsVisible="{Binding HasSelectedCreatorCanvasGraphNodes}">
                                            <ItemsControl ItemsSource="{Binding SelectedCreatorCanvasGraph.Nodes}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="creatorModels:CreatorCanvasNode">
                                                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                                <StackPanel Spacing="6">
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="10,4">
                                                                            <TextBlock Text="{Binding TypeIcon}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}" FontWeight="SemiBold"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                                        <TextBlock Text="{Binding ConnectionSummary}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                        <TextBlock Text="{Binding LinkedFilePath}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <Button Grid.Column="1" Command="{Binding #StreamingToolsRoot.DataContext.SelectCreatorCanvasNodeCommand}" CommandParameter="{Binding}" Classes="secondary" Padding="10,6" FontSize="10" VerticalAlignment="Top">
                                                                    <TextBlock Text="Detail"/>
                                                                </Button>
                                                                <Button Grid.Column="2" Command="{Binding #StreamingToolsRoot.DataContext.DeleteCreatorCanvasNodeCommand}" CommandParameter="{Binding}" Classes="ghost" Padding="10,6" FontSize="10" VerticalAlignment="Top" IsEnabled="{Binding #StreamingToolsRoot.DataContext.IsCreatorWorkspaceEditable}">
                                                                    <TextBlock Text="Smazat" Foreground="{DynamicResource WarningBrush}"/>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Classes="card">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Inspektor uzlu" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CreatorSelectedCanvasNodeStatus}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        <controls:EmptyState IsVisible="{Binding !HasSelectedCreatorCanvasNode}" Icon="{StaticResource IconInfo}" Title="Vyber uzel" Subtitle="V detailu muzes menit typ, popis, navazany soubor i propojeni."/>

                                        <StackPanel Spacing="12" IsVisible="{Binding HasSelectedCreatorCanvasNode}">
                                            <TextBox Text="{Binding SelectedCreatorCanvasNode.Label, UpdateSourceTrigger=PropertyChanged}" Watermark="Nazev uzlu" IsReadOnly="{Binding IsCreatorWorkspaceReadOnly}"/>
                                            <ComboBox ItemsSource="{Binding CreatorCanvasNodeTypes}" SelectedItem="{Binding SelectedCreatorCanvasNode.NodeType}" IsEnabled="{Binding IsCreatorWorkspaceEditable}"/>
                                            <TextBox Text="{Binding SelectedCreatorCanvasNode.Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" Watermark="Co tenhle uzel resi?" IsReadOnly="{Binding IsCreatorWorkspaceReadOnly}"/>
                                            <TextBox Text="{Binding SelectedCreatorCanvasNode.LinkedFilePath, UpdateSourceTrigger=PropertyChanged}" Watermark="Relativni cesta k souboru" IsReadOnly="{Binding IsCreatorWorkspaceReadOnly}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Command="{Binding UseCurrentCreatorFileForCanvasNodeCommand}" Classes="secondary" Padding="12,8" IsEnabled="{Binding IsCreatorWorkspaceEditable}">
                                                    <TextBlock Text="Pouzit soubor z Files"/>
                                                </Button>
                                                <Button Command="{Binding OpenCreatorCanvasNodeLinkedFileCommand}" Classes="ghost" Padding="12,8" IsEnabled="{Binding SelectedCreatorCanvasNode.HasLinkedFile}">
                                                    <TextBlock Text="Otevrit ve Files"/>
                                                </Button>
                                            </StackPanel>

                                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Navazane uzly" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <controls:EmptyState IsVisible="{Binding !HasCreatorCanvasConnectedNodes}" Icon="{StaticResource IconInfo}" Title="Zadne vazby" Subtitle="Vyber uzly ze seznamu nize a vytvor progression flow."/>
                                                    <ItemsControl ItemsSource="{Binding CreatorCanvasConnectedNodes}" IsVisible="{Binding HasCreatorCanvasConnectedNodes}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="creatorModels:CreatorCanvasNode">
                                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,6">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                        <TextBlock Text="{Binding TypeIcon}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                    </StackPanel>
                                                                    <Button Grid.Column="1" Command="{Binding #StreamingToolsRoot.DataContext.UnlinkCreatorCanvasNodeCommand}" CommandParameter="{Binding}" Classes="ghost" Padding="10,4" FontSize="10" IsEnabled="{Binding #StreamingToolsRoot.DataContext.IsCreatorWorkspaceEditable}">
                                                                        <TextBlock Text="Odpojit" Foreground="{DynamicResource WarningBrush}"/>
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Dostupne pro propojeni" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <controls:EmptyState IsVisible="{Binding !HasCreatorCanvasAvailableNodes}" Icon="{StaticResource IconInfo}" Title="Zadne dalsi uzly" Subtitle="Pridavej nove uzly do graphu nebo zmen fokus na jiny node."/>
                                                    <ItemsControl ItemsSource="{Binding CreatorCanvasAvailableNodes}" IsVisible="{Binding HasCreatorCanvasAvailableNodes}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="creatorModels:CreatorCanvasNode">
                                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,6">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                        <TextBlock Text="{Binding TypeIcon}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                    </StackPanel>
                                                                    <Button Grid.Column="1" Command="{Binding #StreamingToolsRoot.DataContext.LinkCreatorCanvasNodeCommand}" CommandParameter="{Binding}" Classes="secondary" Padding="10,4" FontSize="10" IsEnabled="{Binding #StreamingToolsRoot.DataContext.IsCreatorWorkspaceEditable}">
                                                                        <TextBlock Text="Propojit"/>
                                                                    </Button>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="300,16,*" IsVisible="{Binding IsCreatorNotesModeMindMap}">
                            <Border Grid.Column="0" Classes="card">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Mind map grafy" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <controls:EmptyState IsVisible="{Binding !HasCreatorCanvasGraphs}" Icon="{StaticResource IconInfo}" Title="Zadne mind map data" Subtitle="Mind Map pouziva stejne graphy jako Canvas editor."/>
                                    <ListBox ItemsSource="{Binding CreatorCanvasGraphs}" SelectedItem="{Binding SelectedCreatorCanvasGraph}" IsVisible="{Binding HasCreatorCanvasGraphs}" MaxHeight="720">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="creatorModels:CreatorCanvasGraph">
                                                <StackPanel Spacing="3" Margin="2">
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Summary}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Classes="card">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Mind Map" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CreatorSelectedCanvasGraphStatus}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <controls:EmptyState IsVisible="{Binding !HasSelectedCreatorCanvasGraph}" Icon="{StaticResource IconInfo}" Title="Vyber graph vlevo" Subtitle="Mind Map ukazuje progression uzly nad vybranym grafem."/>
                                        <controls:EmptyState IsVisible="{Binding !HasSelectedCreatorCanvasGraphNodes}" Icon="{StaticResource IconInfo}" Title="Vybrany graph nema uzly" Subtitle="Vrat se do Canvas rezimu a pridej progression nody."/>

                                        <WrapPanel Orientation="Horizontal" ItemWidth="280" IsVisible="{Binding HasSelectedCreatorCanvasGraphNodes}">
                                            <ItemsControl ItemsSource="{Binding SelectedCreatorCanvasGraph.Nodes}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="creatorModels:CreatorCanvasNode">
                                                        <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12" Padding="14" Margin="0,0,12,12" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" Width="260">
                                                            <StackPanel Spacing="8">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="10,4">
                                                                        <TextBlock Text="{Binding TypeIcon}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding ConnectionSummary}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                <TextBlock Text="{Binding LinkedFilePath}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                                <Button Command="{Binding #StreamingToolsRoot.DataContext.SelectCreatorCanvasNodeCommand}" CommandParameter="{Binding}" Classes="secondary" Padding="10,6" HorizontalAlignment="Left">
                                                                    <TextBlock Text="Fokus detail"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </WrapPanel>

                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="14" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding HasSelectedCreatorCanvasNode}">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Fokus uzlu" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding SelectedCreatorCanvasNode.Label}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                <TextBlock Text="{Binding SelectedCreatorCanvasNode.Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding CreatorSelectedCanvasNodeStatus}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>

                                                <TextBlock Text="Napojene uzly" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                                                <controls:EmptyState IsVisible="{Binding !HasCreatorCanvasConnectedNodes}" Icon="{StaticResource IconInfo}" Title="Zadne navaznosti" Subtitle="V Canvas editoru propoj dalsi progression body."/>
                                                <ItemsControl ItemsSource="{Binding CreatorCanvasConnectedNodes}" IsVisible="{Binding HasCreatorCanvasConnectedNodes}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="creatorModels:CreatorCanvasNode">
                                                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,0,6">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding TypeIcon}" FontSize="10" Foreground="{DynamicResource PrimaryBBrush}" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ======== TAB 5 — GIT ======== -->
            <TabItem Header="Git">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="8,4,8,40" MaxWidth="1560">
                        <!-- Git status header -->
                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Git" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="12,6">
                                            <TextBlock Text="{Binding CreatorGitBranchSummary}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                        </Border>
                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="12,6">
                                            <TextBlock Text="{Binding CreatorGitLastCommitLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </Border>
                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="12,6">
                                            <TextBlock Text="{Binding CreatorGitRemoteLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding CreatorGitPullCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Top" IsEnabled="{Binding HasCreatorGitRepository}">
                                    <TextBlock Text="Pull"/>
                                </Button>
                                <Button Grid.Column="2" Command="{Binding CreatorGitPushCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Top" IsEnabled="{Binding HasCreatorGitRepository}">
                                    <TextBlock Text="Push"/>
                                </Button>
                                <Button Grid.Column="3" Command="{Binding RefreshCreatorGitStatusCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Top">
                                    <TextBlock Text="Obnovit"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- No git repo state -->
                        <Border Classes="card" IsVisible="{Binding !HasCreatorGitRepository}">
                            <StackPanel Spacing="14" HorizontalAlignment="Center">
                                <controls:EmptyState Icon="{StaticResource IconInfo}" Title="Workspace nema Git repository" Subtitle="Inicializuj git repository pro verzovani workspace a spolecny vyvoj."/>
                                <Button Command="{Binding CreatorGitInitCommand}" Classes="primary" Padding="20,10" HorizontalAlignment="Center" IsEnabled="{Binding CreatorGitIsAvailable}">
                                    <TextBlock Text="git init"/>
                                </Button>
                                <TextBlock Text="Git musi byt dostupny v PATH." FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" IsVisible="{Binding !CreatorGitIsAvailable}"/>
                            </StackPanel>
                        </Border>

                        <!-- Git with repo -->
                        <Grid ColumnDefinitions="1.1*,16,0.9*" IsVisible="{Binding HasCreatorGitRepository}">
                            <!-- Changes + commit -->
                            <Border Grid.Column="0" Classes="card">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Zmeny" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} zmen, {1} staged">
                                                            <Binding Path="CreatorGitChangesCount"/>
                                                            <Binding Path="CreatorGitStagedCount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding CreatorGitStageAllCommand}" Classes="secondary" Padding="12,8" FontSize="11" VerticalAlignment="Top">
                                            <TextBlock Text="Stage all"/>
                                        </Button>
                                    </Grid>

                                    <controls:EmptyState IsVisible="{Binding !HasCreatorGitChanges}" Icon="{StaticResource IconSuccess}" Title="Zadne zmeny" Subtitle="Working tree je cisty. Vsechny zmeny uz jsou commitnute."/>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400" IsVisible="{Binding HasCreatorGitChanges}">
                                        <ItemsControl ItemsSource="{Binding CreatorGitState.Changes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,6" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="Auto,28,*,Auto,Auto" ColumnSpacing="8">
                                                            <CheckBox IsChecked="{Binding IsStaged, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="6" Width="24" Height="24" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding StatusMarker}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryBBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FilePath}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding StatusLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="3" Command="{Binding DataContext.CreatorGitStageFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Classes="ghost" Padding="8,4" FontSize="10">
                                                                <TextBlock Text="Stage"/>
                                                            </Button>
                                                            <Button Grid.Column="4" Command="{Binding DataContext.CreatorGitRevertFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Classes="ghost" Padding="8,4" FontSize="10">
                                                                <TextBlock Text="Revert" Foreground="{DynamicResource WarningBrush}"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Commit area -->
                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="14" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Commit" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBox Text="{Binding CreatorGitCommitMessage}" Watermark="Commit message..." AcceptsReturn="False" MinHeight="36"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Command="{Binding CreatorGitCommitCommand}" Classes="primary" Padding="14,8" IsEnabled="{Binding CanCreatorGitCommit}">
                                                    <TextBlock Text="Commit"/>
                                                </Button>
                                                <Button Command="{Binding CreatorGitCommitAndPushCommand}" Classes="secondary" Padding="14,8" IsEnabled="{Binding CanCreatorGitCommit}">
                                                    <TextBlock Text="Commit &amp; Push"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- History + branches -->
                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Historie commitu" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <controls:EmptyState IsVisible="{Binding !CreatorGitState.HasChanges}" Icon="{StaticResource IconInfo}" Title="Zatim zadne commity" Subtitle="Po prvnim commitu se tu objevi historie."/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                                        <ItemsControl ItemsSource="{Binding CreatorGitState.RecentCommits}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="8" Padding="8,4" VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding ShortHash}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}" FontFamily="Consolas, Cascadia Mono, monospace"/>
                                                            </Border>
                                                            <StackPanel Grid.Column="1" Spacing="3">
                                                                <TextBlock Text="{Binding Message}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding Author}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                    <TextBlock Text="{Binding TimeAgoLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Branches -->
                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="14" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Branches" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <ItemsControl ItemsSource="{Binding CreatorGitBranches}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ======== TAB 6 — RELEASE ======== -->
            <TabItem Header="Release">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="8,4,8,40" MaxWidth="1560">
                        <!-- Pipeline header -->
                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Release Pipeline" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding CreatorCurrentPipelineStep}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding RefreshCreatorReleasePipelineCommand}" Classes="secondary" Padding="14,8" VerticalAlignment="Top">
                                    <TextBlock Text="Obnovit"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Pipeline step bar -->
                        <Border Classes="card" IsVisible="{Binding HasCreatorReleasePipeline}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding CreatorPipelineSummary}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                <ItemsControl ItemsSource="{Binding CreatorReleasePipeline}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:CompileBindings="False">
                                            <Border CornerRadius="10" Padding="16,10" MinWidth="120" Background="{DynamicResource BgElevatedBrush}" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusMarker}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,16,*">
                            <!-- Validation checks -->
                            <Border Grid.Column="0" Classes="card">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Validace" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CreatorValidationSummary}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <controls:EmptyState IsVisible="{Binding !HasCreatorValidationChecks}" Icon="{StaticResource IconInfo}" Title="Zadne validacni kontroly" Subtitle="Po refreshi pipeline se kontroly vygeneruji automaticky."/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400" IsVisible="{Binding HasCreatorValidationChecks}">
                                        <ItemsControl ItemsSource="{Binding CreatorValidationChecks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,6" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Width="28" Height="28" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding StatusIcon}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <!-- Export profiles -->
                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Export profily" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <controls:EmptyState IsVisible="{Binding !HasCreatorExportProfiles}" Icon="{StaticResource IconInfo}" Title="Zadne export profily" Subtitle="Profily se generuji z manifestu a konfigurace workspace."/>
                                    <ItemsControl ItemsSource="{Binding CreatorExportProfiles}" IsVisible="{Binding HasCreatorExportProfiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:CompileBindings="False">
                                                <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,10" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                    <StackPanel Spacing="8">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="10,4">
                                                                <TextBlock Text="{Binding StatusLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Format}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding BlockerLabel}" FontSize="10" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" IsVisible="{Binding BlockerLabel.Length}"/>
                                                        <Button Command="{Binding DataContext.ExportByProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Classes="primary" Padding="12,6" HorizontalAlignment="Left" IsEnabled="{Binding IsReady}">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="Exportovat" FontSize="11"/>
                                                                <TextBlock Text="{Binding Format}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- VoidPacks registration (WIP) -->
                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="12" Padding="14" BorderBrush="{DynamicResource PrimaryBBrush}" BorderThickness="1" Opacity="0.7">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock Text="Registrovat do VoidPacks" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="999" Padding="10,4">
                                                    <TextBlock Text="WIP" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="Publikuj svuj modpack do centralni databaze VoidPacks. Vyzaduje Void ID a aktivni backend." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                            <Button Classes="secondary" Padding="12,6" HorizontalAlignment="Left" IsEnabled="False">
                                                <TextBlock Text="Pripravujeme..." FontSize="11"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Changelog editor -->
                        <Border Classes="card">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Release notes / Changelog" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Pis changelog pro aktualni verzi. Text se pouzije pri exportu i jako release note." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                <TextBox Text="{Binding CreatorReleaseChangelogContent, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="200" FontFamily="Consolas, Cascadia Mono, monospace" Watermark="## v0.1.0&#x0a;- Prvni release..."/>
                            </StackPanel>
                        </Border>

                        <!-- Existing snapshot/export actions -->
                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,16,*">
                                <Border Grid.Column="0" Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="14,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Snapshoty" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding CreatorWorkspaceContext.SnapshotCount, StringFormat='{}{0} snapshotu'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" Padding="14,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Exporty" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding CreatorWorkspaceContext.ExportArtifactCount, StringFormat='{}{0} exportu'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Vytvorit snapshot" Command="{Binding CreateInstanceBackupCommand}" Classes="secondary" Padding="14,8"/>
                                <Button Content="Otevrit exports" Command="{Binding OpenCreatorExportsWorkspaceCommand}" Classes="secondary" Padding="14,8"/>
                            </StackPanel>
                        </Border>

                        <!-- Release history -->
                        <Border Classes="card" IsVisible="{Binding HasCreatorReleaseHistory}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Release historie" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <ItemsControl ItemsSource="{Binding CreatorReleaseHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:CompileBindings="False">
                                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,8" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="8" Padding="10,6" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Version}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="3">
                                                        <TextBlock Text="{Binding Summary}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding DateLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>

    <!-- ═══════════════════ GLOBAL SEARCH OVERLAY (Ctrl+K) ═══════════════════ -->
    <Border IsVisible="{Binding IsCreatorGlobalSearchOpen}" Background="#CC0D1117" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="16" Width="600" MaxHeight="520" VerticalAlignment="Top" Margin="0,80,0,0" Padding="20" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" BoxShadow="0 8 32 0 #40000000">
            <StackPanel Spacing="14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="{StaticResource IconSearch}" VerticalAlignment="Center" Margin="14,0,8,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="16"/>
                            <TextBox Grid.Column="1" Text="{Binding CreatorGlobalSearchQuery, UpdateSourceTrigger=PropertyChanged}" Watermark="Hledej soubory, mody, poznamky, commity..." BorderThickness="0" Background="Transparent" FontSize="14" Padding="4,12">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding ExecuteCreatorGlobalSearchCommand}"/>
                                    <KeyBinding Gesture="Escape" Command="{Binding ToggleCreatorGlobalSearchCommand}"/>
                                </TextBox.KeyBindings>
                            </TextBox>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" Command="{Binding ToggleCreatorGlobalSearchCommand}" Classes="ghost" Padding="10,8">
                        <TextBlock Text="Esc" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                    </Button>
                </Grid>

                <controls:EmptyState IsVisible="{Binding !HasCreatorGlobalSearchResults}" Icon="{StaticResource IconSearch}" Title="Zadej dotaz" Subtitle="Ctrl+K otevira globalni hledani napric celym Creator Studio."/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380" IsVisible="{Binding HasCreatorGlobalSearchResults}">
                    <ItemsControl ItemsSource="{Binding CreatorGlobalSearchResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Button Command="{Binding DataContext.NavigateCreatorSearchResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" HorizontalAlignment="Stretch">
                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,6" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" HorizontalAlignment="Stretch">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="8" Padding="8,4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Subtitle}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding TargetTab}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Border>
</Panel>
</UserControl>
