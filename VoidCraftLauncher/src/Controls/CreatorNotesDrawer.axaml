<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             x:Class="VoidCraftLauncher.Controls.CreatorNotesDrawer"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding IsCreatorNotesDrawerOpen}">

    <Grid>
        <Border Background="#66000000"/>

        <Border HorizontalAlignment="Right"
                Width="420"
                Background="{DynamicResource BgShellBrush}"
                BorderBrush="{DynamicResource StrokeSoftBrush}"
                BorderThickness="1,0,0,0">
            <Grid RowDefinitions="Auto,*">
                <Border Background="{DynamicResource BgElevatedBrush}" Padding="20,18" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Notes / Canvas Drawer" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Rychly workspace pro poznamky, handoff a canvas flow bez opusteni aktualni creator zalozky." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CloseCreatorNotesDrawerCommand}" Classes="ghost" Padding="8,6" VerticalAlignment="Top">
                            <TextBlock Text="Zavrit"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="20,18,20,20">
                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="16" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Notes workspace" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CreatorNotesWorkspaceStatus}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CreatorWorkspaceContext.NotesPath}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                <Button Command="{Binding OpenCreatorNotesWorkspaceCommand}" Classes="secondary" Padding="12,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                    <TextBlock Text="Otevrit notes workspace"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="16" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Aktivni handoff" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CreatorDockSubtitle}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CreatorLastActivityLabel}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="Snapshot-before-apply guard zustava aktivni i pri praci v draweru." FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="15"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="16" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" IsVisible="{Binding HasCreatorRecentWorkspaces}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Posledni workspaces" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <ItemsControl ItemsSource="{Binding CreatorWorkspaceContext.RecentWorkspaces}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:CompileBindings="False">
                                            <Border Background="{DynamicResource BgInteractiveBrush}" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding LastAccessedUtc, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>