<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             xmlns:converters="using:VoidCraftLauncher.Converters"
             xmlns:controls="using:VoidCraftLauncher.Controls"
             xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="VoidCraftLauncher.Controls.LibraryView"
             x:DataType="vm:MainViewModel"
             x:Name="LibraryRoot">

    <UserControl.Resources>
        <converters:ObjectEqualityConverter x:Key="ObjectEqualityConverter"/>
        <converters:ObjectInequalityConverter x:Key="ObjectInequalityConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BgShellBrush}" Padding="24,16"
                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="←" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="→" FontSize="18" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Knihovna" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="{Binding Greeting}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <Border Padding="28,20,28,60">
                <StackPanel Spacing="20">

                    <!-- Empty State -->
                    <StackPanel IsVisible="{Binding !InstalledModpacks.Count}" HorizontalAlignment="Center" Margin="0,32,0,0" Spacing="8">
                        <controls:EmptyState Icon="{StaticResource IconLibrary}"
                                             Title="Žádné instance"
                                             Subtitle="Přidejte modpack z prohlížeče nebo vytvořte vlastní instanci"/>
                        <Button Content="+ Vytvořit novou instanci" Command="{Binding OpenCreateProfileModalCommand}"
                                Classes="primary" FontSize="14" Padding="24,12" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Modpack Grid -->
                    <ItemsControl ItemsSource="{Binding InstalledModpacks}" IsVisible="{Binding !!InstalledModpacks.Count}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Grid Margin="0,0,14,14" ClipToBounds="False">
                                    <Grid.Styles>
                                        <Style Selector="Grid.InstanceCard:pointerover">
                                            <Setter Property="RenderTransform" Value="scale(1.02)"/>
                                        </Style>
                                        <Style Selector="Grid.InstanceCard:pointerover Border.InstanceBorder">
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBBrush}"/>
                                            <Setter Property="BoxShadow" Value="0 8 24 0 #44000000, 0 0 12 0 #557c6fff"/>
                                        </Style>
                                        <Style Selector="Grid.InstanceCard:pressed">
                                            <Setter Property="RenderTransform" Value="scale(0.98)"/>
                                        </Style>
                                    </Grid.Styles>

                                    <Grid Classes="InstanceCard">
                                        <Grid.Transitions>
                                            <Transitions>
                                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                            </Transitions>
                                        </Grid.Transitions>

                                        <Border Classes="InstanceBorder" Width="200" Height="265"
                                                Background="{DynamicResource BgShellBrush}" CornerRadius="{DynamicResource RadiusControl}"
                                                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" ClipToBounds="True"
                                            Cursor="Hand"
                                            controls:CardClickBehavior.Command="{Binding #LibraryRoot.DataContext.SelectAndConfigureCommand}"
                                            controls:CardClickBehavior.CommandParameter="{Binding}"
                                            controls:CardClickBehavior.IgnoreClass="PlayButton"
                                                BoxShadow="0 2 8 0 #33000000">
                                            <Border.Transitions>
                                                <Transitions>
                                                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                                                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                                                </Transitions>
                                            </Border.Transitions>

                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="▶ Spustit" Command="{Binding #LibraryRoot.DataContext.SelectAndPlayCommand}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Přeinstalovat" Command="{Binding #LibraryRoot.DataContext.ReinstallModpackContextCommand}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Otevřít složku" Command="{Binding #LibraryRoot.DataContext.OpenModpackFolderContextCommand}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <MenuItem Header="Smazat" Command="{Binding #LibraryRoot.DataContext.DeleteModpackContextCommand}" CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <Grid RowDefinitions="130,*">
                                                <Border Grid.Row="0" CornerRadius="12,12,0,0" ClipToBounds="True" Background="{DynamicResource BgInteractiveBrush}">
                                                    <asyncImage:AdvancedImage Source="{Binding LogoUrl}" Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Row="1" Margin="12,10,12,12" Spacing="4" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                                               TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" LineHeight="17"/>
                                                    <TextBlock Text="{Binding VersionTransitionText}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                                    <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,2,0,0">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{DynamicResource PrimaryB}" Opacity="0.12"/>
                                                        </Border.Background>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Border Width="5" Height="5" CornerRadius="2.5" Background="{DynamicResource PrimaryBBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Připraveno" FontSize="9" Foreground="{DynamicResource PrimaryBBrush}" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Stop overlay -->
                                                <Border Grid.RowSpan="2" Background="#CC0a0a0f" CornerRadius="{DynamicResource RadiusControl}">
                                                    <Border.IsVisible>
                                                        <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                            <Binding Path="#LibraryRoot.DataContext.RunningModpack"/>
                                                            <Binding Path="."/>
                                                        </MultiBinding>
                                                    </Border.IsVisible>
                                                    <Button Command="{Binding #LibraryRoot.DataContext.StopGameCommand}"
                                                            Classes="danger" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            Padding="20,12" CornerRadius="{DynamicResource RadiusSmall}">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="⏹" FontSize="14"/>
                                                            <TextBlock Text="UKONČIT" FontSize="13" FontWeight="Bold"/>
                                                        </StackPanel>
                                                    </Button>
                                                </Border>

                                                <!-- Progress overlay -->
                                                <Border Grid.RowSpan="2" VerticalAlignment="Bottom" CornerRadius="0,0,12,12"
                                                        Padding="12,8" Background="#EE0a0a0f">
                                                    <Border.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="#LibraryRoot.DataContext.IsLaunching"/>
                                                            <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                                <Binding Path="."/>
                                                                <Binding Path="#LibraryRoot.DataContext.TargetModpack"/>
                                                            </MultiBinding>
                                                        </MultiBinding>
                                                    </Border.IsVisible>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="{Binding #LibraryRoot.DataContext.LaunchStatus}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                        <ProgressBar Value="{Binding #LibraryRoot.DataContext.LaunchProgress}" Maximum="100"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- Play FAB -->
                                        <Grid VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,44">
                                            <Grid.IsVisible>
                                                <MultiBinding Converter="{StaticResource ObjectInequalityConverter}">
                                                    <Binding Path="#LibraryRoot.DataContext.RunningModpack"/>
                                                    <Binding Path="."/>
                                                </MultiBinding>
                                            </Grid.IsVisible>
                                            <Border Background="{DynamicResource PrimaryBBrush}" Width="40" Height="40" CornerRadius="20"
                                                    BoxShadow="0 4 12 0 #557c6fff">
                                                <Button Classes="PlayButton"
                                                        Command="{Binding #LibraryRoot.DataContext.SelectAndPlayCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0"
                                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                        CornerRadius="20" Padding="0" Cursor="Hand">
                                                    <TextBlock Text="▶" Foreground="{DynamicResource BgCanvasBrush}" FontSize="16" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Margin="2,0,0,0" IsHitTestVisible="False"/>
                                                </Button>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
