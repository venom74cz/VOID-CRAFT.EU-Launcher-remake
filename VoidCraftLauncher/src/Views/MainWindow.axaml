<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VoidCraftLauncher.ViewModels"
        xmlns:converters="using:VoidCraftLauncher.Converters"
        xmlns:controls="using:VoidCraftLauncher.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="VoidCraftLauncher.Views.MainWindow"
        Icon="avares://VoidCraftLauncher/src/Assets/icon.png"
        x:DataType="vm:MainViewModel"
        x:Name="RootWindow"
        Title="VOID-CRAFT Launcher"
        Width="1350" Height="850"
        MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgCanvasBrush}"
        TransparencyLevelHint="None">

    <Window.Resources>
        <converters:ObjectEqualityConverter x:Key="ObjectEqualityConverter"/>
        <converters:ObjectInequalityConverter x:Key="ObjectInequalityConverter"/>
        <converters:RamValueConverter x:Key="RamValueConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <!-- ╔══════════════════════════════════════════════════════════════╗ -->
    <!-- ║  MODRINTH-STYLE 3-COLUMN LAYOUT                            ║ -->
    <!-- ║  Left Icon Sidebar (64) | Main Content (*) | Right Panel   ║ -->
    <!-- ╚══════════════════════════════════════════════════════════════╝ -->
    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding Config.GlobalUiScale}" ScaleY="{Binding Config.GlobalUiScale}" />
        </LayoutTransformControl.LayoutTransform>

        <Grid x:Name="RootLayout" ColumnDefinitions="Auto,*,Auto,280">

        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║          NAV RAIL (extracted UserControl)        ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <controls:NavRail Grid.Column="0"/>

        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║              MAIN CONTENT AREA                   ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <Border x:Name="MainContentHost" Grid.Column="1" Background="{DynamicResource BgCanvasBrush}" RenderTransform="translateY(0)">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.16" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <Grid>

                <!-- ══════════ VIEW 0: DASHBOARD ══════════ -->
                <controls:DashboardView Classes="view-panel" IsVisible="{Binding IsDashboardView}"/>

                <!-- ══════════ VIEW 1: LIBRARY ══════════ -->
                <controls:LibraryView Classes="view-panel" IsVisible="{Binding IsLibraryView}"/>

                <!-- ══════════ VIEW 2: DISCOVER ══════════ -->
                <controls:DiscoverView Classes="view-panel" IsVisible="{Binding IsDiscoverView}"/>

                <!-- ══════════ VIEW 2A: VOID ID ══════════ -->
                <controls:IdentityView Classes="view-panel" IsVisible="{Binding IsIdentityView}"/>

                <!-- ══════════ VIEW 3: INSTANCE WORKSPACE ══════════ -->
                <controls:InstanceWorkspaceView Classes="view-panel" IsVisible="{Binding IsInstanceDetailView}"/>

                <!-- ══════════ VIEW 4: SETTINGS ══════════ -->
                <controls:SettingsView Classes="view-panel" IsVisible="{Binding IsSettingsView}"/>

                <!-- ══════════ VIEW 5: SKIN STUDIO ══════════ -->
                <controls:SkinStudioView Classes="view-panel" IsVisible="{Binding IsSkinStudioView}"/>

                <!-- ══════════ VIEW 6: ACHIEVEMENTS ══════════ -->
                <controls:AchievementsView Classes="view-panel" IsVisible="{Binding IsAchievementsView}"/>

                <!-- ══════════ VIEW 7: SERVER HUB ══════════ -->
                <controls:ServerHubView Classes="view-panel" IsVisible="{Binding IsServerHubView}"/>

                <!-- ══════════ VIEW 8: NEWS ══════════ -->
                <controls:NewsView Classes="view-panel" IsVisible="{Binding IsNewsView}"/>

                <!-- ══════════ VIEW 9: STREAMING TOOLS ══════════ -->
                <controls:StreamingToolsView Classes="view-panel" IsVisible="{Binding IsStreamingToolsView}"/>

                <!-- ══════════ VIEW 10: FUTURE ══════════ -->
                <controls:FutureView Classes="view-panel" IsVisible="{Binding IsFutureView}"/>

                <!-- ══════════ VIEW 11: THEME SWITCHER ══════════ -->
                <controls:ThemeSwitcherView Classes="view-panel" IsVisible="{Binding IsThemeSwitcherView}"/>

                <!-- ══════════ VIEW 12: LOCALIZATION ══════════ -->
                <controls:LocalizationView Classes="view-panel" IsVisible="{Binding IsLocalizationView}"/>

            </Grid>
        </Border>


        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║      CONTEXT DOCK (extracted UserControl)        ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <GridSplitter Grid.Column="2" Width="6" Background="Transparent" ResizeDirection="Columns" 
                      IsVisible="{Binding IsRightDockHostVisible}" 
                      ZIndex="10"/>

        <Grid x:Name="RightDockHost" Grid.Column="3" MinWidth="240" MaxWidth="1000" IsVisible="{Binding IsRightDockHostVisible}">
            <controls:ContextDock x:Name="ContextDockPanel" IsVisible="{Binding IsStandardContextDockVisible}"/>
            <controls:CreatorArchitektDesk IsVisible="{Binding IsCreatorArchitektDeskVisible}"/>
        </Grid>


        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║               LOGIN MODAL                        ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <Grid Grid.ColumnSpan="4" IsVisible="{Binding IsLoginModalVisible}">
            <Border Background="{DynamicResource BgCanvasBrush}" Opacity="0.82" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <Border Classes="overlay-panel" Background="{DynamicResource BgShellBrush}" CornerRadius="{DynamicResource RadiusCard}"
                    BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Width="440" Padding="0">
                <Border.Effect><DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.85"/></Border.Effect>

                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="16,16,0,0" Padding="28,20"
                            BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Přihlášení" FontSize="22" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Vyberte způsob přihlášení" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✕" Command="{Binding CloseLoginModalCommand}"
                                    Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" FontSize="16"
                                    Padding="6" Cursor="Hand" CornerRadius="{DynamicResource RadiusSmall}" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <Border Grid.Row="1" Padding="28,24">
                        <TabControl>
                            <TabItem Header="Microsoft">
                                <StackPanel Spacing="16" Margin="0,16,0,0">
                                    <TextBlock Text="Bezpečné přihlášení přes Microsoft účet."
                                               TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextAlignment="Center"/>
                                    <Button Content="Přihlásit přes Microsoft" Command="{Binding LoginMicrosoftCommand}"
                                            IsEnabled="{Binding !IsLoginInProgress}"
                                            Classes="accent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="0,14" FontSize="14"/>

                                    <!-- Device code panel -->
                                    <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusSmall}"
                                            Padding="16" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                                            IsVisible="{Binding IsLoginInProgress}">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="{Binding LoginStatus}" Foreground="{DynamicResource WarningBrush}"
                                                       TextWrapping="Wrap" FontSize="11"/>
                                            <TextBlock Text="{Binding ManualLoginCode, StringFormat='Kód: {0}'}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="15"
                                                       IsVisible="{Binding IsLoginInProgress}" HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                <Button Content="Zkopírovat kód" Command="{Binding CopyLoginCodeCommand}"
                                                        Classes="secondary" FontSize="11" Padding="12,6"/>
                                                <Button Content="Otevřít web" Command="{Binding OpenUrlCommand}" CommandParameter="{Binding AuthUrl}"
                                                        Classes="secondary" FontSize="11" Padding="12,6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Offline">
                                <StackPanel Spacing="16" Margin="0,16,0,0">
                                    <TextBlock Text="Hra bez originálu. Skiny nebudou fungovat mimo servery s pluginem."
                                               TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextAlignment="Center"/>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Herní jméno" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                                        <TextBox Text="{Binding OfflineUsername}" Watermark="Player123"/>
                                    </StackPanel>
                                    <Button Content="Přihlásit offline" Command="{Binding LoginOfflineCommand}"
                                            Classes="secondary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="0,14" FontSize="14"/>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <controls:CreateProfileWizard Grid.ColumnSpan="4"/>


        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║          BACKUP PROMPT SHEET (M3)                ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <controls:BackupPromptSheet Grid.ColumnSpan="4"/>

        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║          UPDATE PROMPT SHEET (M3)                ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <controls:UpdatePromptSheet Grid.ColumnSpan="4"/>


        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║          CRASH DIAGNOSTICS DRAWER (M3)           ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <controls:CrashDrawer Grid.ColumnSpan="4"/>

        <controls:CreatorNotesDrawer Grid.ColumnSpan="4"/>


        <!-- ╔══════════════════════════════════════════════════╗ -->
        <!-- ║          TOAST HOST (M3)                         ║ -->
        <!-- ╚══════════════════════════════════════════════════╝ -->
        <controls:ToastHost Grid.ColumnSpan="4"/>

    </Grid>
    </LayoutTransformControl>
</Window>
