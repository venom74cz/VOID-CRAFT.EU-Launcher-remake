<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VoidCraftLauncher.App"
             xmlns:local="using:VoidCraftLauncher"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://VoidCraftLauncher/src/Assets/icon.ico"
                      ToolTipText="VOID-CRAFT Launcher"
                      IsVisible="{Binding IsTrayIconVisible, Source={x:Static local:App.TrayState}}"
                      Command="{Binding RestoreWindowCommand, Source={x:Static local:App.TrayState}}" />
        </TrayIcons>
    </TrayIcon.Icons>
  
    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Background" Value="#111218"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif"/>
        </Style>

        <!-- ===== GLOBAL COLOR PALETTE ===== -->
        <!-- Primary: #1BD96A (Modrinth green)  
             Accent: #0066FF (VoidCraft blue)
             Bg-0: #111218  Bg-1: #1A1B26  Bg-2: #1E2030  Bg-3: #24273A  
             Border: #363A4F  Text: #E2E8F0  Muted: #8892B0  Dimmed: #5B6078 -->

        <!-- ===== SCROLLBAR ===== -->
        <Style Selector="ScrollViewer /template/ ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="#363A4F"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="MinHeight" Value="6"/>
        </Style>
        <Style Selector="ScrollBar:pointerover /template/ Thumb">
            <Setter Property="Background" Value="#5B6078"/>
        </Style>

        <!-- ===== BUTTONS ===== -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1BD96A"/>
            <Setter Property="Foreground" Value="#111218"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22E677"/>
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#17C45D"/>
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#0066FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A75FF"/>
        </Style>
        <Style Selector="Button.accent:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#0052CC"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#24273A"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#363A4F"/>
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8892B0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E2030"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#ED4245"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F04F52"/>
        </Style>

        <!-- ===== NAV BUTTONS (Legacy wide) ===== -->
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8892B0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E2030"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Background" Value="#1E2030"/>
            <Setter Property="Foreground" Value="#1BD96A"/>
        </Style>
        <Style Selector="Button.nav.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E2030"/>
        </Style>

        <!-- ===== NAV ICON BUTTONS (Modrinth narrow sidebar) ===== -->
        <Style Selector="Button.navIcon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="Button.navIcon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E2030"/>
        </Style>
        <Style Selector="Button.navIcon:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.navIcon.active">
            <Setter Property="Background" Value="#1E2030"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.navIcon.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E2030"/>
        </Style>
        <!-- Green left accent bar for active nav -->
        <Style Selector="Button.navIcon.active">
            <Setter Property="BorderBrush" Value="#1BD96A"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
        </Style>

        <!-- ===== TEXT INPUTS ===== -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E2030"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#363A4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1BD96A"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#5B6078"/>
        </Style>

        <!-- ===== COMBO BOX ===== -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#1E2030"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#363A4F"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- ===== TOGGLE SWITCH ===== -->
        <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnobBounds">
            <Setter Property="Background" Value="#1BD96A"/>
        </Style>

        <!-- ===== SLIDER ===== -->
        <Style Selector="Slider /template/ Thumb">
            <Setter Property="Background" Value="#1BD96A"/>
        </Style>
        <Style Selector="Slider /template/ RepeatButton.TrackFilled /template/ Border">
            <Setter Property="Background" Value="#1BD96A"/>
        </Style>

        <!-- ===== PROGRESS BAR ===== -->
        <Style Selector="ProgressBar">
            <Setter Property="Background" Value="#24273A"/>
            <Setter Property="Foreground" Value="#1BD96A"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Height" Value="4"/>
        </Style>

        <!-- ===== TAB CONTROL ===== -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#5B6078"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Foreground" Value="#8892B0"/>
        </Style>
        <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="#1BD96A"/>
            <Setter Property="Height" Value="3"/>
            <Setter Property="CornerRadius" Value="1.5"/>
        </Style>

        <!-- ===== CARDS ===== -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1A1B26"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#24273A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style Selector="Border.card-elevated">
            <Setter Property="Background" Value="#1E2030"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#363A4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

    </Application.Styles>

    <Application.Resources>
        <!-- Named Colors for reference -->
        <SolidColorBrush x:Key="VoidPrimary" Color="#1BD96A"/>
        <SolidColorBrush x:Key="VoidAccent" Color="#0066FF"/>
        <SolidColorBrush x:Key="VoidBg0" Color="#111218"/>
        <SolidColorBrush x:Key="VoidBg1" Color="#1A1B26"/>
        <SolidColorBrush x:Key="VoidBg2" Color="#1E2030"/>
        <SolidColorBrush x:Key="VoidBg3" Color="#24273A"/>
        <SolidColorBrush x:Key="VoidBorder" Color="#363A4F"/>
        <SolidColorBrush x:Key="VoidText" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="VoidMuted" Color="#8892B0"/>
        <SolidColorBrush x:Key="VoidDimmed" Color="#5B6078"/>
        <SolidColorBrush x:Key="VoidDanger" Color="#ED4245"/>
        <SolidColorBrush x:Key="VoidWarning" Color="#FFAA00"/>
    </Application.Resources>
</Application>