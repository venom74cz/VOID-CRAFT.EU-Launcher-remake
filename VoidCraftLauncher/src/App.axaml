<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VoidCraftLauncher.App"
             xmlns:local="using:VoidCraftLauncher"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://VoidCraftLauncher/src/Assets/icon.ico"
                      ToolTipText="VOID-CRAFT Launcher"
                      IsVisible="{Binding IsTrayIconVisible, Source={x:Static local:App.TrayState}}"
                      Command="{Binding RestoreWindowCommand, Source={x:Static local:App.TrayState}}" />
        </TrayIcons>
    </TrayIcon.Icons>

    <!-- ╔══════════════════════════════════════════════════════════════╗ -->
    <!-- ║              VOID-CRAFT OBSIDIAN THEME v2                    ║ -->
    <!-- ║  Tokens → Controls → Motion (loaded in dependency order)    ║ -->
    <!-- ╚══════════════════════════════════════════════════════════════╝ -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://VoidCraftLauncher/src/Themes/ObsidianTokens.axaml"/>
                <ResourceInclude Source="avares://VoidCraftLauncher/src/Themes/ObsidianIcons.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://VoidCraftLauncher/src/Themes/ObsidianControls.axaml"/>
        <StyleInclude Source="avares://VoidCraftLauncher/src/Themes/ObsidianMotion.axaml"/>
    </Application.Styles>

</Application>