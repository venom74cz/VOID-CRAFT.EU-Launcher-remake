<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="VoidCraftLauncher.Controls.NavRail"
             x:DataType="vm:MainViewModel">

    <Border Width="{Binding NavRailWidth}"
            Background="{DynamicResource BgShellBrush}"
            BorderBrush="{DynamicResource BgInteractiveBrush}"
            BorderThickness="0,0,1,0">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Width" Duration="0:0:0.22" Easing="CubicEaseOut"/>
            </Transitions>
        </Border.Transitions>

        <Grid RowDefinitions="Auto,*,Auto">
            <StackPanel Grid.Row="0" Margin="12,18,12,10" Spacing="12">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Width="40" Height="40" CornerRadius="12" Background="{DynamicResource BgPanelBrush}" Padding="4">
                        <Image Source="avares://VoidCraftLauncher/src/Assets/icon.png"
                               Width="32"
                               Height="32"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="1" IsVisible="{Binding IsNavRailExpanded}">
                        <TextBlock Text="VOID-CRAFT" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Desktop launcher" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </Grid>

                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource StrokeSoftBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12"
                        IsVisible="{Binding IsNavRailExpanded}">
                    <StackPanel Spacing="3">
                        <TextBlock Text="{Binding MainPanelTitle}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Greeting}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" MaxWidth="170"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="6" Margin="10,0,10,0">
                    <TextBlock Text="Hlavní" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,4,4,2" IsVisible="{Binding IsNavRailExpanded}"/>

                    <Button Command="{Binding GoToDashboardCommand}" Classes="navRailItem" Classes.active="{Binding IsDashboardView}" ToolTip.Tip="Domů">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconDashboard}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Domů" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Přehled a rychlé akce launcheru" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToHomeCommand}" Classes="navRailItem" Classes.active="{Binding IsLibraryView}" ToolTip.Tip="Knihovna">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconLibrary}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Knihovna" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Nainstalované instance a projekty" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToBrowserCommand}" Classes="navRailItem" Classes.active="{Binding IsDiscoverView}" ToolTip.Tip="Procházet">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconDiscover}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Procházet" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Nové packy a importy" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToIdentityCommand}" Classes="navRailItem" Classes.active="{Binding IsIdentityView}" ToolTip.Tip="VOID ID">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconUser}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="VOID ID" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Webový profil, GitHub a projektové workflow" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Border Height="1" Background="{DynamicResource BgInteractiveBrush}" Margin="4,8"/>
                    <TextBlock Text="Hraní a komunita" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,4,2" IsVisible="{Binding IsNavRailExpanded}"/>

                    <Button Command="{Binding GoToServerHubCommand}" Classes="navRailItem" Classes.active="{Binding IsServerHubView}" ToolTip.Tip="Servery">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconServerHub}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Servery" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Přehled serverů, rychlé připojení a stav" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToNewsCommand}" Classes="navRailItem" Classes.active="{Binding IsNewsView}" ToolTip.Tip="Novinky">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconNews}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Novinky" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Novinky, změny a oznámení" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToAchievementsCommand}" Classes="navRailItem" Classes.active="{Binding IsAchievementsView}" ToolTip.Tip="Úspěchy">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconAchievements}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Úspěchy" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Osobní progres a sezónní data" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToSkinStudioCommand}" Classes="navRailItem" Classes.active="{Binding IsSkinStudioView}" ToolTip.Tip="Skin Studio">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconSkinStudio}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Skin Studio" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Skins, náhled a export" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToStreamingToolsCommand}" Classes="navRailItem" Classes.active="{Binding IsStreamingToolsView}" ToolTip.Tip="Creator Studio">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconStreaming}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Creator Studio" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Branding, vydání a soubory projektu" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToFutureCommand}" Classes="navRailItem" Classes.active="{Binding IsFutureView}" ToolTip.Tip="Roadmapa">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconFuture}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Roadmapa" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Další směr vývoje produktu" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Border Height="1" Background="{DynamicResource BgInteractiveBrush}" Margin="4,8"/>
                    <TextBlock Text="Tvorba" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,4,2" IsVisible="{Binding IsNavRailExpanded}"/>

                    <Button Command="{Binding OpenCreateProfileModalCommand}" Classes="navRailItem" ToolTip.Tip="Nová instance">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{StaticResource IconAdd}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                                <TextBlock Text="Nová instance" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Prázdný profil nebo import" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Spacing="6" Margin="10,0,10,14">
                <Button Command="{Binding CheckForUpdatesCommand}" Classes="navRailItem" ToolTip.Tip="Hledat aktualizace">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{StaticResource IconUpdate}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                        <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                            <TextBlock Text="Aktualizace" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Verze launcheru a přehled změn" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding GoToSettingsCommand}" Classes="navRailItem" Classes.active="{Binding IsSettingsView}" ToolTip.Tip="Nastavení">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{StaticResource IconSettings}" FontSize="18" Width="22" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBBrush}"/>
                        <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                            <TextBlock Text="Nastavení" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Runtime, výkon a instance" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>


                <Button Command="{Binding OpenLoginModalCommand}" Classes="navRailItem" ToolTip.Tip="{Binding UserSession.Username, FallbackValue='Přihlásit se'}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Panel Width="22">
                            <TextBlock Text="{StaticResource IconLogin}" FontSize="18" HorizontalAlignment="Center" IsVisible="{Binding !IsLoggedIn}" Foreground="{DynamicResource PrimaryBBrush}"/>
                            <Border Width="22" Height="22" CornerRadius="11" ClipToBounds="True" IsVisible="{Binding IsLoggedIn}" Background="{DynamicResource BgInteractiveBrush}">
                                <asyncImage:AdvancedImage Width="22" Height="22" Source="{Binding PlayerSkinUrl, FallbackValue='https://crafatar.com/avatars/MHF_Steve?size=32&amp;overlay'}"/>
                            </Border>
                        </Panel>
                        <StackPanel IsVisible="{Binding IsNavRailExpanded}" Spacing="1">
                            <TextBlock Text="Účet" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding UserSession.Username, FallbackValue='Přihlásit se'}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
