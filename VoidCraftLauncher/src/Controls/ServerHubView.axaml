<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoidCraftLauncher.ViewModels"
             xmlns:models="using:VoidCraftLauncher.Models"
             xmlns:controls="using:VoidCraftLauncher.Controls"
             xmlns:asyncImage="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:converters="using:VoidCraftLauncher.Converters"
             x:Class="VoidCraftLauncher.Controls.ServerHubView"
             x:DataType="vm:MainViewModel"
             x:Name="ServerHubRoot">

    <Grid RowDefinitions="Auto,*">

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BgShellBrush}" Padding="24,16"
                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{StaticResource IconServerHub}" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="Server Hub" FontSize="18" FontWeight="ExtraBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="secondary"
                        FontSize="12" Padding="16,8" Command="{Binding RefreshDiscoveredServersCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{StaticResource IconRefresh}"/>
                        <TextBlock Text="Detekovat z instancí"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Classes="primary"
                        FontSize="12" Padding="16,8" Command="{Binding OpenAddServerCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{StaticResource IconAdd}"/>
                        <TextBlock Text="Přidat server"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="24" Margin="32,28,32,60" MaxWidth="900">

                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{DynamicResource RadiusControl}"
                        Padding="18,16" BorderBrush="{DynamicResource PrimaryBBrush}" BorderThickness="1"
                        IsVisible="{Binding IsLaunching}">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Quick Connect připravuje spuštění" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding LaunchStatus}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding TargetModpack.Name, FallbackValue='Minecraft'}"
                                       FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <ProgressBar Classes="smooth" Value="{Binding LaunchProgress}" Maximum="100"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{DynamicResource RadiusControl}"
                        Padding="20" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1"
                        IsVisible="{Binding IsAddServerSheetOpen}">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Přidat vlastní server" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Button Grid.Column="1" Command="{Binding CloseAddServerCommand}"
                                    Classes="ghost" FontSize="12" Padding="8,4">
                                <TextBlock Text="{StaticResource IconClose}"/>
                            </Button>
                        </Grid>
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Název" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NewServerName}" Watermark="Např. Private SMP"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Adresa" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NewServerAddress}" Watermark="play.example.net"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Port" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <NumericUpDown Value="{Binding NewServerPort}" Minimum="1" Maximum="65535"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Navázaná instance" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <ComboBox ItemsSource="{Binding NewServerModpackOptions}" SelectedItem="{Binding SelectedNewServerModpackOption}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:SelectionOption">
                                            <TextBlock Text="{Binding Label}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Vybraný modpack se použije pro Quick Connect a pro automatické otevření správné instance po spuštění hry."
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" LineHeight="18"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <ToggleSwitch IsChecked="{Binding NewServerAutoConnect}" OnContent="" OffContent=""/>
                                <TextBlock Text="Po startu hry se pokusit o auto-connect" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Uložit server" Classes="primary" Padding="18,10"
                                    Command="{Binding SaveCustomServerCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- VOID-CRAFT pinned server -->
                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{DynamicResource RadiusCard}"
                        Padding="0" BorderBrush="{DynamicResource PrimaryBBrush}" BorderThickness="1"
                        ClipToBounds="True">

                    <!-- Header gradient bar -->
                    <Grid RowDefinitions="Auto,Auto">
                        <Border Grid.Row="0" Padding="24,20"
                                Background="{DynamicResource BgElevatedBrush}">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="16">
                                <!-- Server icon -->
                                <Border Width="56" Height="56" CornerRadius="{DynamicResource RadiusControl}"
                                        ClipToBounds="True">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource PrimaryB}" Opacity="0.15"/>
                                    </Border.Background>
                                    <Grid>
                                        <TextBlock Text="{StaticResource IconServerHub}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   IsVisible="{Binding PinnedServer.IconUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                        <asyncImage:AdvancedImage Source="{Binding PinnedServer.IconUrl}" Stretch="UniformToFill"
                                                                 IsVisible="{Binding PinnedServer.IconUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </Grid>
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding PinnedServer.Name}" FontSize="20" FontWeight="ExtraBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Border Background="{DynamicResource PrimaryBBrush}" CornerRadius="{DynamicResource RadiusPill}"
                                                Padding="8,3">
                                            <TextBlock Text="Pinned" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource BgCanvasBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding PinnedServer.Address}" FontSize="13" FontFamily="Consolas,monospace"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Status -->
                                <Border Grid.Column="2" VerticalAlignment="Center">
                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    IsVisible="{Binding IsServerOnline}"/>
                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Background="{DynamicResource DangerBrush}"
                                                    IsVisible="{Binding !IsServerOnline}"/>
                                            <TextBlock Text="Online" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" IsVisible="{Binding IsServerOnline}"/>
                                            <TextBlock Text="Offline" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" IsVisible="{Binding !IsServerOnline}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding PinnedServer.PlayerCountLabel}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Actions -->
                                <StackPanel Grid.Column="3" Spacing="6" VerticalAlignment="Center">
                                    <Button Content="▶ Připojit se" Classes="primary" FontSize="12" Padding="16,8" Cursor="Hand"
                                            Command="{Binding QuickConnectCommand}" CommandParameter="{Binding PinnedServer}"/>
                                    <Button Command="{Binding CopyServerIpCommand}" CommandParameter="{Binding PinnedServer}"
                                            Classes="secondary" FontSize="11" Padding="12,6" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{StaticResource IconCopy}"/>
                                            <TextBlock Text="Kopírovat IP"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Server details row -->
                        <Border Grid.Row="1" Padding="24,14"
                                BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Modpack" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PinnedServer.LinkedModpackName}" FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Mody" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PinnedServer.LinkedModCountLabel}" FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Verze" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PinnedServer.RequiredMcVersion}" FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Dynmapa" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <Button Content="Otevřít ↗" Command="{Binding OpenUrlCommand}"
                                            CommandParameter="http://mc.void-craft.eu:25566/"
                                            Background="Transparent" Foreground="{DynamicResource AccentTealBrush}"
                                            FontSize="12" FontWeight="Bold" Padding="0" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Quick Connect section header -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Další servery" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Vlastní a komunitní servery s rychlým připojením"
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <controls:EmptyState IsVisible="{Binding !HasCommunityServers}"
                                     Icon="{StaticResource IconServerHub}"
                                     Title="Zatím tu máš jen VOID-CRAFT"
                                     Subtitle="Přidej vlastní server, naváž ho na modpack a použij stejný Quick Connect flow jako pro hlavní server."/>

                <ItemsControl ItemsSource="{Binding CommunityServers}" IsVisible="{Binding HasCommunityServers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ServerInfo">
                            <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{DynamicResource RadiusControl}"
                                    Padding="20" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                    <Border Width="52" Height="52" CornerRadius="{DynamicResource RadiusControl}"
                                            Background="{DynamicResource BgInteractiveBrush}" ClipToBounds="True">
                                        <Grid>
                                            <TextBlock Text="{StaticResource IconServerHub}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding IconUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                            <asyncImage:AdvancedImage Source="{Binding IconUrl}" Stretch="UniformToFill"
                                                                     IsVisible="{Binding IconUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <Border Background="{DynamicResource BgElevatedBrush}" CornerRadius="{DynamicResource RadiusPill}" Padding="8,3">
                                                <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Border>
                                                <Border Background="{DynamicResource PrimaryBBrush}" Opacity="0.14" CornerRadius="{DynamicResource RadiusPill}" Padding="8,3"
                                                        IsVisible="{Binding IsAutoDiscovered}">
                                                    <TextBlock Text="Auto" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource PrimaryBBrush}"/>
                                                </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Address}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas,monospace"/>
                                        <TextBlock Text="{Binding DiscoverySource}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                                   IsVisible="{Binding IsAutoDiscovered}" TextWrapping="Wrap"/>
                                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="Modpack:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding LinkedModpackName, FallbackValue='Nenavázáno'}" FontSize="11" Foreground="{DynamicResource PrimaryBBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="MC / mody:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding RequiredMcVersion, FallbackValue='libovolná'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="•" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding LinkedModCountLabel}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="Hráči:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding PlayerCountLabel}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="▶ Připojit se" Classes="primary" Padding="14,8"
                                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).QuickConnectCommand}"
                                                CommandParameter="{Binding}"/>
                                        <Button Classes="secondary" Padding="12,6"
                                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CopyServerIpCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{StaticResource IconCopy}"/>
                                                <TextBlock Text="Kopírovat IP"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="ghost" Padding="12,6"
                                                Foreground="{DynamicResource DangerBrush}"
                                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).RemoveServerCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{StaticResource IconTrash}"/>
                                                <TextBlock Text="Odebrat"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- How it works -->
                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{DynamicResource RadiusControl}"
                        Padding="20" BorderBrush="{DynamicResource StrokeSoftBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Jak funguje Quick Connect?" FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="{DynamicResource PrimaryBBrush}" Opacity="0.15">
                                    <TextBlock Text="1" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Klikněte na 'Připojit se' u serveru"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="{DynamicResource PrimaryBBrush}" Opacity="0.15">
                                    <TextBlock Text="2" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Launcher automaticky stáhne a nainstaluje správný modpack"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="{DynamicResource PrimaryBBrush}" Opacity="0.15">
                                    <TextBlock Text="3" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Po startu hry se automaticky připojíte na server"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
